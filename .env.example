# 이 파일을 .env로 복사한 뒤 필요한 값만 채우세요.
# 공개 현재가/캔들 조회 명령은 API 키가 없어도 동작합니다.
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

UPBIT_BASE_URL=https://api.upbit.com
UPBIT_MARKET=KRW-BTC
# 여러 코인을 동시에 감시하려면 쉼표로 추가하세요.
UPBIT_MARKETS=KRW-BTC,KRW-ETH,KRW-XRP,KRW-SOL,KRW-DOGE,KRW-ADA,KRW-AVAX,KRW-LINK,KRW-DOT,KRW-TRX
UPBIT_CANDLE_UNIT=5
UPBIT_CANDLE_COUNT=80

STRATEGY_SHORT_WINDOW=5
STRATEGY_LONG_WINDOW=20
# 선택 가능: maeuknam_cards, alex_method, adaptive_learning, guarded_momentum, probability_edge, sma_cross, breakout,
# mean_reversion, rsi_reversal, macd_cross, bollinger_band, stochastic, ichimoku_trend, vwap_reversion, donchian_channel
STRATEGY_NAME=maeuknam_cards
STRATEGY_MIN_TREND_PCT=0.12
STRATEGY_MIN_VOLUME_RATIO=1.02
STRATEGY_MAX_VOLATILITY_PCT=9
STRATEGY_PULLBACK_SELL_PCT=4
# 과거 학습 버튼이 전략별 백테스트에 사용할 분봉 개수입니다.
LEARNING_CANDLE_COUNT=400
# 0이면 제한 없음. 전체 KRW 학습을 테스트용으로 줄이고 싶으면 숫자를 넣으세요.
LEARNING_MAX_MARKETS=0
# 전체 KRW 학습 시 업비트 유의/주의 종목을 제외합니다.
LEARNING_EXCLUDE_MARKET_WARNINGS=true

# true이면 몇 초 단위로 학습 모델 + 현재 틱/분봉 상황을 결합해 순간 판단을 수행합니다.
REALTIME_DECISION_ENABLED=true
REALTIME_DECISION_INTERVAL_SECONDS=5
REALTIME_WATCH_TOP_N=0
REALTIME_CANDLE_TOP_N=60
REALTIME_CANDLE_REFRESH_SECONDS=60
REALTIME_CANDIDATE_TOP_N=12
REALTIME_MIN_SCORE=0.18
REALTIME_MAX_ORDER_PCT=1
REALTIME_LOW_VOLATILITY_PCT=0.30
REALTIME_STAGNATION_EXIT_SECONDS=900
REALTIME_STAGNATION_TREND_PCT=0.20
REALTIME_STAGNATION_VOLUME_RATIO=1.10
REALTIME_IDLE_EXIT_SECONDS=3600
REALTIME_IDLE_EXIT_RETURN_PCT=0.30
REALTIME_IDLE_EXIT_TREND_PCT=0.40
REALTIME_WEAK_BREAKOUT_ENABLED=false
REALTIME_WEAK_BREAKOUT_SCORE_BUFFER=0.25
REALTIME_RECOVERY_SCOUT_ENABLED=false
REALTIME_RECOVERY_SCOUT_MAX_POSITION_PCT=0.35

# 주문 후보마다 업비트 누적 호가를 확인해 예상 체결가, 슬리피지, 권장 수량을 보정합니다.
ORDERBOOK_ANALYSIS_ENABLED=true
ORDERBOOK_DEPTH_LEVELS=15
ORDERBOOK_MAX_SLIPPAGE_PCT=0.50
ORDERBOOK_MIN_FILL_RATIO=0.95
ORDERBOOK_MIN_DEPTH_RATIO=0.35
ORDERBOOK_LIQUIDITY_USE_PCT=0.35
ORDERBOOK_REPRICE_SPREAD_PCT=0.12
ORDERBOOK_PRICE_STEP_BPS=5
ORDERBOOK_HARD_MAX_SPREAD_PCT=0.80
ORDERBOOK_MIN_VISIBLE_ASK_KRW=50000
ORDERBOOK_MIN_VISIBLE_BID_KRW=50000

# Stronger entry protection. These filters block new buys in crash, overheat,
# low-liquidity, and repeated-loss regimes.
RISK_CRASH_GUARD_ENABLED=true
RISK_CRASH_1M_DROP_PCT=1.0
RISK_CRASH_5M_DROP_PCT=2.5
RISK_CRASH_30M_DROP_PCT=6
RISK_CRASH_DRAWDOWN_PCT=8
RISK_CRASH_VOLATILITY_PCT=7
RISK_OVERHEAT_DAY_CHANGE_PCT=18
RISK_OVERHEAT_1M_REVERSAL_PCT=-0.35
RISK_OVERHEAT_RANGE_POSITION_PCT=92
RISK_OVERHEAT_VOLUME_RATIO=3
RISK_MAX_CONSECUTIVE_LOSSES=2
RISK_STRATEGY_MAX_CONSECUTIVE_LOSSES=1
RISK_SAME_PATTERN_MAX_CONSECUTIVE_LOSSES=1
RISK_GLOBAL_MAX_CONSECUTIVE_LOSSES=4
RISK_LOSS_STREAK_COOLDOWN_MINUTES=180
RISK_MARKET_MIN_TRADE_VALUE_24H_KRW=300000000
RISK_MIN_CANDLE_TRADE_VALUE_KRW=10000000
RISK_MIN_ENTRY_SCORE_BUFFER=0.08
RISK_CHASE_5M_RISE_PCT=3.5
RISK_CHASE_30M_RISE_PCT=8
RISK_CHASE_RANGE_POSITION_PCT=88
RISK_CHASE_VOLUME_RATIO=2.2
RISK_MIN_TRADE_PRESSURE=-1.4
RISK_REGIME_GUARD_ENABLED=true
RISK_REGIME_MIN_MARKET_COUNT=3
RISK_REGIME_TREND_WINDOW_CANDLES=12
RISK_REGIME_MIN_POSITIVE_RATIO=0.38
RISK_REGIME_SOFT_POSITIVE_RATIO=0.48
RISK_REGIME_RISK_ON_POSITIVE_RATIO=0.62
RISK_REGIME_MAX_CRASH_RATIO=0.28
RISK_REGIME_CRASH_TREND_PCT=2.5
RISK_REGIME_MIN_AVG_TREND_PCT=-1.0

# true이면 페이퍼 자동 실행이 짧은 주기로 전체 KRW 학습 모델 기반 동적 자금 배분을 수행합니다.
DYNAMIC_ALLOCATION_ENABLED=false
ALLOCATION_INTERVAL_SECONDS=300
ALLOCATION_TOP_N=8
ALLOCATION_FOCUS_TOP_N=3
ALLOCATION_FOCUS_SCORE_GAP=0.12
ALLOCATION_MIN_SCORE=0.02
ALLOCATION_MAX_DEPLOY_PCT=1
ALLOCATION_MAX_POSITION_PCT=1
ALLOCATION_MAX_ORDERS_PER_RUN=3

PAPER_CASH_KRW=1000000
GOAL_START_KRW=1000000
GOAL_TARGET_KRW=100000000
GOAL_DAYS=30
GOAL_SCHEDULER_TRADING_ENABLED=false
GOAL_SCHEDULER_MAX_ENTRY_RELIEF=0.08
GOAL_SCHEDULER_MAX_DEPLOY_BOOST=0.40
GOAL_SCHEDULER_MAX_ORDER_BOOST=0.25
GOAL_SCHEDULER_MAX_POSITION_BOOST=0.35
RISK_MIN_ORDER_KRW=5000
RISK_MAX_ORDER_KRW=100000000
RISK_MAX_POSITION_KRW=100000000
RISK_DAILY_LOSS_LIMIT_KRW=50000
RISK_STOP_LOSS_PCT=3
RISK_TAKE_PROFIT_PCT=6
RISK_COOLDOWN_SECONDS=900
RISK_MAX_OPEN_POSITIONS=50
RISK_MAX_DAILY_ORDERS=80
RISK_FEE_RATE=0.0005

# true로 바꾸면 웹 서버 시작 시 페이퍼 자동 스캔 루프가 켜집니다.
AUTO_RUN_ENABLED=false

# 대시보드를 LAN/모바일에서 볼 때는 로그인 보호를 켜세요.
# 기본값은 로컬 PC 전용 운영을 방해하지 않기 위해 false입니다.
DASHBOARD_AUTH_ENABLED=false
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=

OPS_ALERTS_ENABLED=true

# 실거래는 이중 잠금입니다.
# 1. LIVE_TRADING_ENABLED=true
# 2. LIVE_ORDER_CONFIRMATION=실거래 손실 동의
#    한글 입력이 어려운 서버/터미널에서는 LIVE_ORDER_CONFIRMATION=LIVE-RISK-ACCEPTED
# 3. CLI 실행 시 --live 플래그 또는 별도 웹 실거래 허용이 필요합니다.
LIVE_TRADING_ENABLED=false
WEB_LIVE_TRADING_ENABLED=false
LIVE_TEST_ORDER_ENABLED=false
LIVE_ORDER_CONFIRMATION=

# AI PM bridge: read-only program-to-model supervisor.
AI_PM_ENABLED=false
AI_PM_MODEL=gpt-5
AI_PM_INTERVAL_SECONDS=60
AI_PM_MAX_CANDIDATES=8
OPENAI_API_KEY=

TRADING_STATE_FILE=state/paper_state.json
EVENT_LOG_FILE=state/events.jsonl
DATABASE_FILE=state/autotrading.sqlite3
LOOP_SLEEP_SECONDS=60

BINANCE_BASE_URL=https://api.binance.com
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
BINANCE_FUTURES_TESTNET_ENABLED=false
BINANCE_FUTURES_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,DOGEUSDT,BNBUSDT,ADAUSDT,AVAXUSDT,LINKUSDT,LTCUSDT
BINANCE_FUTURES_API_KEY=
BINANCE_FUTURES_SECRET_KEY=

# 웹 대시보드 실행 설정입니다.
AUTOTRADING_HOST=127.0.0.1
AUTOTRADING_PORT=8000
# 기본값은 현재 폴더의 .env입니다. 다른 파일을 쓰려면 경로를 넣으세요.
AUTOTRADING_ENV_FILE=.env
