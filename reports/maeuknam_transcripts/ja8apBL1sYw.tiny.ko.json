    {
      "start": 1933.05,
      "end": 1937.05,
      "text": "조금만 더 보유물이랭도 많이 나오고 되었는데"
    },
    {
      "start": 1937.05,
      "end": 1940.05,
      "text": "그냥 10체 우리 합쳐서 이 정도 조정 받았으면"
    },
    {
      "start": 1940.05,
      "end": 1942.65,
      "text": "저는 적당선의 조정인 것 같아요."
    },
    {
      "start": 1942.65,
      "end": 1945.85,
      "text": "옛날 같았으면 이렇게 하락했거든요."
    },
    {
      "start": 1945.85,
      "end": 1949.05,
      "text": "지금 여기까지만 이렇게 빠진 것 보면"
    },
    {
      "start": 1949.05,
      "end": 1985.22,
      "text": "대전보단 확실의 판단의 타이트 좋아졌다는 생각이 듭니다."
    },
    {
      "start": 1985.22,
      "end": 1986.42,
      "text": "그렇습니다."
    },
    {
      "start": 1986.42,
      "end": 1989.42,
      "text": "뭐 오늘 드릴 말씀을 이게 다고요."
    },
    {
      "start": 1989.42,
      "end": 1992.02,
      "text": "일단 지켜봅시다."
    },
    {
      "start": 1992.02,
      "end": 1996.82,
      "text": "저 정의 마스에 때 과연 피곤하지 영점에"
    },
    {
      "start": 1996.82,
      "end": 2001.82,
      "text": "우관정도 이 가격 정도 잘 지지를 해주고"
