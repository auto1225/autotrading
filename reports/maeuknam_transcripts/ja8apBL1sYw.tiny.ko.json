{
  "id": "ja8apBL1sYw",
  "title": "[2024.08.07] Maeoknam_Bitcoin Analysis Broadcast #Bitcoin #bitcoin #btc #chartanalysis",
  "url": "https://www.youtube.com/watch?v=ja8apBL1sYw",
  "duration": 2590.3949375,
  "language": "ko",
  "model": "tiny",
  "elapsed_seconds": 55.6,
  "segments": [
    {
      "start": 539.09,
      "end": 542.71,
      "text": "마이크를 어떻게 크게 하는지 몰라서"
    },
    {
      "start": 544.37,
      "end": 548.39,
      "text": "여러분들이 볼륨을 최대한 번 키워봐주시겠어요"
    },
    {
      "start": 548.39,
      "end": 564.15,
      "text": "노래 소리 아직도 커요"
    },
    {
      "start": 564.15,
      "end": 587.94,
      "text": "꼬만 더 주름 들을 만해요"
    },
    {
      "start": 587.94,
      "end": 589.66,
      "text": "아 오케이 알겠습니다"
    },
    {
      "start": 590.88,
      "end": 596.08,
      "text": "일단 코인"
    },
    {
      "start": 596.08,
      "end": 601.14,
      "text": "일단 오늘은 가득하게만 이야기할 생각이고요"
    },
    {
      "start": 602.14,
      "end": 611.08,
      "text": "일단 지금 비트코인 떨어진 이유가"
    },
    {
      "start": 612.08,
      "end": 614.46,
      "text": "여러가지 여윤이 있지만"
    },
    {
      "start": 615.26,
      "end": 619.52,
      "text": "한 가지로 정리하자면 경기 침체대한 우려"
    },
    {
      "start": 619.52,
      "end": 622.26,
      "text": "때문에 비트코인이 빠졌고"
    },
    {
      "start": 622.26,
      "end": 625.88,
      "text": "다들 아시겠지만 코인만 그런 게 아니라"
    },
    {
      "start": 625.88,
      "end": 627.28,
      "text": "SMP 500"
    },
    {
      "start": 627.28,
      "end": 628.56,
      "text": "나스타"
    },
    {
      "start": 628.56,
      "end": 633.76,
      "text": "미국 주가도 빠졌고 한국 코스피고 스타크도 금락이 왔었었죠"
    },
    {
      "start": 634.4,
      "end": 637.24,
      "text": "서키프레이까지 걸렸었고"
    },
    {
      "start": 637.24,
      "end": 639.96,
      "text": "그 정도로 좀 이제 단기간 최대 납고"
    },
    {
      "start": 639.96,
      "end": 642.16,
      "text": "코로나 이후 최대 납고기라고 할 정도로"
    },
    {
      "start": 642.16,
      "end": 645.04,
      "text": "그렇게 가게 좀 증시가 빠졌었습니다"
    },
    {
      "start": 645.04,
      "end": 670.52,
      "text": "누군은 잘 들린대으로 누군은 작다 그러고"
    },
    {
      "start": 670.52,
      "end": 673.08,
      "text": "오늘 구독 작다고"
    },
    {
      "start": 673.08,
      "end": 693.93,
      "text": "근데 이거 세팅일 마이크를 바꾼 거 어떻게 하는지 몰라서"
    },
    {
      "start": 693.93,
      "end": 702.04,
      "text": "미안해요 내가 기계치랑 세팅을 잘 몰라서"
    },
    {
      "start": 702.04,
      "end": 705.28,
      "text": "사오즈들 말고 일단 오늘은 조금 불편해도 들어 보고요"
    },
    {
      "start": 705.28,
      "end": 707.88,
      "text": "제가 이거 방송 끝나면"
    },
    {
      "start": 707.88,
      "end": 710.36,
      "text": "목소리가 얼마나 작아는 지 좀 모니터링 해보고"
    },
    {
      "start": 710.36,
      "end": 714.76,
      "text": "너무 작았으면 볼륨을 좀 키우는 방법을 강구해오겠습니다"
    },
    {
      "start": 714.76,
      "end": 716.6,
      "text": "오늘은 조금 양해해 주세요"
    },
    {
      "start": 717.88,
      "end": 723.32,
      "text": "일단 예전에 비트코인이라고 하면"
    },
    {
      "start": 723.32,
      "end": 729.12,
      "text": "그러니까 예전에 옛날에 비트코인이라고 하면"
    },
    {
      "start": 729.12,
      "end": 738.85,
      "text": "뭔가 얼리 얻었터들만 투자하는"
    },
    {
      "start": 738.85,
      "end": 742.45,
      "text": "관장이 매뉴았트한 투자탕품이 없다고 하면"
    },
    {
      "start": 742.45,
      "end": 746.85,
      "text": "시간이 지나냐나라서 점점 점점 대중을 투자 좀 늘어나고"
    },
    {
      "start": 746.85,
      "end": 752.45,
      "text": "이제는 기간 투자 작가지 이제 투자가 시작된 상황이죠"
    },
    {
      "start": 752.45,
      "end": 757.33,
      "text": "그래서 그런지 예전에 좀 독립적으로 움직였다고 하면"
    },
    {
      "start": 757.33,
      "end": 762.13,
      "text": "지금은 거의 완벽하게 다른 자산시장과 같이"
    },
    {
      "start": 762.13,
      "end": 769.16,
      "text": "마무리려서 가게 크림이 형성이 되는 것 같습니다"
    },
    {
      "start": 769.16,
      "end": 775.08,
      "text": "어쨌든 그래서 최근에 경기 침체된 우렛 때문에"
    },
    {
      "start": 775.08,
      "end": 776.6,
      "text": "가격이 많이 빠졌죠"
    },
    {
      "start": 776.6,
      "end": 781.0,
      "text": "아인 캐릭크레이 트레이드보다 아이쌸의 배조 없듯"
    },
    {
      "start": 781.0,
      "end": 787.08,
      "text": "뭐 기타 등등 있지만 한축적으로 이야기하면 경기 침체된 우려 라고 표현할 수 있겠습니다"
    },
    {
      "start": 787.08,
      "end": 790.12,
      "text": "그래서 지금 중요한 거는 저도 좀 생각을 해보고 있어요"
    },
    {
      "start": 790.12,
      "end": 795.0,
      "text": "가장 중요한 부분은 경기 침체나 올 것인가"
    },
    {
      "start": 795.0,
      "end": 801.56,
      "text": "온다며 어떻게 데뷔할 것인가에 대해서 좀 진지하게 고민을 하고 있고"
    },
    {
      "start": 801.56,
      "end": 804.36,
      "text": "사려 조사하들을 좀 하고 있는 상황입니다"
    },
    {
      "start": 804.36,
      "end": 812.44,
      "text": "그래서 경기 침체된 우려을 미리 생각하지 않고 있었거든요"
    },
    {
      "start": 812.44,
      "end": 816.12,
      "text": "근데 미리 했었어야죠"
    },
    {
      "start": 816.12,
      "end": 820.92,
      "text": "근데 빠지고 나니까 경기 침체된 우려가 좀 고민이 되더라고요"
    },
    {
      "start": 820.92,
      "end": 826.12,
      "text": "그래서 한 마치간은 좀 더 자려 조사를 하고 공부를 좀 더 해보고"
    },
    {
      "start": 826.12,
      "end": 831.8,
      "text": "다음에 분석을 해서 다음 방송을 치면 경기 침체에"
    },
    {
      "start": 831.8,
      "end": 836.36,
      "text": "가 주식시장과 경식시가 올지 않을지"
    },
    {
      "start": 836.36,
      "end": 841.0,
      "text": "그리고 온다면 그게 우리나라 심을검게 어떤 영향을 미칠지"
    },
    {
      "start": 841.0,
      "end": 844.76,
      "text": "주가 코스피커 스타트 시작이 나왔던 영향 미칠지"
    },
    {
      "start": 844.76,
      "end": 847.08,
      "text": "비트코인에는 어떤 영향을 미칠지"
    },
    {
      "start": 847.08,
      "end": 849.4,
      "text": "부동산시작이 나왔던 영향을 미칠지"
    },
    {
      "start": 849.4,
      "end": 854.12,
      "text": "좀 종합적으로 결론을 지은 다음에 말씀을 드리도록 하겠습니다"
    },
    {
      "start": 854.12,
      "end": 857.72,
      "text": "일단 이제 데뷔할 시간이 약간 있으니까"
    },
    {
      "start": 857.72,
      "end": 863.0,
      "text": "그건을 조금 뒤에 이야기 하는 걸로 하고"
    },
    {
      "start": 863.0,
      "end": 867.4,
      "text": "나 경기 침체가 온 거라 온다고 하더라도"
    },
    {
      "start": 867.4,
      "end": 870.6,
      "text": "뭐 경기 침체에가 좀 그래요"
    },
    {
      "start": 870.6,
      "end": 873.88,
      "text": "예전에 경기 침체가 온다고 했었을 때"
    },
    {
      "start": 873.88,
      "end": 876.04,
      "text": "실제로 왔었을 때"
    },
    {
      "start": 876.04,
      "end": 878.76,
      "text": "대표적인 가장 대표적인 것들"
    },
    {
      "start": 878.76,
      "end": 883.32,
      "text": "이 두 부관 정도를 좀 보실는데"
    },
    {
      "start": 883.32,
      "end": 885.8,
      "text": "금락이 왔다가 반등왔다 금락이 왔다 반가웠다"
    },
    {
      "start": 885.8,
      "end": 889.0,
      "text": "약간 이런 형상이 요거든요"
    },
    {
      "start": 889.0,
      "end": 891.56,
      "text": "금락했다가도 반등 오금락했다가 반등 오"
    },
    {
      "start": 891.56,
      "end": 895.96,
      "text": "이런 편상이 있어요"
    },
    {
      "start": 896.2,
      "end": 902.44,
      "text": "지금 금락이 있었다고 반등이 있었는데"
    },
    {
      "start": 902.44,
      "end": 905.16,
      "text": "제 첫 바로 큰 금락은 없을 거라 생각해요"
    },
    {
      "start": 905.16,
      "end": 908.92,
      "text": "왜냐하면 굉장히 큰 주무에 금락이 있었기 때문에"
    },
    {
      "start": 908.92,
      "end": 917.32,
      "text": "특히 코인 같은 경우는 이미 고정 대비 30% 넘게 가격이 하락했기 때문에"
    },
    {
      "start": 917.32,
      "end": 921.96,
      "text": "이 저점을 당분간을 깨지 않을 거라 생각해요"
    },
    {
      "start": 921.96,
      "end": 925.24,
      "text": "일단은 이제"
    },
    {
      "start": 925.24,
      "end": 931.49,
      "text": "그래서 경기 침체에 한 이야기는 다음에 한 걸로 하고"
    },
    {
      "start": 931.49,
      "end": 935.73,
      "text": "당기가 저점 이외신 반등에 나오고 있는 흐름인데"
    },
    {
      "start": 935.73,
      "end": 940.69,
      "text": "조정이 잊긴 했습니다만 계속 경고하게 상승을 하고 있었죠"
    },
    {
      "start": 940.69,
      "end": 945.41,
      "text": "근데 어쨌든 몰라 오는 모양이 라이징했진"
    },
    {
      "start": 945.41,
      "end": 948.45,
      "text": "라이징 외친 상반수에게 모양이고"
    },
    {
      "start": 948.45,
      "end": 953.81,
      "text": "상반수에게 이라는 건 결국에는 이렇게 상반으로 수렴하다가"
    },
    {
      "start": 953.81,
      "end": 958.93,
      "text": "하방으로 조정이 오는 패턴 이물음이 합니다"
    },
    {
      "start": 958.93,
      "end": 965.17,
      "text": "그래서 수색이를 상단을 깨지 못하는 이상한 라이정"
    },
    {
      "start": 965.17,
      "end": 969.33,
      "text": "여기를 깨지 못하는 이상 하방 돌파 를 했고"
    },
    {
      "start": 969.33,
      "end": 973.49,
      "text": "하방 돌파하면 어느 정도 조정이 있지 않을까"
    },
    {
      "start": 973.49,
      "end": 975.49,
      "text": "라고 생각을 하고"
    },
    {
      "start": 975.49,
      "end": 981.17,
      "text": "이게 더해서 지금 15분 봉을 보게 되면"
    },
    {
      "start": 981.17,
      "end": 985.17,
      "text": "그점은 계속 담기간의 긴신을 하고 있어요"
    },
    {
      "start": 985.17,
      "end": 987.73,
      "text": "여기에서부터 여기 고점 변신했고"
    },
    {
      "start": 987.73,
      "end": 990.85,
      "text": "또 고점이 한 번 더 올라고 또 올라왔고"
    },
    {
      "start": 990.85,
      "end": 994.13,
      "text": "그래서 고점이 한 번 두 번 세 번 긴신이 됐는데"
    },
    {
      "start": 994.13,
      "end": 997.33,
      "text": "아래 사이는 고점이 긴신이 되지 못했고"
    },
    {
      "start": 997.33,
      "end": 1000.21,
      "text": "당신 되지 못했고, 당신 되지 못했어요"
    },
    {
      "start": 1000.21,
      "end": 1003.65,
      "text": "그래서 주까 하는 박역은 상승하는데"
    },
    {
      "start": 1003.65,
      "end": 1012.12,
      "text": "아래스의 보조주표에 가격이 쭉 빠지면서"
    },
    {
      "start": 1012.12,
      "end": 1016.52,
      "text": "아지면서 이것 조차도 하락을 의미하고 있죠"
    },
    {
      "start": 1016.52,
      "end": 1021.4,
      "text": "그래서 일단 정석적으로 보았을 때에는"
    },
    {
      "start": 1021.4,
      "end": 1026.28,
      "text": "조정이 있을 것 같다 그 조정에 크게는"
    },
    {
      "start": 1026.28,
      "end": 1029.72,
      "text": "정말 경기충체에가 심각한 순수로 온다라고 하면"
    },
    {
      "start": 1029.72,
      "end": 1033.0,
      "text": "저 점을 한 번 더 깨끗했지만 지금"
    },
    {
      "start": 1033.0,
      "end": 1038.52,
      "text": "올지 안울지도 모르는 브락실한 상황의 브락실성이 반영되면서"
    },
    {
      "start": 1038.52,
      "end": 1041.32,
      "text": "가격이 그 빛 빠진 건데"
    },
    {
      "start": 1041.32,
      "end": 1043.72,
      "text": "한 번 더 크게 빠질 만한 이유는 없을 것 같아요"
    },
    {
      "start": 1043.72,
      "end": 1045.96,
      "text": "이미 충분히 조정이 왔다고 보여주고"
    },
    {
      "start": 1045.96,
      "end": 1049.4,
      "text": "그렇기 때문에 이번 조정이 여기서 또 조정이"
    },
    {
      "start": 1049.4,
      "end": 1052.12,
      "text": "저 점을 겟진하는 조정이는 보다는"
    },
    {
      "start": 1052.12,
      "end": 1056.12,
      "text": "이 코에 풀린의 라이징에 지구 시작점이죠"
    },
    {
      "start": 1056.12,
      "end": 1059.24,
      "text": "피곤할 수 있는 정도"
    },
    {
      "start": 1059.24,
      "end": 1061.72,
      "text": "까지의 조정이지 않을까"
    },
    {
      "start": 1061.72,
      "end": 1064.84,
      "text": "예상 구가 하는 여기까지가"
    },
    {
      "start": 1064.84,
      "end": 1068.36,
      "text": "어리시선 물하고 지난번에 풀린을 지워졌을 때"
    },
    {
      "start": 1068.36,
      "end": 1071.96,
      "text": "영점은 터치 안 하고 바로 위가격에서 올라갔거든요"
    },
    {
      "start": 1071.96,
      "end": 1073.88,
      "text": "대략, 영점 살짝 위해서"
    },
    {
      "start": 1073.88,
      "end": 1077.16,
      "text": "이번에도 영점으로 터치를 꼭 해준다리 보다는"
    },
    {
      "start": 1077.16,
      "end": 1080.36,
      "text": "어쨌든 영점 구간 지음에서"
    },
    {
      "start": 1080.36,
      "end": 1083.08,
      "text": "지지를 받을 어느정 있겠다"
    },
    {
      "start": 1083.08,
      "end": 1086.36,
      "text": "그래서 지금 쭉 포지션에 들어 간다면"
    },
    {
      "start": 1086.36,
      "end": 1092.04,
      "text": "한다면 여기서 쇼셔도 들어가 있다면"
    },
    {
      "start": 1092.04,
      "end": 1098.16,
      "text": "손절라인은 여기가 되겠죠"
    },
    {
      "start": 1098.16,
      "end": 1099.92,
      "text": "이쪽 라인을 여기가 될 것 같고"
    },
    {
      "start": 1099.92,
      "end": 1105.04,
      "text": "그래서 손이 빛 같게 괜찮은 자리인가갔다"
    },
    {
      "start": 1105.04,
      "end": 1108.18,
      "text": "라고 보여주고"
    },
    {
      "start": 1108.18,
      "end": 1111.3,
      "text": "근데 만약에 하나, 만약에 하나"
    },
    {
      "start": 1111.3,
      "end": 1113.54,
      "text": "여기를 넘긴다면"
    },
    {
      "start": 1113.54,
      "end": 1115.38,
      "text": "선발 넘긴다면"
    },
    {
      "start": 1115.38,
      "end": 1119.06,
      "text": "그러면 좀 급격한 상승이 오지 않을까 생각하시"
    },
    {
      "start": 1119.06,
      "end": 1122.1,
      "text": "위로 슈팅을 소지 않을까 싶어요"
    },
    {
      "start": 1122.1,
      "end": 1125.78,
      "text": "왜냐하면 여기가 좀 의미가 있는 자리인데"
    },
    {
      "start": 1125.78,
      "end": 1128.1,
      "text": "이전에 저 점 형성하고"
    },
    {
      "start": 1128.1,
      "end": 1131.88,
      "text": "뚜리면서 폭나게 왔거든요"
    },
    {
      "start": 1131.88,
      "end": 1134.36,
      "text": "폭나게 시작된 10월 좀 가격이란 말에"
    },
    {
      "start": 1134.36,
      "end": 1136.28,
      "text": "이 라인이"
    },
    {
      "start": 1136.28,
      "end": 1139.0,
      "text": "이 지점을 뚫고 다시 정상 가격으로"
    },
    {
      "start": 1139.0,
      "end": 1141.48,
      "text": "들어왔다는 거는"
    },
    {
      "start": 1141.48,
      "end": 1143.88,
      "text": "이제 많은 걸 의미하죠"
    },
    {
      "start": 1143.88,
      "end": 1146.84,
      "text": "이 폭나게 다 해볼 때 스물 의미하고"
    },
    {
      "start": 1146.84,
      "end": 1150.92,
      "text": "이전 가격으로 돌아왔다는 걸 의미하기 때문에"
    },
    {
      "start": 1150.92,
      "end": 1152.84,
      "text": "여기서부터가 뭔가 좀 안전구간"
    },
    {
      "start": 1152.84,
      "end": 1155.4,
      "text": "이라고 보여식 때문에 매주 세가 들어있을 수 있고"
    },
    {
      "start": 1155.4,
      "end": 1157.16,
      "text": "그렇게 보았을 때"
    },
    {
      "start": 1157.16,
      "end": 1159.24,
      "text": "좀 급격한 상승이"
    },
    {
      "start": 1159.24,
      "end": 1161.64,
      "text": "이 기울기보다 조금 더 급격한"
    },
    {
      "start": 1161.64,
      "end": 1164.6,
      "text": "기울기의 상승이 있을 수 있고"
    },
    {
      "start": 1164.6,
      "end": 1168.44,
      "text": "보통 이제 이정도에 다 입어저 수가"
    },
    {
      "start": 1168.44,
      "end": 1169.48,
      "text": "형성이 될 것 같고"
    },
    {
      "start": 1169.48,
      "end": 1172.76,
      "text": "이렇게 폴링해지지 않게 라인이 지가 나왔는데"
    },
    {
      "start": 1172.76,
      "end": 1175.24,
      "text": "이게 칼하지 않고"
    },
    {
      "start": 1175.24,
      "end": 1178.68,
      "text": "여구로 역백팅으로 역방향으로 수팅"
    },
    {
      "start": 1178.68,
      "end": 1180.12,
      "text": "상승이 나오면"
    },
    {
      "start": 1180.12,
      "end": 1183.32,
      "text": "그러면 분출하는 모양이 자주 나거든요"
    },
    {
      "start": 1183.32,
      "end": 1186.76,
      "text": "왜냐하면 보통 그리야 떨어질 자리에서"
    },
    {
      "start": 1186.76,
      "end": 1188.76,
      "text": "분명 떨어질 자리인데 떨어지지 않으면"
    },
    {
      "start": 1188.76,
      "end": 1191.56,
      "text": "반대편으로 급격한 방향"
    },
    {
      "start": 1191.56,
      "end": 1195.81,
      "text": "솔림이 나오거든요"
    },
    {
      "start": 1195.81,
      "end": 1199.97,
      "text": "그래서 만약 여기에서 하락하지 않고"
    },
    {
      "start": 1199.97,
      "end": 1201.41,
      "text": "상승한다면"
    },
    {
      "start": 1201.41,
      "end": 1202.93,
      "text": "여기"
    },
    {
      "start": 1202.93,
      "end": 1206.69,
      "text": "이를 넘는 순간 급격한 상승이 나오지 않을까"
    },
    {
      "start": 1206.69,
      "end": 1208.93,
      "text": "라고 생각을 하고 있습니다"
    },
    {
      "start": 1208.93,
      "end": 1211.81,
      "text": "그리고 지금 이 반등을"
    },
    {
      "start": 1211.81,
      "end": 1214.05,
      "text": "저점을 넘기지 않고"
    },
    {
      "start": 1214.05,
      "end": 1216.05,
      "text": "영정 우강까지 오고 저정이 왔다"
    },
    {
      "start": 1216.05,
      "end": 1219.33,
      "text": "다시 올라갈 거라고 보고 있는데"
    },
    {
      "start": 1220.21,
      "end": 1225.44,
      "text": "이전에도 비슷한 양상이 좀 있었어요"
    },
    {
      "start": 1225.44,
      "end": 1229.92,
      "text": "이제 금락이 나왔고 계단영상승이 오고 있는데"
    },
    {
      "start": 1229.92,
      "end": 1234.0,
      "text": "이 그림을 잘 보셨고"
    },
    {
      "start": 1234.0,
      "end": 1239.62,
      "text": "예전 거를 좀 볼게요"
    },
    {
      "start": 1239.62,
      "end": 1256.92,
      "text": "이렇게 여쾌하셨다가"
    },
    {
      "start": 1256.92,
      "end": 1260.52,
      "text": "이때가 2020년"
    },
    {
      "start": 1260.52,
      "end": 1263.64,
      "text": "코로나가 발가�하면서"
    },
    {
      "start": 1263.64,
      "end": 1264.92,
      "text": "금락이 한 번 왔었죠"
    },
    {
      "start": 1264.92,
      "end": 1267.56,
      "text": "이때도 죽가 빠졌고 비트코인 빠졌고"
    },
    {
      "start": 1267.56,
      "end": 1271.16,
      "text": "금방 빠졌고 거의 모든 자산이"
    },
    {
      "start": 1271.16,
      "end": 1273.16,
      "text": "다 하락했던 시기입니다"
    },
    {
      "start": 1273.16,
      "end": 1283.16,
      "text": "그때 이후에 반등오던 이 모양새"
    },
    {
      "start": 1283.16,
      "end": 1288.47,
      "text": "매치형 느낌 상단에"
    },
    {
      "start": 1288.47,
      "end": 1292.39,
      "text": "이런 모양새와 함께 닮아 있거든요"
    },
    {
      "start": 1292.39,
      "end": 1297.75,
      "text": "물론 이때는 좀 매치로 보았다면 조금"
    },
    {
      "start": 1297.75,
      "end": 1301.59,
      "text": "곤란한 게 여기까지 빠지기 예상했는데"
    },
    {
      "start": 1301.59,
      "end": 1305.43,
      "text": "안 빠지고 올라갔었죠"
    },
    {
      "start": 1305.43,
      "end": 1309.99,
      "text": "정확하다고는 할 수 없지만 닮은 새가 꽤 있어요"
    },
    {
      "start": 1309.99,
      "end": 1311.59,
      "text": "때랑"
    },
    {
      "start": 1311.59,
      "end": 1314.47,
      "text": "꽤 뭔가 반복된 느낌이고"
    },
    {
      "start": 1314.47,
      "end": 1315.91,
      "text": "상황도 비슷해요"
    },
    {
      "start": 1315.91,
      "end": 1319.91,
      "text": "그 전에 폭락이 왔다가 계단영으로 상승을 하는"
    },
    {
      "start": 1319.91,
      "end": 1322.15,
      "text": "상황이라는 정도 비슷하고"
    },
    {
      "start": 1322.15,
      "end": 1340.88,
      "text": "시간 동으로 보면 좀 더 잘 볼 것 같은데"
    },
    {
      "start": 1340.88,
      "end": 1343.44,
      "text": "아 본 게 있을때는 안 보이는구나"
    },
    {
      "start": 1345.76,
      "end": 1347.2,
      "text": "아무튼"
    },
    {
      "start": 1347.2,
      "end": 1349.76,
      "text": "이때 차트 좀 참고 해보시면 좋을 것 같아요"
    },
    {
      "start": 1349.76,
      "end": 1351.2,
      "text": "저 20일"
    },
    {
      "start": 1351.2,
      "end": 1353.6,
      "text": "코로나 3월 때"
    },
    {
      "start": 1353.6,
      "end": 1356.0,
      "text": "이 구간 차트"
    },
    {
      "start": 1356.0,
      "end": 1358.32,
      "text": "이때도 사실 좀 얘를 먹었어요"
    },
    {
      "start": 1358.32,
      "end": 1360.32,
      "text": "결국에는 여기가 인팔 수였거든요"
    },
    {
      "start": 1360.32,
      "end": 1365.56,
      "text": "또는 리딩 다이어곤을 보고싶으면 되는데"
    },
    {
      "start": 1365.56,
      "end": 1370.52,
      "text": "진 저점이었고 대세 상승장의 10화일점이었죠"
    },
    {
      "start": 1370.52,
      "end": 1371.64,
      "text": "그래서 그런지"
    },
    {
      "start": 1371.64,
      "end": 1374.2,
      "text": "이거 리딩으로 보아도 좋은데"
    },
    {
      "start": 1374.2,
      "end": 1381.27,
      "text": "어쨌든 조정부기 굉장히 야타죠"
    },
    {
      "start": 1381.27,
      "end": 1383.43,
      "text": "여기서 신틀을 얻을 수 있는 게"
    },
    {
      "start": 1383.43,
      "end": 1388.56,
      "text": "여기 아마 지금 시간 동으로 보면"
    },
    {
      "start": 1388.56,
      "end": 1391.04,
      "text": "여기 상승답을 서 있을 거거든요"
    },
    {
      "start": 1391.04,
      "end": 1392.4,
      "text": "그리고 올라갔어요"
    },
    {
      "start": 1392.4,
      "end": 1396.32,
      "text": "그래서 만약에 지금 쇼 자리도"
    },
    {
      "start": 1396.32,
      "end": 1398.88,
      "text": "이 구간을 기다리고 있는데"
    },
    {
      "start": 1398.88,
      "end": 1402.24,
      "text": "살짝 떨어지는 상황에서 상승답을 서 걸리면"
    },
    {
      "start": 1402.24,
      "end": 1405.12,
      "text": "제 차상승할 가능성을 양도해"
    },
    {
      "start": 1405.12,
      "end": 1406.48,
      "text": "두시면서"
    },
    {
      "start": 1406.48,
      "end": 1408.0,
      "text": "티퓨을 여기로"
    },
    {
      "start": 1408.0,
      "end": 1410.0,
      "text": "잡때"
    },
    {
      "start": 1410.0,
      "end": 1413.2,
      "text": "무조건 여기까지 간다게 봤더니"
    },
    {
      "start": 1413.2,
      "end": 1415.92,
      "text": "30분 동안이나 시곤 먹은 상승될 것과"
    },
    {
      "start": 1415.92,
      "end": 1420.24,
      "text": "어느 중 하나에 걸린다면 제 차트 고점을 남길 가능성"
    },
    {
      "start": 1420.24,
      "end": 1422.32,
      "text": "그리고 이렇게 다시 좀"
    },
    {
      "start": 1422.32,
      "end": 1424.88,
      "text": "잘 겸과하게 오를 반성"
    },
    {
      "start": 1424.88,
      "end": 1427.04,
      "text": "요즘 보내 좋지 않을까"
    },
    {
      "start": 1427.04,
      "end": 1431.44,
      "text": "좀 가라고 있습니다"
    },
    {
      "start": 1431.44,
      "end": 1433.92,
      "text": "그리고"
    },
    {
      "start": 1435.04,
      "end": 1436.96,
      "text": "솔직히 차트만 탁 봤을 때"
    },
    {
      "start": 1436.96,
      "end": 1439.76,
      "text": "얘는 여전히"
    },
    {
      "start": 1439.76,
      "end": 1442.32,
      "text": "4%로 본 게 맞는 것 같아요"
    },
    {
      "start": 1442.32,
      "end": 1445.94,
      "text": "그러니까 무슨 말이냐면"
    },
    {
      "start": 1445.94,
      "end": 1448.58,
      "text": "계속해서 보던 거였는데"
    },
    {
      "start": 1448.58,
      "end": 1455.3,
      "text": "1, 2, 3, 4, 9, 9, 9, 9, 9, 9, 10, 10, 10"
    },
    {
      "start": 1456.02,
      "end": 1458.5,
      "text": "0, 6, 8, 6, 8, 5, 5, 9, 6, 8, 8, 6, 5, 6, 8, 6, 8, 6, 8, 6, 8, 6, 8, 8, 6, 9, 8, 9, 8, 8, 6, 6, 8, 8, 8, 8, 8, 6, 8, 8, 6, 8, 8, 6, 8, 8, 8, 7, 8."
    },
    {
      "start": 1458.5,
      "end": 1460.5,
      "text": "그래도 이렇게 컴퓨팅 하는 게"
    },
    {
      "start": 1460.5,
      "end": 1462.1,
      "text": "좀 더"
    },
    {
      "start": 1462.1,
      "end": 1464.74,
      "text": "이거를 하뭐ком으로 보는 게"
    },
    {
      "start": 1464.74,
      "end": 1466.58,
      "text": "맞는 컴퓨팅이지 않나?"
    },
    {
      "start": 1466.58,
      "end": 1467.98,
      "text": "싶고"
    },
    {
      "start": 1467.98,
      "end": 1469.38,
      "text": "이거를"
    },
    {
      "start": 1469.38,
      "end": 1471.62,
      "text": "이렇게 안 분리하면"
    },
    {
      "start": 1471.62,
      "end": 1471.7,
      "text": "1, 2에"
    },
    {
      "start": 1471.7,
      "end": 1472.7,
      "text": "만영 플래스를"
    },
    {
      "start": 1472.7,
      "end": 1475.3,
      "text": "3, 5, 5, 5, 8, 5, 8, 5, 8, 8, 9, 8, 5, 8, 8, 8, 8, 8, 9, 3, 5, 8, 8."
    },
    {
      "start": 1475.3,
      "end": 1481.86,
      "text": "이렇게 보면"
    },
    {
      "start": 1481.86,
      "end": 1484.6,
      "text": "이렇게 보면 한파도 딱 끝난 거긴 하거든요."
    },
    {
      "start": 1485.78,
      "end": 1490.86,
      "text": "근데 뭐 그래도 나름 618까지 저점 되기 조정이 있었고"
    },
    {
      "start": 1490.86,
      "end": 1493.12,
      "text": "반등이 올라와 있기 때문에"
    },
    {
      "start": 1493.12,
      "end": 1514.64,
      "text": "뭐 그래도 나쁘지 않은 가격인 것 같고"
    },
    {
      "start": 1514.64,
      "end": 1516.06,
      "text": "1리 3사 오로봅니다."
    },
    {
      "start": 1516.06,
      "end": 1520.28,
      "text": "화면 1리 3사 여전히 오정도 하나 70% 건"
    },
    {
      "start": 1520.28,
      "end": 1523.72,
      "text": "피곤하치지가 보면 618를 넘겨딴한 점이에요."
    },
    {
      "start": 1523.72,
      "end": 1526.28,
      "text": "저는 약간 618를 항상 중요시 여긴 했는데"
    },
    {
      "start": 1526.28,
      "end": 1528.14,
      "text": "영점 5를 찍었다는 거죠."
    },
    {
      "start": 1528.14,
      "end": 1531.7,
      "text": "그래서 석 좋아하진 않는데"
    },
    {
      "start": 1531.7,
      "end": 1535.22,
      "text": "예외는 있으니까 그 예외가 직전이 있었으니까"
    },
    {
      "start": 1535.22,
      "end": 1538.02,
      "text": "여기에 상승장 이렇게 아잖아요."
    },
    {
      "start": 1538.02,
      "end": 1541.46,
      "text": "3사 오로 왔는데 그러면"
    },
    {
      "start": 1541.46,
      "end": 1545.34,
      "text": "이 3파 구간에 제도림이 얼마였느냐 라고 하면"
    },
    {
      "start": 1545.34,
      "end": 1551.2,
      "text": "이때는 영점 5도 더 내려왔거든요."
    },
    {
      "start": 1551.2,
      "end": 1553.54,
      "text": "때는 거의 3파리까지 갔어요."
    },
    {
      "start": 1553.54,
      "end": 1555.64,
      "text": "그래서 1파 고점하고"
    },
    {
      "start": 1555.64,
      "end": 1559.04,
      "text": "4파 저점 여기랑 여기랑 개비 있어서"
    },
    {
      "start": 1559.14,
      "end": 1561.92,
      "text": "모보레픈 데이지 않았기 때문에"
    },
    {
      "start": 1561.92,
      "end": 1566.98,
      "text": "피곤하치"
    },
    {
      "start": 1566.98,
      "end": 1569.28,
      "text": "그러니까 사실 중요한 법칙은 아니죠."
    },
    {
      "start": 1569.28,
      "end": 1574.28,
      "text": "대개 618를 지켜준다는 그런 관점이 있는데"
    },
    {
      "start": 1574.28,
      "end": 1576.58,
      "text": "여기씩 그래서 고민이 돼요."
    },
    {
      "start": 1576.58,
      "end": 1579.28,
      "text": "618를 넘어져 엄청 5관까지 왔는데"
    },
    {
      "start": 1579.28,
      "end": 1583.38,
      "text": "그럼 이거를 4파 구간으로 보지 않을 것이냐."
    },
    {
      "start": 1583.38,
      "end": 1587.58,
      "text": "아니면 여전히 고점과 여기까지 개비 많이 남아 있고"
    },
    {
      "start": 1587.58,
      "end": 1589.18,
      "text": "여기까지는"
    },
    {
      "start": 1589.58,
      "end": 1592.28,
      "text": "LED 파 등 규칙을 준수하고 있기 때문에"
    },
    {
      "start": 1592.28,
      "end": 1593.88,
      "text": "4파리 볼 것이냐."
    },
    {
      "start": 1593.88,
      "end": 1596.58,
      "text": "이 2가지 차인데"
    },
    {
      "start": 1596.58,
      "end": 1599.18,
      "text": "사실 우선 순위는 컨트뉴이거든요."
    },
    {
      "start": 1599.18,
      "end": 1600.38,
      "text": "피곤하치 보다."
    },
    {
      "start": 1600.38,
      "end": 1604.38,
      "text": "컨트뉴의 적합성으로 보았을 때"
    },
    {
      "start": 1604.38,
      "end": 1607.58,
      "text": "이렇게 3파리가로 연장으로"
    },
    {
      "start": 1607.58,
      "end": 1609.58,
      "text": "3파 구간에 연장으로 보고"
    },
    {
      "start": 1609.58,
      "end": 1613.98,
      "text": "이게 1일 파였고 4파 저점이 다소 크게 나왔다."
    },
    {
      "start": 1613.98,
      "end": 1618.68,
      "text": "정도로 보는 게 조금 더 맞는해서 이제 안 했가."
    },
    {
      "start": 1618.68,
      "end": 1619.68,
      "text": "10파요."
    },
    {
      "start": 1619.68,
      "end": 1625.08,
      "text": "그래서 저점이 한 번 더 경신이 안 될 거라고 조금 더 무게를 두고 있어요."
    },
    {
      "start": 1625.08,
      "end": 1631.76,
      "text": "왜냐하면 지금 5파 상승 구간으로 여전히 보고 있고"
    },
    {
      "start": 1631.76,
      "end": 1636.76,
      "text": "그리고 20년 3월 코어 나 폭나트"
    },
    {
      "start": 1636.76,
      "end": 1640.46,
      "text": "폭나갔다가 반대 온 계단 식상승 모습도 그때와 비슷하고"
    },
    {
      "start": 1640.46,
      "end": 1644.76,
      "text": "그때 또 저점이 왜 다시 한 번 곧 점이 굉장히 신대는 상황이었잖아요."
    },
    {
      "start": 1644.76,
      "end": 1648.36,
      "text": "조금 더 무게를 두고 있습니다."
    },
    {
      "start": 1648.36,
      "end": 1649.76,
      "text": "상승적으로."
    },
    {
      "start": 1649.76,
      "end": 1653.56,
      "text": "그래서 내가 현물를 하는 사람이다 라고 하면"
    },
    {
      "start": 1653.56,
      "end": 1658.16,
      "text": "이번 폭력 때 여기에서 매수하셨으면 잘한 거고"
    },
    {
      "start": 1658.16,
      "end": 1668.28,
      "text": "저는 안 해게 이때 조금 너무 급작스러운 상황이라"
    },
    {
      "start": 1668.28,
      "end": 1671.08,
      "text": "상한 판단을 하지 못해서 매수를 못했다고 하면"
    },
    {
      "start": 1671.08,
      "end": 1674.68,
      "text": "현물나 같은 경우는 이번 좀 떨어지면"
    },
    {
      "start": 1674.68,
      "end": 1678.28,
      "text": "이런 구간들에서 매수하면 좋지 않을까"
    },
    {
      "start": 1678.28,
      "end": 1682.0,
      "text": "현물나 싶은 분들은 잘 안 해."
    },
    {
      "start": 1682.0,
      "end": 1685.56,
      "text": "생각을 하고 있습니다."
    },
    {
      "start": 1685.56,
      "end": 1689.76,
      "text": "그리고 지금의 오린할 수 있는 좋은 가격대는 아닌 것 같아요."
    },
    {
      "start": 1689.76,
      "end": 1691.36,
      "text": "인생을 매트인한다."
    },
    {
      "start": 1691.36,
      "end": 1694.63,
      "text": "그럼 가격대는 아닌 것 같고"
    },
    {
      "start": 1694.63,
      "end": 1700.89,
      "text": "하지만 이 구간에서 물린다 현물를 매수했다가"
    },
    {
      "start": 1700.89,
      "end": 1705.09,
      "text": "여기에서 물렸다라고 하면은"
    },
    {
      "start": 1705.09,
      "end": 1708.29,
      "text": "좋지 않긴 하겠다."
    },
    {
      "start": 1708.29,
      "end": 1711.86,
      "text": "저점에 많이 올라와서"
    },
    {
      "start": 1711.86,
      "end": 1717.06,
      "text": "그래도 버티에 버티라마를 못하겠다 너무 높다 가요."
    },
    {
      "start": 1717.06,
      "end": 1755.22,
      "text": "제긴대 좋은 것도 아닌데"
    },
    {
      "start": 1755.22,
      "end": 1758.82,
      "text": "피부나지 이렇게 찍던"
    },
    {
      "start": 1758.82,
      "end": 1760.62,
      "text": "이것도 100번 말은 것 같아요."
    },
    {
      "start": 1760.62,
      "end": 1762.62,
      "text": "이렇게 찍건."
    },
    {
      "start": 1762.62,
      "end": 1764.82,
      "text": "0.38이 6일 바른 똑같아요."
    },
    {
      "start": 1764.82,
      "end": 1768.42,
      "text": "780가 2.38이 다른 거 780가 2.38이 잘 안 봐요."
    },
    {
      "start": 1768.42,
      "end": 1775.43,
      "text": "그래서 그냥 항상 스간대로 위해서 아래로 찍는 거예요."
    },
    {
      "start": 1775.43,
      "end": 1781.49,
      "text": "뭐가 중요하니까."
    },
    {
      "start": 1781.49,
      "end": 1809.71,
      "text": "맵에 하는데 안 중요해요."
    },
    {
      "start": 1809.71,
      "end": 1814.11,
      "text": "지금 뭐 4.38 말고 2.8을 보는 것 같더라고요."
    },
    {
      "start": 1814.11,
      "end": 1816.11,
      "text": "하시는데 그럴 수도 있죠."
    },
    {
      "start": 1816.11,
      "end": 1818.71,
      "text": "1.234.5였고 1."
    },
    {
      "start": 1818.71,
      "end": 1820.71,
      "text": "이렇게 해보도록 하죠."
    },
    {
      "start": 1820.71,
      "end": 1821.71,
      "text": "비상승이에요."
    },
    {
      "start": 1821.71,
      "end": 1834.56,
      "text": "오빠가 남았다고 보관 1.5가 고쯤 찍고 2.8 나왔다고 보관."
    },
    {
      "start": 1834.56,
      "end": 1841.45,
      "text": "아 근데 모르겠어요."
    },
    {
      "start": 1841.45,
      "end": 1843.85,
      "text": "지금 경기 침착해서 찰취해서"
    },
    {
      "start": 1843.85,
      "end": 1849.16,
      "text": "경기 침착이 온다고 하면은 여기 1.1인 것만 아래 안 되고"
    },
    {
      "start": 1849.16,
      "end": 1851.96,
      "text": "심지어 온다고 하면 고쯤 찍고 경기 침착이 영향으로 계속"
    },
    {
      "start": 1851.96,
      "end": 1852.96,
      "text": "이렇게 좀 하러 가더라고요."
    },
    {
      "start": 1852.96,
      "end": 1855.76,
      "text": "이렇게 올라간 게 말을 되거든요."
    },
    {
      "start": 1855.76,
      "end": 1862.91,
      "text": "이게 말이 되는 상황인 거라."
    },
    {
      "start": 1862.91,
      "end": 1864.11,
      "text": "어쨌든 경기 침착이 한 거죠."
    },
    {
      "start": 1864.11,
      "end": 1867.31,
      "text": "그다음에 힘들 때 달아 볼게요."
    },
    {
      "start": 1867.31,
      "end": 1872.71,
      "text": "지금은 이제 결론적으로 이야기하면은"
    },
    {
      "start": 1872.71,
      "end": 1878.85,
      "text": "경기 침착이 한 우렛 때문에 금약이 나왔는데"
    },
    {
      "start": 1878.85,
      "end": 1882.05,
      "text": "우려 대한 가격적 반영이 이미 됐다고 보고"
    },
    {
      "start": 1882.05,
      "end": 1885.55,
      "text": "여기서 또 다른 뭔가 대단한 이유가"
    },
    {
      "start": 1885.55,
      "end": 1890.15,
      "text": "나오지 않는 이상 제 차 연속적인 하락"
    },
    {
      "start": 1890.15,
      "end": 1891.95,
      "text": "그는 없을 것 같아요."
    },
    {
      "start": 1891.95,
      "end": 1897.55,
      "text": "전보다 비트코인에 대한 시장 믿음이 좀 더 강해졌고요."
    },
    {
      "start": 1897.55,
      "end": 1900.55,
      "text": "기관의 메수세가 있기 때문에 물론 기관들도"
    },
    {
      "start": 1900.55,
      "end": 1902.35,
      "text": "무조건 상기만 하는 건 아니에요."
    },
    {
      "start": 1902.35,
      "end": 1905.35,
      "text": "최근에 보니까 7월달에 보니까 이테부"
    },
    {
      "start": 1905.35,
      "end": 1910.15,
      "text": "순 6 7위 또 라고 보니까 메수 보다 말도가 많았다 이테부"
    },
    {
      "start": 1910.15,
      "end": 1912.55,
      "text": "그의 무관에서 판거죠."
    },
    {
      "start": 1924.43,
      "end": 1933.05,
      "text": "최근에 마음땐 곡실 물량들 많이 나오기도 했고"
