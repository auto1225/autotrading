    {
      "start": 2001.82,
      "end": 2010.6,
      "text": "모르는지 그러면 조금 더 더 빌리시하게 보실겠죠."
    },
    {
      "start": 2010.6,
      "end": 2015.6,
      "text": "그리고 곧점으로 갈 거라면 계속해서"
    },
    {
      "start": 2015.6,
      "end": 2020.67,
      "text": "이런 이유에 잔팔서 계속해서 나와줄 거에요."
    },
    {
      "start": 2020.67,
      "end": 2022.67,
      "text": "여기 지켜보면서"
    },
    {
      "start": 2023.67,
      "end": 2026.67,
      "text": "컨딸가 이 중에서 한 달 같이 보면서"
    },
    {
      "start": 2026.67,
      "end": 2029.67,
      "text": "저작하락할지 아니면 신고점을 넘길지"
    },
    {
      "start": 2029.67,
      "end": 2032.27,
      "text": "한 달 하는 것도 괜찮습니다."
    },
    {
      "start": 2032.27,
      "end": 2053.05,
      "text": "지금 이것만 보고는 모든 걸 다 할 수 없으니까"
    },
    {
      "start": 2053.05,
      "end": 2059.05,
      "text": "그리고 대회 멤버들 상태로 비벅게 방송 한 번 했고"
    },
    {
      "start": 2059.05,
      "end": 2065.35,
      "text": "이 때의 대회그램으로 계속 외치 보면서"
    },
    {
      "start": 2065.35,
      "end": 2070.98,
      "text": "여기에서 쇼짜리 한 번"
    },
    {
      "start": 2070.98,
      "end": 2072.98,
      "text": "그때는 이렇게 왔어요."
    },
    {
      "start": 2072.98,
      "end": 2073.98,
      "text": "비용투스 리포트."
    },
    {
      "start": 2073.98,
      "end": 2079.28,
      "text": "이렇게 기억이 안 나는데?"
    },
    {
      "start": 2079.28,
      "end": 2092.67,
      "text": "이렇게 맞구나."
    },
    {
      "start": 2092.67,
      "end": 2094.67,
      "text": "봤는데 구점 넘긴 상황이라"
    },
    {
      "start": 2094.67,
      "end": 2099.67,
      "text": "아무튼 멤버들은 손절에 나갔을 수도 있습니다."
    },
    {
      "start": 2099.67,
      "end": 2101.67,
      "text": "어떻게 대응하지?"
    },
    {
      "start": 2101.67,
      "end": 2103.67,
      "text": "반입절 했지?"
    },
    {
      "start": 2103.67,
      "end": 2105.67,
      "text": "반입절 했다."
    },
    {
      "start": 2105.67,
      "end": 2106.67,
      "text": "상관없네?"
    },
    {
      "start": 2106.67,
      "end": 2107.67,
      "text": "진짜 안 나갔다."
    },
    {
      "start": 2107.67,
      "end": 2111.95,
      "text": "감오, 기억이 감옥감옥해서"
    },
    {
      "start": 2111.95,
      "end": 2115.2,
      "text": "탭댄 그러고 있는데"
    },
    {
      "start": 2115.2,
      "end": 2119.2,
      "text": "대회 멤버들한테는 조금 더 자주"
    },
    {
      "start": 2119.2,
      "end": 2121.2,
      "text": "그 탈레�그램으로"
    },
    {
      "start": 2121.2,
      "end": 2124.2,
      "text": "그때 그때 분석한 내용들"
    },
    {
      "start": 2124.2,
      "end": 2126.2,
      "text": "사정들 보면 해드리도록 하겠습니다."
    },
    {
      "start": 2126.2,
      "end": 2128.2,
      "text": "비공개 방송을 좀 더 자주 할게요."
    },
    {
      "start": 2128.2,
      "end": 2135.62,
      "text": "근데 그만큼 유튜브는 조금 빈도가 적을 수 있습니다."
    },
    {
      "start": 2135.62,
      "end": 2138.62,
      "text": "궁금한 거 간단하게 한 50분 만에 씹는답니다."
    },
    {
      "start": 2138.62,
      "end": 2141.62,
      "text": "지금 바꾸는 일찍 마치이도록 하겠습니다."
    },
    {
      "start": 2141.62,
      "end": 2172.0,
      "text": "카카오는 사실 좀 더 지켜봐야 되는데"
    },
    {
      "start": 2172.0,
      "end": 2174.0,
      "text": "손절 안 하고 다고 있습니다."
    },
    {
      "start": 2174.0,
      "end": 2180.88,
      "text": "왜냐하면 주봉상보다 더불이거든요."
    },
    {
      "start": 2180.88,
      "end": 2183.88,
      "text": "물론 이가 상당히 큰 폼 안 됐어요."
    },
    {
      "start": 2183.88,
      "end": 2186.88,
      "text": "앞으로 계속 겸 기침 최대한 우려가 있어서"
    },
    {
      "start": 2186.88,
      "end": 2188.88,
      "text": "코스틱 코스킹작살라면서 계속 부르식"
    },
    {
      "start": 2188.88,
      "end": 2191.88,
      "text": "부르식도 하느라 카카오도 계속 빠질 거예요."
    },
    {
      "start": 2191.88,
      "end": 2198.9,
      "text": "근데 어찌 됩든 좀 안정세로 돌아간다."
    },
    {
      "start": 2198.9,
      "end": 2201.9,
      "text": "그래서 주가가 다음 주 용도까지 또는"
    },
    {
      "start": 2201.9,
      "end": 2203.9,
      "text": "다음 주 정도까지 한 1리 중간"
    },
    {
      "start": 2203.9,
      "end": 2205.9,
      "text": "반등 연다시프면 더불다이번에 이렇게"
    },
    {
      "start": 2205.9,
      "end": 2207.9,
      "text": "먹을 거기 때문에 그러면"
    },
    {
      "start": 2207.9,
      "end": 2210.9,
      "text": "적어도 적어도 여기까지는 가거든요."
    },
    {
      "start": 2210.9,
      "end": 2214.9,
      "text": "그러면 여기에서 입절했으니까"
    },
    {
      "start": 2214.9,
      "end": 2216.9,
      "text": "여기서 진입했었으니까"
    },
    {
      "start": 2216.9,
      "end": 2224.83,
      "text": "입절로 충분히 한 50% 이상 수용이로 끝낼 수 있습니다."
    },
    {
      "start": 2224.83,
      "end": 2228.83,
      "text": "그래서 시간은 한 1년에 걸리겠죠."
    },
    {
      "start": 2228.83,
      "end": 2233.83,
      "text": "그래서 내속 가격이 여기니까"
    },
    {
      "start": 2233.83,
      "end": 2241.86,
      "text": "그렇게 나쁜 가격은 아니라고 보여줍니다."
    },
    {
      "start": 2241.86,
      "end": 2244.86,
      "text": "근데 만약에 주봉상다가"
    },
    {
      "start": 2244.86,
      "end": 2247.86,
      "text": "없다는 수가 코스틱 앞으로 계속"
    },
    {
      "start": 2247.86,
      "end": 2249.86,
      "text": "10%씩 빠진다."
    },
    {
      "start": 2249.86,
      "end": 2251.86,
      "text": "그런데 이래도 여기 선젤크리가 낼 텐데"
    },
    {
      "start": 2251.86,
      "end": 2253.86,
      "text": "이래도 좀 그렇다."
    },
    {
      "start": 2253.86,
      "end": 2255.86,
      "text": "그것은 안실 것 같은데 그런 적도."
    },
    {
      "start": 2255.86,
      "end": 2258.86,
      "text": "왜냐하면 주봉이 계속 빠지는 걸 보고 나서"
    },
    {
      "start": 2258.86,
      "end": 2260.86,
      "text": "생각해야 될 텐데"
    },
    {
      "start": 2260.86,
      "end": 2262.86,
      "text": "그래도 그런 어차피 맥을 때랑"
    },
    {
      "start": 2262.86,
      "end": 2266.86,
      "text": "이만으로 돼서 선젤크리는 데 의미가 있는 거 파카오래."
    },
    {
      "start": 2266.86,
      "end": 2268.86,
      "text": "경기에 복하고"
    },
    {
      "start": 2268.86,
      "end": 2271.86,
      "text": "파카옷 혼자 멘다 좋아지도까지 기다렸다가"
    },
    {
      "start": 2271.86,
      "end": 2332.04,
      "text": "판결하지 않을까."
    },
    {
      "start": 2332.04,
      "end": 2334.04,
      "text": "그리고 이도 같은 경우는"
    },
    {
      "start": 2334.04,
      "end": 2338.04,
      "text": "인파스에 확실히 실패한 모양이죠."
    },
    {
      "start": 2338.04,
      "end": 2340.04,
      "text": "비트랑 달라요."
    },
    {
      "start": 2340.04,
      "end": 2342.04,
      "text": "여기 저쯤"
    },
    {
      "start": 2342.04,
      "end": 2346.77,
      "text": "예전부터 이건 계속 이상하다 왔는데"
    },
    {
      "start": 2346.77,
      "end": 2350.77,
      "text": "또 원투, 원투 이렇게 보기에"
    },
    {
      "start": 2350.77,
      "end": 2353.77,
      "text": "방법이 없어 언제까지 원투 원투 할 수 없으니까."
    },
    {
      "start": 2353.77,
      "end": 2355.77,
      "text": "그래서 결국은 끝났죠 여기에서"
    },
    {
      "start": 2355.77,
      "end": 2357.77,
      "text": "그쪽은 못 놈기면서."
    },
    {
      "start": 2357.77,
      "end": 2361.77,
      "text": "그래서 만약에 간다고 하면"
    },
    {
      "start": 2361.77,
      "end": 2364.77,
      "text": "그쪽이 여기 없고"
    },
    {
      "start": 2364.77,
      "end": 2367.77,
      "text": "다음은 수럼형으로 조정이"
    },
    {
      "start": 2367.77,
      "end": 2375.85,
      "text": "계속해서 나오지 않을까."
    },
    {
      "start": 2375.85,
      "end": 2378.85,
      "text": "떨어지더라도 담기 반드 지지라인이 여기"
    },
    {
      "start": 2378.85,
      "end": 2380.85,
      "text": "영상 될 것 같고"
    },
    {
      "start": 2380.85,
      "end": 2383.85,
      "text": "수럼이 끝나고 나서"
    },
    {
      "start": 2383.85,
      "end": 2384.85,
      "text": "그리고 나서"
    },
    {
      "start": 2384.85,
      "end": 2387.85,
      "text": "올라가도 그때 올라가지 않을까."
    },
    {
      "start": 2387.85,
      "end": 2390.85,
      "text": "그리고 이러면 비트랑 간장을 마춘다면"
    },
    {
      "start": 2390.85,
      "end": 2401.08,
      "text": "이제 비트가 올라갈 때"
    },
    {
      "start": 2401.08,
      "end": 2403.08,
      "text": "오프가 남았죠."
    },
    {
      "start": 2403.08,
      "end": 2405.08,
      "text": "이더도 여기서 올라가는 거죠."
    },
    {
      "start": 2405.08,
      "end": 2407.08,
      "text": "하지만 많이 못 올라가는 거죠."
    },
    {
      "start": 2407.08,
      "end": 2413.51,
      "text": "그리고 비트가 다시 제찹 빠졌을 때"
    },
    {
      "start": 2413.51,
      "end": 2416.51,
      "text": "이더는 많이 빠지지 않고"
    },
    {
      "start": 2416.51,
      "end": 2417.51,
      "text": "이만큼만 빠지고."
    },
    {
      "start": 2417.51,
      "end": 2421.98,
      "text": "비트가 다시"
    },
    {
      "start": 2421.98,
      "end": 2423.98,
      "text": "올라갈 때"
    },
    {
      "start": 2423.98,
      "end": 2425.98,
      "text": "이때도 또한 크게 올라와서"
    },
    {
      "start": 2425.98,
      "end": 2427.98,
      "text": "전거청을 남기는."
    },
    {
      "start": 2427.98,
      "end": 2430.98,
      "text": "이더랑 비트랑 대량 맞거든요."
    },
    {
      "start": 2430.98,
      "end": 2437.52,
      "text": "그런데 물론 비트가"
    },
    {
      "start": 2437.52,
      "end": 2439.52,
      "text": "겠 빠진다 그냥."
    },
    {
      "start": 2439.52,
      "end": 2440.52,
      "text": "뭐."
    },
    {
      "start": 2440.52,
      "end": 2443.52,
      "text": "이더도 이 비트에 저항선 때"
    },
    {
      "start": 2443.52,
      "end": 2445.52,
      "text": "꼭 계속 빠지겠죠."
    },
    {
      "start": 2445.52,
      "end": 2447.52,
      "text": "이렇게 꼭 계속 빠지겠죠."
    },
    {
      "start": 2447.52,
      "end": 2449.52,
      "text": "이거 뭐 볼 것도 없는 든서는 거고"
    },
    {
      "start": 2449.52,
      "end": 2470.14,
      "text": "오늘 변석은 여기까지 하기로 하고"
    },
    {
      "start": 2470.14,
      "end": 2473.14,
      "text": "다음 방송 좀 기대해 주세요."
    },
    {
      "start": 2473.14,
      "end": 2476.14,
      "text": "다음 방송까지는 제가 준비를 많이 할게요."
    },
    {
      "start": 2476.14,
      "end": 2478.14,
      "text": "일단 비트코인 보다도"
    },
    {
      "start": 2478.14,
      "end": 2480.14,
      "text": "저는 지금."
    },
    {
      "start": 2480.14,
      "end": 2482.14,
      "text": "되게 초미일 관심사는"
    },
    {
      "start": 2482.14,
      "end": 2484.14,
      "text": "경기 침착가 올 것인가?"
    },
    {
      "start": 2484.14,
      "end": 2486.14,
      "text": "안 올 것인가."
    },
    {
      "start": 2486.14,
      "end": 2489.14,
      "text": "경기 침착가 많이 하고 온다면"
    },
    {
      "start": 2489.14,
      "end": 2491.14,
      "text": "그 동안 들고 있는 주식"
    },
    {
      "start": 2491.14,
      "end": 2494.14,
      "text": "그는 원자제, 딜라,"
    },
    {
      "start": 2494.14,
      "end": 2497.68,
      "text": "해외 주식,"
    },
    {
      "start": 2497.68,
      "end": 2498.68,
      "text": "국내 주식,"
    },
    {
      "start": 2498.68,
      "end": 2500.68,
      "text": "부동산,"
    },
    {
      "start": 2500.68,
      "end": 2502.68,
      "text": "비트코인."
    },
    {
      "start": 2502.68,
      "end": 2503.68,
      "text": "어떻게 할 것인가?"
    },
    {
      "start": 2504.68,
      "end": 2507.96,
      "text": "어떤 타이밍에 어떤 자세히 들어가서"
    },
    {
      "start": 2507.96,
      "end": 2509.96,
      "text": "자세한 건 어떻게 지키고"
    },
    {
      "start": 2509.96,
      "end": 2511.96,
      "text": "어떻게 늘릴 것인가?"
    },
    {
      "start": 2511.96,
      "end": 2513.96,
      "text": "침착가 온다면 그거가"
    },
    {
      "start": 2513.96,
      "end": 2515.96,
      "text": "되게 중요한 사인 것 같아요."
    },
    {
      "start": 2515.96,
      "end": 2517.96,
      "text": "살짝 늙진 가문이 있긴 한데"
    },
    {
      "start": 2517.96,
      "end": 2519.96,
      "text": "전문가 중에서도"
    },
    {
      "start": 2519.96,
      "end": 2522.96,
      "text": "이렇게 섞이 프레크 걸릴 수가처럼"
    },
    {
      "start": 2522.96,
      "end": 2525.96,
      "text": "10% 폭나 5년서"
    },
    {
      "start": 2525.96,
      "end": 2528.96,
      "text": "이런 상황이 벌어질 거라고"
    },
    {
      "start": 2528.96,
      "end": 2529.96,
      "text": "아무도 생각 못 했으니까"
    },
    {
      "start": 2529.96,
      "end": 2530.96,
      "text": "좀 늦은감이 있지만"
    },
    {
      "start": 2530.96,
      "end": 2532.96,
      "text": "지금 이럴 수 좀 준비를 철저히"
    },
    {
      "start": 2533.96,
      "end": 2537.96,
      "text": "침착 온다면 어떻게 대응하는 것이 좋을지"
    },
    {
      "start": 2537.96,
      "end": 2540.96,
      "text": "에 대해서 고민을 좀 해보고"
    },
    {
      "start": 2540.96,
      "end": 2542.96,
      "text": "그리고 다음 방송 때"
    },
    {
      "start": 2542.96,
      "end": 2544.96,
      "text": "말씀드리도록 하겠습니다."
    },
    {
      "start": 2545.96,
      "end": 2548.96,
      "text": "오늘 방송을 이만 짱 이렇게"
    },
    {
      "start": 2548.96,
      "end": 2549.96,
      "text": "마치했습니다."
    }
  ]
}