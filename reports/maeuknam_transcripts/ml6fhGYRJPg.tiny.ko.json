      "start": 923.82,
      "end": 926.06,
      "text": "그러면 여기서부터 인퍼를 수 나와야 되는데"
    },
    {
      "start": 926.06,
      "end": 928.94,
      "text": "처음에 여기만 봤었을 때는 인퍼를 갔다."
    },
    {
      "start": 928.94,
      "end": 932.62,
      "text": "그래서 진한 범성대가 아마 이월 말쯤인데"
    },
    {
      "start": 932.62,
      "end": 935.58,
      "text": "올라가는 조금 방향을 봤었죠."
    },
    {
      "start": 935.58,
      "end": 937.5,
      "text": "상승이 나오긴 했는데"
    },
    {
      "start": 937.5,
      "end": 938.7,
      "text": "아무런 의미가 없어요."
    },
    {
      "start": 938.7,
      "end": 940.22,
      "text": "인퍼를 안 나왔잖아요."
    },
    {
      "start": 940.22,
      "end": 942.14,
      "text": "결국 애기시로 올라갔고"
    },
    {
      "start": 942.14,
      "end": 944.78,
      "text": "애기시로 올라갔기 때문에"
    },
    {
      "start": 945.1,
      "end": 949.02,
      "text": "진짜 저점이라고 확신하긴 좀 어렵다."
    },
    {
      "start": 949.02,
      "end": 952.43,
      "text": "라는 거고"
    },
    {
      "start": 952.43,
      "end": 953.79,
      "text": "그리고 나서 애기시나고"
    },
    {
      "start": 953.79,
      "end": 955.95,
      "text": "또 애기시로 떨어졌어요."
    },
    {
      "start": 955.95,
      "end": 958.59,
      "text": "여기 가 애기시로 떨어졌죠."
    },
    {
      "start": 958.59,
      "end": 965.23,
      "text": "그래서 지금 어떻게 보겠느냐 하면"
    },
    {
      "start": 965.23,
      "end": 966.83,
      "text": "여기까지 추세에 가 좀 보여요."
    },
    {
      "start": 966.83,
      "end": 976.78,
      "text": "애기시도 ist요."
    },
    {
      "start": 977.02,
      "end": 979.74,
      "text": "이렇게 애기시로 추세 보여이죠."
    },
    {
      "start": 979.74,
      "end": 985.42,
      "text": "저 전 바다 채널 근처에서"
    },
    {
      "start": 985.42,
      "end": 989.42,
      "text": "그리고 알았어요, 오르고"
    },
    {
      "start": 989.42,
      "end": 991.58,
      "text": "바닥에서 금방 등 왔다가"
    },
    {
      "start": 991.58,
      "end": 997.77,
      "text": "뚫른 척 회의크에 따라졌다가 지금 다시 비리고 있는데"
    },
    {
      "start": 997.77,
      "end": 1001.41,
      "text": "그래서 뭐"
    },
    {
      "start": 1001.41,
      "end": 1003.41,
      "text": "이렇게 나올 것 같아요."
    },
    {
      "start": 1004.37,
      "end": 1007.41,
      "text": "지금 단기 상반을 보고 있거든요."
    },
    {
      "start": 1007.41,
      "end": 1011.15,
      "text": "왜냐면 장기적으로 봤을 때 여기가 적점인지 아니면"
    },
    {
      "start": 1011.15,
      "end": 1013.65,
      "text": "한 번 더 떨어진지 모른다고 했잖아요."
    },
    {
      "start": 1013.65,
      "end": 1016.61,
      "text": "그러면 이제 중기를 볼 수밖에 없어요."
    },
    {
      "start": 1016.61,
      "end": 1019.01,
      "text": "앱이 시작해놨었고"
    },
    {
      "start": 1019.01,
      "end": 1021.21,
      "text": "그리고 올라가는 신화를 가 있겠죠."
    },
    {
      "start": 1021.21,
      "end": 1025.37,
      "text": "이렇게 채널을 상당할 뚫른 그렇게 봤었을 때"
    },
    {
      "start": 1025.37,
      "end": 1027.49,
      "text": "조정이 이미 나왔다."
    },
    {
      "start": 1027.49,
      "end": 1030.9,
      "text": "얼마큼"
    },
    {
      "start": 1030.9,
      "end": 1032.9,
      "text": "3-3-3 밑으로 내려왔어요."
    },
    {
      "start": 1032.9,
      "end": 1035.42,
      "text": "거기 조정은 충분했다고 봐요."
    },
    {
      "start": 1035.42,
      "end": 1038.18,
      "text": "그리고 채널을 하던까지 받고 나이셔야 뭔가 상가 나왔죠."
    },
    {
      "start": 1038.18,
      "end": 1040.5,
      "text": "그러면 여기 앱이 시작하시니까"
    },
    {
      "start": 1040.5,
      "end": 1042.74,
      "text": "반드응이 있을 거예요."
    },
    {
      "start": 1042.74,
      "end": 1052.68,
      "text": "까떡어지더라도 떨어지더라도 여기까지 올라갈 거고"
    },
    {
      "start": 1052.68,
      "end": 1056.52,
      "text": "올라갈 거면 이대로 깨부 여기로 올라와서"
    },
    {
      "start": 1056.52,
      "end": 1059.0,
      "text": "채널 상당으로 올라갈 거고"
    },
    {
      "start": 1059.0,
      "end": 1062.04,
      "text": "그래서 지금 이 자리만 봤을 때"
    },
    {
      "start": 1062.04,
      "end": 1069.0,
      "text": "얘는 상반을 보는 게 맞는 것 같아요."
    },
    {
      "start": 1069.0,
      "end": 1076.76,
      "text": "저도 지금 롱 들어가 있고"
    },
    {
      "start": 1076.76,
      "end": 1081.61,
      "text": "이게 했나요?"
    },
    {
      "start": 1081.61,
      "end": 1082.85,
      "text": "이게 다시 정리하면"
    },
    {
      "start": 1082.85,
      "end": 1086.61,
      "text": "저점부터 상승인 벌스가 안 나와서"
    },
    {
      "start": 1086.61,
      "end": 1088.45,
      "text": "여기에 진 저점인지 모르겠다."
    },
    {
      "start": 1088.45,
      "end": 1089.51,
      "text": "물론"
    },
    {
      "start": 1089.51,
      "end": 1090.37,
      "text": "벌스가 안 나오다."
    },
    {
      "start": 1090.37,
      "end": 1091.93,
      "text": "네, 비시러 상승할 수 있죠?"
    },
    {
      "start": 1091.93,
      "end": 1092.93,
      "text": "어쨌든"
    },
    {
      "start": 1092.93,
      "end": 1096.65,
      "text": "그런가 그렇게 때문에 하방도 여러 두기는 했는데"
    },
    {
      "start": 1096.65,
      "end": 1098.81,
      "text": "하방으로 가더라도"
    },
    {
      "start": 1098.81,
      "end": 1101.89,
      "text": "이제 앱이 집한등이 요의 하방을 가더라도"
    },
    {
      "start": 1101.89,
      "end": 1104.57,
      "text": "여기에 앱이 집하, 하랑 나오고"
    },
    {
      "start": 1104.57,
      "end": 1105.69,
      "text": "상단 나왔고"
    },
    {
      "start": 1105.69,
      "end": 1107.89,
      "text": "그러면 반등 왔다 떨어질 거 아니야?"
    },
    {
      "start": 1107.89,
      "end": 1110.41,
      "text": "그렇죠, 여기까지는 상방을 보면 되겠다."
    },
    {
      "start": 1110.41,
      "end": 1111.85,
      "text": "하방을 보더라도"
    },
    {
      "start": 1111.85,
      "end": 1113.37,
      "text": "그쵸?"
    },
    {
      "start": 1113.37,
      "end": 1116.69,
      "text": "그리고 그냥 상방이 나오면 어차피 상방이니까"
    },
    {
      "start": 1116.69,
      "end": 1119.37,
      "text": "그러면 여기에서 여기까지는 공통구관이잖아?"
    },
    {
      "start": 1119.37,
      "end": 1121.81,
      "text": "여기서 여기까지는 공통구관이라고."
    },
    {
      "start": 1121.81,
      "end": 1124.81,
      "text": "하락을 하더라도 반등 같다 떨어지고"
    },
    {
      "start": 1124.81,
      "end": 1127.01,
      "text": "올라가면 그냥 올라가고"
    },
    {
      "start": 1127.01,
      "end": 1129.13,
      "text": "그러니까 롱 보는 게"
    },
    {
      "start": 1129.13,
      "end": 1132.13,
      "text": "공통구관이라 맞겠다 라는 생각이 들고"
    },
    {
      "start": 1132.13,
      "end": 1136.53,
      "text": "물론, 뭐 안 틀려는데도 있죠?"
    },
    {
      "start": 1136.53,
      "end": 1137.69,
      "text": "뭐 예를 들면"
    },
    {
      "start": 1137.69,
      "end": 1142.29,
      "text": "여기에서 행복하나 봐"
    },
    {
      "start": 1142.29,
      "end": 1144.09,
      "text": "행복 좀 길어져"
    },
    {
      "start": 1144.09,
      "end": 1146.01,
      "text": "그래서 ABC 나왔고"
    },
    {
      "start": 1146.01,
      "end": 1147.81,
      "text": "B가 행보로 나오는 거죠?"
    },
    {
      "start": 1147.81,
      "end": 1150.69,
      "text": "그 다음에 떨어지면 이제"
    },
    {
      "start": 1150.69,
      "end": 1151.77,
      "text": "더 떨어질 수 있죠?"
    },
    {
      "start": 1151.77,
      "end": 1155.41,
      "text": "이러면 WXYXC 패턴인데"
    },
    {
      "start": 1155.41,
      "end": 1158.73,
      "text": "근데 그래도 뭐 큰 손에 낳을 거 같아요."
    },
    {
      "start": 1158.73,
      "end": 1160.37,
      "text": "저 피부에 행복한"
    },
    {
      "start": 1160.37,
      "end": 1162.65,
      "text": "생각스러운 이렇게 나올 거잖아."
    },
    {
      "start": 1162.65,
      "end": 1164.05,
      "text": "그래서 지금 가격쯤"
    },
    {
      "start": 1164.05,
      "end": 1166.89,
      "text": "이면 만약에 지금 매서랑 의미나 아니지만"
    },
    {
      "start": 1166.89,
      "end": 1169.89,
      "text": "지금 쯤 모류를 바다라고 하면"
    },
    {
      "start": 1169.89,
      "end": 1173.49,
      "text": "그러면 손절라인이 생각쯤 하다니 될 거고"
    },
    {
      "start": 1173.49,
      "end": 1176.01,
      "text": "아마 가격차이는 크게 안 날 거예요."
    },
    {
      "start": 1176.01,
      "end": 1179.41,
      "text": "그래서 손 내 손절름 크게 안 볼 거 같고"
    },
    {
      "start": 1179.41,
      "end": 1184.67,
      "text": "올라가면 다니 손이 띄는 좋고"
    },
    {
      "start": 1184.67,
      "end": 1186.39,
      "text": "그럴 거 같다."
    },
    {
      "start": 1186.39,
      "end": 1188.11,
      "text": "근데 이제 생각 좀 안 나오고"
    },
    {
      "start": 1188.11,
      "end": 1191.95,
      "text": "그냥 떨어진 경우는 솔직히 잘 모르겠어요."
    },
    {
      "start": 1191.95,
      "end": 1193.71,
      "text": "생각스러운 만드하고 그냥 떨어질 수 있나?"
    },
    {
      "start": 1193.71,
      "end": 1195.63,
      "text": "사실 이러면 이제 좀 당스러운 데"
    },
    {
      "start": 1195.63,
      "end": 1197.15,
      "text": "이러면 손절라인 좀 멀죠?"
    },
    {
      "start": 1197.15,
      "end": 1201.68,
      "text": "여기에요."
    },
    {
      "start": 1201.68,
      "end": 1203.48,
      "text": "그리고 이쪽 라인, 일단 이쪽 라인 여기"
    },
    {
      "start": 1203.48,
      "end": 1208.78,
      "text": "그리고 현재 지금 여기 있고"
    },
    {
      "start": 1208.78,
      "end": 1212.42,
      "text": "롱 보는 게 손이 뼈 완전 에서나"
    },
    {
      "start": 1212.42,
      "end": 1213.94,
      "text": "홍을 조금 안쯤 에서나?"
    },
    {
      "start": 1213.94,
      "end": 1215.94,
      "text": "맞는 거 같아요."
    },
    {
      "start": 1215.94,
      "end": 1218.5,
      "text": "지금 그렇게 생각합니다."
    },
    {
      "start": 1218.5,
      "end": 1220.66,
      "text": "어쨌든"
    },
    {
      "start": 1220.66,
      "end": 1223.3,
      "text": "그러하고"
    },
    {
      "start": 1223.3,
      "end": 1227.02,
      "text": "지금 맵었던 거는 별게 없긴 했어요."
    },
    {
      "start": 1227.02,
      "end": 1230.74,
      "text": "보시면 뭐 이렇게 맵고"
    },
    {
      "start": 1230.74,
      "end": 1234.54,
      "text": "10번 거 손해본 거 좀 왔다갔다 하고"
    },
    {
      "start": 1234.54,
      "end": 1239.88,
      "text": "지금 이제 롱 들어가 있고 그냥 그렇습니다."
    },
    {
      "start": 1239.88,
      "end": 1243.08,
      "text": "저 롱 평다 하는 중만 6천이 150이고"
    },
    {
      "start": 1243.08,
      "end": 1245.82,
      "text": "손절라인은 여기 윗망오천 700에다가"
    },
    {
      "start": 1245.82,
      "end": 1249.08,
      "text": "그런 아쉬움이 됩니다."
    },
    {
      "start": 1249.08,
      "end": 1253.38,
      "text": "위치원 라갈치에 선절라갈지 모르겠네요."
    },
    {
      "start": 1253.38,
      "end": 1261.4,
      "text": "어쨌든 롱을 보고 있습니다."
    },
    {
      "start": 1261.4,
      "end": 1267.43,
      "text": "바닥을 수상으로 리딩으로 바아도 되지 않냐고"
    },
    {
      "start": 1267.43,
      "end": 1270.07,
      "text": "좀 애매하지 않나요?"
    },
    {
      "start": 1270.07,
      "end": 1272.39,
      "text": "볼 수 있나?"
    },
    {
      "start": 1272.39,
      "end": 1280.02,
      "text": "이렇게?"
    },
    {
      "start": 1280.02,
      "end": 1282.14,
      "text": "뭐 와"
    },
    {
      "start": 1282.14,
      "end": 1284.46,
      "text": "안 되는 건 아니죠?"
    },
    {
      "start": 1284.46,
      "end": 1289.22,
      "text": "여기 위에가 휩소가 있었다"
    },
    {
      "start": 1289.22,
      "end": 1290.98,
      "text": "꼬리가 튀어 나오는데"
    },
    {
      "start": 1290.98,
      "end": 1292.18,
      "text": "안 되는 건 아니죠?"
    },
    {
      "start": 1292.18,
      "end": 1310.16,
      "text": "1위, 3위, 3위, 3위 등으로 볼 수 있겠네요."
    },
    {
      "start": 1310.16,
      "end": 1311.96,
      "text": "갈트요?"
    },
    {
      "start": 1311.96,
      "end": 1320.78,
      "text": "아직도 알트 희망 못 볼었어요?"
    },
    {
      "start": 1320.78,
      "end": 1323.54,
      "text": "제가 작년에 방송할 때"
    },
    {
      "start": 1323.54,
      "end": 1328.02,
      "text": "알트장 안 온다고 해가지고 맨날 시청자 남쌀 없잖아."
    },
    {
      "start": 1328.02,
      "end": 1333.24,
      "text": "이 부관에서 맨날 안 온다고 얘기해가지고"
    },
    {
      "start": 1333.24,
      "end": 1335.4,
      "text": "싫어해 알트장 안 온다고 하면"
    },
    {
      "start": 1335.4,
      "end": 1338.28,
      "text": "왜 알트으로 다 둔 벌려고 하는데"
    },
    {
      "start": 1338.28,
      "end": 1339.68,
      "text": "싫어하는 건 싫어하는 거고"
    },
    {
      "start": 1339.68,
      "end": 1342.84,
      "text": "안 할 것 같은 거고"
    },
    {
      "start": 1342.84,
      "end": 1347.64,
      "text": "알트 제가 먹을 수 있는 주간이 딱 하나라 그랬죠?"
    },
    {
      "start": 1347.64,
      "end": 1349.24,
      "text": "이 피티시 도미냈을 때"
    },
    {
      "start": 1349.24,
      "end": 1352.52,
      "text": "피티가 빠지으면서"
    },
    {
      "start": 1352.52,
      "end": 1354.04,
      "text": "여기 위에"
    },
    {
      "start": 1354.04,
      "end": 1356.2,
      "text": "1금 상으로 허락 달건수 있고"
    },
    {
      "start": 1356.2,
      "end": 1357.56,
      "text": "외치 패턴 나왔고"
    },
    {
      "start": 1357.56,
      "end": 1363.47,
      "text": "그래서 1차 빠지면 여기까지"
    },
    {
      "start": 1363.47,
      "end": 1366.71,
      "text": "여기 분개되면 아마 여기까지 빠지면서"
    },
    {
      "start": 1366.71,
      "end": 1368.71,
      "text": "알트장 올 것 같다"
    },
    {
      "start": 1368.71,
      "end": 1370.95,
      "text": "이 부관만 먹자였어요"
    },
    {
      "start": 1370.95,
      "end": 1373.07,
      "text": "1차 공갓은 없고 이 차 공갓이 안 왔고"
    },
    {
      "start": 1373.07,
      "end": 1374.63,
      "text": "이 때 잠깐 아니었으면"
    },
    {
      "start": 1374.63,
      "end": 1376.99,
      "text": "알트장은 없는 것 같아요"
    },
    {
      "start": 1376.99,
      "end": 1380.63,
      "text": "제가 봤다 앞으로도 알트장은 없을 것 같아요"
    },
    {
      "start": 1380.63,
      "end": 1387.96,
      "text": "그러니까 갈수록 안 오는 것 같아요"
    },
    {
      "start": 1387.96,
      "end": 1390.72,
      "text": "여러분도 제가 아마 샀을 겪겠지만"
    },
    {
      "start": 1390.72,
      "end": 1394.36,
      "text": "이때가 대알트장이었고"
    },
    {
      "start": 1394.36,
      "end": 1397.08,
      "text": "그 다음에 이때도 괜찮은 알트장이었고"
    },
    {
      "start": 1397.08,
      "end": 1400.36,
      "text": "이번에는 없었어요 제가 보게"
    },
    {
      "start": 1400.36,
      "end": 1402.6,
      "text": "이더림 쏠라나 모르긴 했는데"
    },
    {
      "start": 1402.6,
      "end": 1410.17,
      "text": "그거를 우리가 지음회의자에 몇 개 오른 거 우리가 원했던 알트장이라고 하진 않잖아요"
    },
    {
      "start": 1410.17,
      "end": 1413.09,
      "text": "올렸던 정목의 가짓 수도 많았고"
    },
    {
      "start": 1413.09,
      "end": 1415.21,
      "text": "상승률도 많았고"
    },
    {
      "start": 1415.21,
      "end": 1418.69,
      "text": "가짓 수도 주고 상승률도 주고"
    },
    {
      "start": 1418.69,
      "end": 1420.53,
      "text": "가짓 수 완전 만지스럽고"
    },
    {
      "start": 1420.53,
      "end": 1422.33,
      "text": "상승률도 완전 만지스럽고"
    },
    {
      "start": 1422.33,
      "end": 1424.29,
      "text": "다음에는 어떻게 될까요?"
    },
    {
      "start": 1424.29,
      "end": 1428.09,
      "text": "갑자기 이어 없이 대알트장에 올까?"
    },
    {
      "start": 1428.09,
      "end": 1430.83,
      "text": "그어요"
    },
    {
      "start": 1430.83,
      "end": 1434.23,
      "text": "영어카 근거 없이"
    },
    {
      "start": 1434.23,
      "end": 1436.03,
      "text": "또 힘든데"
    },
    {
      "start": 1436.03,
      "end": 1437.07,
      "text": "근거 20도 힘든데"
    },
    {
      "start": 1437.07,
      "end": 1438.43,
      "text": "예측한 게 근거 없이"
    },
    {
      "start": 1438.43,
      "end": 1442.52,
      "text": "뭐 알트장 예측하는 건 어렵지 않을까?"
    },
    {
      "start": 1442.52,
      "end": 1445.72,
      "text": "혜킹당한 거는 이제"
    },
    {
      "start": 1445.72,
      "end": 1448.12,
      "text": "접수했고 본청 사이버에서 수사했는데"
    },
    {
      "start": 1448.12,
      "end": 1450.72,
      "text": "북한에 코소행 이래요"
    },
    {
      "start": 1450.72,
      "end": 1452.48,
      "text": "단정기를 쓰는데"
    },
    {
      "start": 1452.48,
      "end": 1456.64,
      "text": "북한 혜코소행일 황일"
    },
    {
      "start": 1456.64,
      "end": 1459.28,
      "text": "99%"
    },
    {
      "start": 1459.28,
      "end": 1464.64,
      "text": "라고 합니다"
    },
    {
      "start": 1464.64,
      "end": 1467.76,
      "text": "그리고 이제 운천상에서 설거지를"
    },
    {
      "start": 1467.76,
      "end": 1469.96,
      "text": "뽑도드 뽑도드 하게 해가지고"
    },
    {
      "start": 1469.96,
      "end": 1470.96,
      "text": "못 찾겠대요"
    },
    {
      "start": 1470.96,
      "end": 1476.36,
      "text": "경시한도"
    },
    {
      "start": 1476.36,
      "end": 1479.64,
      "text": "뭐 여기저기 세탁을 만들렸더라고요"
    },
    {
      "start": 1479.64,
      "end": 1481.08,
      "text": "뭐 뭐"
    },
    {
      "start": 1481.08,
      "end": 1481.92,
      "text": "여기저기 막"
    },
    {
      "start": 1481.92,
      "end": 1483.92,
      "text": "그 노들도 부딪지하고"
    },
    {
      "start": 1483.92,
      "end": 1484.8,
      "text": "다음에 무슨 뭐"
    },
    {
      "start": 1484.8,
      "end": 1486.12,
      "text": "와사비 원래"
    },
    {
      "start": 1486.12,
      "end": 1492.03,
      "text": "그게 세탁할 때 쓰는 건가 봐요"
    },
    {
      "start": 1492.03,
      "end": 1496.03,
      "text": "그 믹싱하는 기능이래요"
    },
    {
      "start": 1496.03,
      "end": 1498.03,
      "text": "여러 주세요 주소만 보고"
    },
    {
      "start": 1498.03,
      "end": 1500.51,
      "text": "출근 이나예너렇게 해서"
    },
    {
      "start": 1500.51,
      "end": 1501.71,
      "text": "자금 세탁 추조 안 되게"
    },
    {
      "start": 1501.71,
      "end": 1503.75,
      "text": "믹싱하는 원래 시가도 안 되게"
    },
    {
      "start": 1503.75,
      "end": 1505.63,
      "text": "와사비 원래 시가 안 믹싱을 해서"
    },
    {
      "start": 1505.63,
      "end": 1507.99,
      "text": "그래서 최종 세탁까지 맞춰서"
    },
    {
      "start": 1507.99,
      "end": 1510.76,
      "text": "못 찾는데요"
    },
    {
      "start": 1510.76,
      "end": 1514.76,
      "text": "북한의 코일 이라고 하더라고요"
    },
    {
      "start": 1514.76,
      "end": 1516.28,
      "text": "경찰청 말라"
    },
    {
      "start": 1516.28,
      "end": 1518.36,
      "text": "제 피시 포링시까지 했습니다"
    },
    {
      "start": 1518.36,
      "end": 1521.8,
      "text": "경찰 서울 본청 사이버에서 가져와서"
    },
    {
      "start": 1521.8,
      "end": 1523.8,
      "text": "피시 포링시까지 했는데"
    },
    {
      "start": 1523.8,
      "end": 1531.16,
      "text": "뭐 답이 없대요"
    },
    {
      "start": 1531.16,
      "end": 1534.2,
      "text": "9월 2매일에 털 옆에 9월 2매를 연동된"
    },
    {
      "start": 1534.2,
      "end": 1535.32,
      "text": "OTP가 털였어요"
    },
    {
      "start": 1535.32,
      "end": 1538.52,
      "text": "저는 제 핸드폰을 뺏기지 않는 이사 안 털인 줄 알았는데"
    },
    {
      "start": 1538.52,
      "end": 1541.12,
      "text": "9월 OTP가 털여서 그래요"
    },
    {
      "start": 1541.12,
      "end": 1542.92,
      "text": "여러분들 9구로 TPS지 마시고"
    },
    {
      "start": 1542.92,
      "end": 1544.76,
      "text": "다른 OTP 있으세요"
    },
    {
      "start": 1544.76,
      "end": 1546.0,
      "text": "본인이 쓰는 부블림에"
    },
    {
      "start": 1546.0,
      "end": 1548.84,
      "text": "이 맬 계정이랑 동계하다 있는데"
    },
    {
      "start": 1548.84,
      "end": 1552.0,
      "text": "그게 털인다 같이 털여요"
    },
    {
      "start": 1552.0,
      "end": 1557.38,
      "text": "제가 그것 때문에 털인 겁니다"
    },
    {
      "start": 1557.38,
      "end": 1558.7,
      "text": "그냥 쉽게 얘기하면"
    },
    {
      "start": 1558.7,
      "end": 1560.9,
      "text": "9구로 OTP를 쓰지 마시고"
    },
    {
      "start": 1560.9,
      "end": 1566.69,
      "text": "다른 OTP를 쓰여"
    },
    {
      "start": 1566.69,
      "end": 1567.37,
      "text": "시기 이야기하면"
    },
    {
      "start": 1567.37,
      "end": 1569.53,
      "text": "근데 왜 9구로 TPS지 말라고 하냐"
    },
    {
      "start": 1569.53,
      "end": 1572.41,
      "text": "근데 9구로 TPS 9구를"
    },
    {
      "start": 1572.41,
      "end": 1574.41,
      "text": "이매를 동계하다가 되 있거든요"
    },
    {
      "start": 1574.41,
      "end": 1576.81,
      "text": "글쓴이 있어요"
    },
    {
      "start": 1576.81,
      "end": 1578.97,
      "text": "그래서 제 이맬이 털여서 정확히는"
    },
    {
      "start": 1578.97,
      "end": 1580.01,
      "text": "이맬이를 털리니까"
    },
    {
      "start": 1580.01,
      "end": 1582.17,
      "text": "이맬일과 동계하는 9구로 OTP가 털였어요"
    },
    {
      "start": 1582.17,
      "end": 1584.65,
      "text": "OTP가 털리니까 핸드폰이 말정해도"
    },
    {
      "start": 1584.65,
      "end": 1585.69,
      "text": "추금이 된 거죠"
    },
    {
      "start": 1585.69,
      "end": 1589.13,
      "text": "핸드폰 핵킹당하고 핸드폰이라고 하는데요"
    },
    {
      "start": 1589.13,
      "end": 1598.81,
      "text": "그래서 그냥 9구로 TPS지 마세요"
    },
    {
      "start": 1598.81,
      "end": 1600.65,
      "text": "아무 OTP는 쓰세요"
    },
    {
      "start": 1600.65,
      "end": 1612.17,
      "text": "9구로 TPS는 안 할 수 있는"
    },
    {
      "start": 1612.17,
      "end": 1615.29,
      "text": "맥두기랑 상관없어요"
    },
    {
      "start": 1615.29,
      "end": 1620.52,
      "text": "맥두기랑 아무 상관없어요"
    },
    {
      "start": 1620.52,
      "end": 1623.24,
      "text": "그냥 이제 저는 원래 북한 안 좋아했지만"
    },
    {
      "start": 1623.24,
      "end": 1628.65,
      "text": "이제 이 사건으로 내부칸 진짜 싫어졌어요"
    },
    {
      "start": 1628.65,
      "end": 1634.92,
      "text": "그냥"
    },
    {
      "start": 1634.92,
      "end": 1635.64,
      "text": "거군요"
    },
    {
      "start": 1635.64,
      "end": 1638.28,
      "text": "그게 북한"
    },
    {
      "start": 1639.56,
      "end": 1641.64,
      "text": "뭐냐 정치적으로 하는 거잖아요"
    },
    {
      "start": 1641.64,
      "end": 1642.84,
      "text": "그러니까 그"
    },
    {
      "start": 1642.84,
      "end": 1645.48,
      "text": "계게인이 북한에 커가 있는 게 아니라"
    },
    {
      "start": 1645.48,
      "end": 1647.88,
      "text": "계게인 시민이 한 게 아니라 그냥"
    },
    {
      "start": 1647.88,
      "end": 1649.88,
      "text": "그 나라에서 밀어주는 거잖아요"
    },
    {
      "start": 1649.88,
      "end": 1652.92,
      "text": "핵킹은 아주 덤버로가 구워가지고"
    },
    {
      "start": 1652.92,
      "end": 1656.2,
      "text": "그 김정은 우리 수령님"
    },
    {
      "start": 1656.2,
      "end": 1662.62,
      "text": "비자금 조성하고 핵개발 하는 데 쓰고 그런 거잖아요"
    },
    {
      "start": 1662.62,
      "end": 1664.62,
      "text": "왜 그러고 사는지 모르겠어요"
    },
    {
      "start": 1665.9,
      "end": 1668.62,
      "text": "아무튼"
    },
    {
      "start": 1668.62,
      "end": 1670.54,
      "text": "그냥 플레이스처에 OTP 처보세요"
    },
    {
      "start": 1670.54,
      "end": 1676.41,
      "text": "스트로 팩든 나오니까"
    },
    {
      "start": 1676.41,
      "end": 1679.05,
      "text": "아무튼 다들 조심하시고"
    },
    {
      "start": 1679.05,
      "end": 1686.56,
      "text": "조심하시고"
    },
    {
      "start": 1686.56,
      "end": 1689.52,
      "text": "방금 ABC로 떨어진 거 세부 파통 어떻게 보거든요"
    },
    {
      "start": 1689.52,
      "end": 1693.12,
      "text": "이거 누가 봐도 ABC인데 이거를 세부 파팅 볼 수가 있어요"
    },
    {
      "start": 1693.12,
      "end": 1694.96,
      "text": "볼 필요가 있어요"
    },
    {
      "start": 1694.96,
      "end": 1697.2,
      "text": "여기도 누가 봐도 ABC인데"
    },
    {
      "start": 1697.2,
      "end": 1699.6,
      "text": "그래도 누가 봐도 ABC"
    },
    {
      "start": 1699.6,
      "end": 1701.76,
      "text": "여기는 제거"
    },
    {
      "start": 1701.76,
      "end": 1704.48,
      "text": "인퍼를 갖기도 하고 보죠"
    },
    {
      "start": 1704.48,
      "end": 1712.72,
      "text": "아니면 ABC 수도 있지만"
    },
    {
      "start": 1712.72,
      "end": 1715.84,
      "text": "이게 왜 궁금하실 수 있었더니"
    },
    {
      "start": 1715.84,
      "end": 1730.84,
      "text": "너무 영화가 간데"
    },
    {
      "start": 1730.84,
      "end": 1734.6,
      "text": "대신폰 잃어버림 돈 못 찾아야는 아니에요"
    },
    {
      "start": 1734.6,
      "end": 1738.28,
      "text": "본인 신혼 인증하고 거래소에 자기가 동목해놓은"
    },
    {
      "start": 1738.28,
      "end": 1740.2,
      "text": "어떻게 초기하실 수 있어요"
    },
    {
      "start": 1740.2,
      "end": 1749.32,
      "text": "복잡해지는 거죠 이리"
    },
    {
      "start": 1749.32,
      "end": 1753.64,
      "text": "대신 핵킹 당할 일은 없고 복잡해지는 대신"
    },
    {
      "start": 1754.2,
      "end": 1766.52,
      "text": "본인의 선택이에요"
    },
    {
      "start": 1766.52,
      "end": 1771.32,
      "text": "하방 외치로 컴퓨터 어떤가요"
    },
    {
      "start": 1771.32,
      "end": 1775.47,
      "text": "아 여기를"
    },
    {
      "start": 1775.47,
      "end": 1776.59,
      "text": "이렇게"
    },
    {
      "start": 1776.59,
      "end": 1798.92,
      "text": "네 뭐 그러셔도 되고요"
    },
    {
      "start": 1798.92,
      "end": 1802.49,
      "text": "장기관점은"
    },
    {
      "start": 1802.49,
      "end": 1810.52,
      "text": "뭐 솔직히 얘기해서 진짜 오대로 생각하고 다 열어놨어요"
    },
    {
      "start": 1810.52,
      "end": 1812.84,
      "text": "한 번 더 5만 5000"
    },
    {
      "start": 1812.84,
      "end": 1819.05,
      "text": "밑에까지 내려올지 않냐로 지지금 알 수 없고"
    },
    {
      "start": 1819.05,
      "end": 1821.05,
      "text": "여기서 어떻게 나온지 봐야하죠"
    },
    {
      "start": 1821.05,
      "end": 1824.57,
      "text": "일단 저는 반등 나올 거로 생각하는데"
    },
    {
      "start": 1824.57,
      "end": 1826.41,
      "text": "여기서 비비다가"
    },
    {
      "start": 1826.41,
      "end": 1828.65,
      "text": "다시 올라가면"
    },
    {
      "start": 1828.65,
      "end": 1831.69,
      "text": "여기가 저점인 거고"
    },
    {
      "start": 1831.69,
      "end": 1834.57,
      "text": "비비다가 하라그로 또 내려가면"
    },
    {
      "start": 1834.57,
      "end": 1837.93,
      "text": "저는 아 저 좀 깨루한다 이때"
    },
    {
      "start": 1837.93,
      "end": 1840.57,
      "text": "이 파도 나오네 저 좀 깨루한다 생각할 거예요"
    },
    {
      "start": 1840.57,
      "end": 1848.81,
      "text": "지금은 알 수 없어요"
    },
    {
      "start": 1848.81,
      "end": 1853.13,
      "text": "아무튼 그리고"
    },
    {
      "start": 1853.13,
      "end": 1857.16,
      "text": "소식 하나 전해드리면"
    },
    {
      "start": 1857.16,
      "end": 1864.12,
      "text": "공주 올리그인 할 건데 4월 너 7일 들어"
    },
    {
      "start": 1864.12,
      "end": 1865.72,
      "text": "8월 10일"
    },
    {
      "start": 1865.72,
      "end": 1867.08,
      "text": "한 번가 10시 8일"
    },
    {
      "start": 1867.08,
      "end": 1883.96,
      "text": "10시 10"
    },
    {
      "start": 1885.0,
      "end": 1888.99,
      "text": "일단 4월 10일에"
    },
    {
      "start": 1888.99,
      "end": 1894.59,
      "text": "시아예스 라는 곳에서 발표를 하게 됐어요"
    },
    {
      "start": 1894.59,
      "end": 1896.51,
      "text": "시아예스는 뭐냐면"
    },
    {
      "start": 1896.51,
      "end": 1900.51,
      "text": "크립토인 베스 머트 쇼"
    },
    {
      "start": 1900.51,
      "end": 1904.51,
      "text": "라고 하고"
    },
    {
      "start": 1904.51,
      "end": 1906.35,
      "text": "한화"
    },
    {
      "start": 1906.35,
      "end": 1911.63,
      "text": "그래서 주간하는 행사 라고 해요"
    },
    {
      "start": 1911.63,
      "end": 1913.95,
      "text": "이제 기존의"
    },
    {
      "start": 1913.95,
      "end": 1916.11,
      "text": "글로벌에서 가장 영향력 있는 행사가"
    },
    {
      "start": 1916.11,
      "end": 1918.03,
      "text": "토크닉공사 그런 건데"
    },
    {
      "start": 1918.03,
      "end": 1921.66,
      "text": "토크닉공사구가"
    },
    {
      "start": 1921.66,
      "end": 1923.98,
      "text": "1년에 죽어내거든요"
    },
    {
      "start": 1923.98,
      "end": 1928.78,
      "text": "한 번은 이제 주 바이에서 한 번은 신가포를 했어요"
    },
    {
      "start": 1928.78,
      "end": 1932.7,
      "text": "근데 시아예스는 중동은 중동인데"
    },
    {
      "start": 1932.7,
      "end": 1934.78,
      "text": "주 바이에 큰형님이 어디죠?"
    },
    {
      "start": 1934.78,
      "end": 1936.22,
      "text": "아프다 아프죠"
    },
    {
      "start": 1936.22,
      "end": 1939.42,
      "text": "그리고 아시아 국가 중에서 신가포를 아니라"
    },
    {
      "start": 1939.42,
      "end": 1940.46,
      "text": "한국"
    },
    {
      "start": 1940.46,
      "end": 1943.26,
      "text": "이렇게 이제 크립토 허브를 만들자"
    },
    {
      "start": 1943.26,
      "end": 1945.18,
      "text": "라는 행사 라고 하더라고요"
    },
    {
      "start": 1945.18,
      "end": 1946.46,
      "text": "거기에 대해서 이제"
    },
    {
      "start": 1946.46,
      "end": 1949.5,
      "text": "소등해를 받았었을 발표를 하게 됐고"
    },
    {
      "start": 1949.5,
      "end": 1953.66,
      "text": "그래서 이 행사에서는 좀"
    },
    {
      "start": 1954.94,
      "end": 1957.1,
      "text": "좋은 내용들이 공유 될 것 같아요"
    },
    {
      "start": 1957.1,
      "end": 1959.66,
      "text": "그래서 한국에서는 그동안 큰 행사가 없었는데"
    },
    {
      "start": 1959.66,
      "end": 1961.74,
      "text": "그래서 토크닉공사구 참고 하려면"
    },
    {
      "start": 1961.74,
      "end": 1964.94,
      "text": "여러분들의 신가포를 한 두 번 가썼어야 되는데"
    },
    {
      "start": 1964.94,
      "end": 1968.7,
      "text": "그렇지 않으시 아예스는 한국에서 하니까"
    },
    {
      "start": 1968.7,
      "end": 1971.26,
      "text": "코인 투자 관심 있으신 분들은"
    },
    {
      "start": 1971.26,
      "end": 1975.02,
      "text": "지금 코인 어깨가 틀러 가는지"
    },
    {
      "start": 1975.02,
      "end": 1976.7,
      "text": "한 장 와서 느껴보시면 좋을 것 같아요"
    },
    {
      "start": 1976.7,
      "end": 1979.1,
      "text": "저도 이제 발표를 하게 됐고"
    },
    {
      "start": 1979.1,
      "end": 1981.58,
      "text": "어쨌든"
    },
    {
      "start": 1981.58,
      "end": 1984.86,
      "text": "그래서 이제 그를 올릴 건데"
    },
    {
      "start": 1984.86,
      "end": 1989.02,
      "text": "뭐 한 100분 200분 무려 초대 이렇게 할 거고"
    },
    {
      "start": 1989.02,
      "end": 1992.06,
      "text": "행사 금액을 올려면 모르겠는데"
    },
    {
      "start": 1992.06,
      "end": 1994.78,
      "text": "빛 살 거예요 무료 초대 아니면 막 한"
    },
    {
      "start": 1994.78,
      "end": 1998.78,
      "text": "30만 원 40만 원 할 수도 있고 이를 꺼내"
    },
    {
      "start": 1998.78,
      "end": 2002.54,
      "text": "어쨌든 시청자 선착순 이벤트 이런 거 할 테니까"
    },
    {
      "start": 2002.54,
      "end": 2010.25,
      "text": "올리면은 올리면 뭐 신청하실 분들은 신청해주세요"
    },
    {
      "start": 2010.25,
      "end": 2014.41,
      "text": "이때 이제 풀 저의 발표는"
    },
    {
      "start": 2014.41,
      "end": 2024.19,
      "text": "이 경우 이 이유"
    },
    {
      "start": 2024.19,
      "end": 2027.07,
      "text": "이런 주제에요 제가 발표를 주시는"
    },
    {
      "start": 2027.07,
      "end": 2029.79,
      "text": "이공위로 내가 놀이는 단 하나의 탓점"
    },
    {
      "start": 2029.79,
      "end": 2033.15,
      "text": "그리고 꾸준히 돈보는 것"
    },
    {
      "start": 2033.15,
      "end": 2036.91,
      "text": "그냥 거창하고 멋있는 걸 수 있는데"
    },
    {
      "start": 2036.91,
      "end": 2041.63,
      "text": "사실 사람들이 제일 궁금해하는 거 해야 될 것 같아요"
    },
    {
      "start": 2041.63,
      "end": 2048.35,
      "text": "올해 매수 한다면 어느 탓점에 내가 들어갈 것인가"
    },
    {
      "start": 2048.35,
      "end": 2053.87,
      "text": "그리고 올해 그렇게 탓점 잘 잡을 건데 앞으로 꾸준히는 어떻게 뭐라야 되는가"
    },
    {
      "start": 2053.87,
      "end": 2059.23,
      "text": "이 주제로 발표를 할 거니까 관심 있으신 분들은"
    },
    {
      "start": 2060.19,
      "end": 2064.19,
      "text": "컴퓨터에다가 유튜브 계시판에다가 올릴 테니까"
    },
    {
      "start": 2064.19,
      "end": 2069.28,
      "text": "선착순 행사할 테니까 신청하세요"
    },
    {
      "start": 2069.28,
      "end": 2072.96,
      "text": "환율 1500원 유놈말 누가 또 그 단들이 받는 거야"
    },
    {
      "start": 2072.96,
      "end": 2082.16,
      "text": "아 그런 소리 하지 마세요 환율 1500원"
    },
    {
      "start": 2082.16,
      "end": 2084.16,
      "text": "유놈말 같은 소리"
    },
    {
      "start": 2084.16,
      "end": 2088.72,
      "text": "여러분들 여러분들 진짜 지금"
    },
    {
      "start": 2088.72,
      "end": 2093.12,
      "text": "환율이 길까 미쳤죠 여러분들 주요서"
    },
    {
      "start": 2093.28,
      "end": 2094.96,
      "text": "정말 해보세요 주요 해봐"
    },
    {
      "start": 2094.96,
      "end": 2098.22,
      "text": "길은까 미쳤다고"
    },
    {
      "start": 2098.22,
      "end": 2102.52,
      "text": "유놈말 같은 소리 하고 있어"
    },
    {
      "start": 2102.52,
      "end": 2105.24,
      "text": "딜라인덱스 좀 볼까"
    },
    {
      "start": 2105.24,
      "end": 2108.04,
      "text": "아 딜라인덱스가 100인데"
    },
    {
      "start": 2108.04,
      "end": 2110.6,
      "text": "환율만 1000원 왜 계잖아 이거"
    },
    {
      "start": 2110.6,
      "end": 2112.84,
      "text": "뭔 유놈말이야 그냥 한국"
    },
    {
      "start": 2112.84,
      "end": 2119.29,
      "text": "한국 정부가 그냥 이를 너무 못해서 그래야"
    },
    {
      "start": 2119.29,
      "end": 2123.21,
      "text": "그렇게 추경해야 되는데 원화가 짓던 것 같대구"
    },
    {
      "start": 2123.21,
      "end": 2125.77,
      "text": "기준급닉이 인하 못하고"
    },
    {
      "start": 2125.77,
      "end": 2130.48,
      "text": "그러니까 그렇지 뭐"
    },
    {
      "start": 2130.48,
      "end": 2133.95,
      "text": "답도 없다"
    },
    {
      "start": 2133.95,
      "end": 2136.19,
      "text": "이제 묶어도 오를 거고"
    },
    {
      "start": 2136.19,
      "end": 2145.6,
      "text": "기능값도 오를 거고"
    },
    {
      "start": 2145.6,
      "end": 2148.16,
      "text": "진짜 이러면은 부동산 있는"
    },
    {
      "start": 2148.16,
      "end": 2153.95,
      "text": "부자들만 가격방업 제산 방어가 되고"
    },
    {
      "start": 2153.95,
      "end": 2155.55,
      "text": "서민들은"
    },
    {
      "start": 2155.55,
      "end": 2157.79,
      "text": "내 지없는 서민들은 방어가 안 된다니까"
    },
    {
      "start": 2157.79,
      "end": 2164.33,
      "text": "그냥 계속 거지되고 있는 거에 환율을만큼"
    },
    {
      "start": 2164.33,
      "end": 2168.25,
      "text": "60만원 중다고 전쟁 주경 좋아하지 마세요"
    },
    {
      "start": 2168.25,
      "end": 2171.13,
      "text": "그리고 전쟁은 남의 날아가 있는데 추경은 우리가"
    },
    {
      "start": 2171.13,
      "end": 2172.49,
      "text": "애"
    },
    {
      "start": 2175.85,
      "end": 2177.85,
      "text": "진짜 모르겠다"
    },
    {
      "start": 2177.85,
      "end": 2182.78,
      "text": "아무튼 정치에게 하지 마시다"
    },
    {
      "start": 2182.78,
      "end": 2186.38,
      "text": "어쨌든 환율 1000원 왜가 누군가 말은 아니고요"
    },
    {
      "start": 2186.38,
      "end": 2189.82,
      "text": "여기 한 번은 피자 나갈 수 있다고 생각해요"
    },
    {
      "start": 2189.82,
      "end": 2198.62,
      "text": "1000원 130원 때까지 갔잖아요"
    },
    {
      "start": 2198.62,
      "end": 2203.1,
      "text": "이럴 때에 우승자인데 부정행이 안 했는데"
    },
    {
      "start": 2203.1,
      "end": 2205.5,
      "text": "조금만 못 받았다고"
    },
    {
      "start": 2205.5,
      "end": 2210.7,
      "text": "이등 한 사람한테 5,000만원 지급했어요"
    },
    {
      "start": 2210.7,
      "end": 2214.46,
      "text": "그리고 제가 아기로는 1등 하신 분"
    },
    {
      "start": 2214.46,
      "end": 2216.86,
      "text": "부정행이 거의 확실하다 와는데"
    },
    {
      "start": 2216.86,
      "end": 2220.06,
      "text": "저도 웬만하면 오케이X이랑 이야기할 때"
    },
    {
      "start": 2220.06,
      "end": 2222.78,
      "text": "상금 둔데 할 때"
    },
    {
      "start": 2222.78,
      "end": 2224.86,
      "text": "확실한 없으면 그냥 줄하고 하거든요"
    },
    {
      "start": 2224.86,
      "end": 2228.22,
      "text": "제가 2년 동안 그렇게 기조대에 기둥 그랬어요"
    },
    {
      "start": 2228.22,
      "end": 2231.74,
      "text": "애매하면 상가 지금 패드로 해드리자"
    },
    {
      "start": 2231.74,
      "end": 2235.5,
      "text": "확실한 것만 필터링해서 버리지않아 이거 12월입니다"
    },
    {
      "start": 2235.5,
      "end": 2236.54,
      "text": "했는데"
    },
    {
      "start": 2236.54,
      "end": 2238.86,
      "text": "이럴 때 부정행이 이야기 드로는데"
    },
    {
      "start": 2238.86,
      "end": 2246.28,
      "text": "제가 알기로는 확실하다 오드렸습니다"
    },
    {
      "start": 2246.28,
      "end": 2247.88,
      "text": "먼저 어쨌든 이렇게 이야기하셨으니까"
    },
    {
      "start": 2247.88,
      "end": 2254.36,
      "text": "제가 한 번 더 오케이X이랑 이야기 해보겠습니다"
    },
    {
      "start": 2254.36,
      "end": 2257.4,
      "text": "어쨌든 이럴 상금은"
    },
    {
      "start": 2257.4,
      "end": 2261.0,
      "text": "1등 상금은 2등 간 뒤 2월대 가지고"
    },
    {
      "start": 2261.0,
      "end": 2264.44,
      "text": "2등이 5,000만원 받았고"
    },
    {
      "start": 2264.44,
      "end": 2271.16,
      "text": "또 2,000 등 상금이 2월대에서 3,000 등이 2,000 등 3등을 받았습니다"
    },
    {
      "start": 2271.16,
      "end": 2279.2,
      "text": "아무튼 오늘 방송은 여기서 짧게"
    },
    {
      "start": 2279.2,
      "end": 2281.6,
      "text": "마치도록 하고"
    },
    {
      "start": 2282.88,
      "end": 2287.44,
      "text": "아마 다음 주 토요일을 지금 방송할 것 같아요"
    },
    {
      "start": 2287.44,
      "end": 2290.24,
      "text": "숨어 끊출장이 있어서"
    },
    {
      "start": 2290.24,
      "end": 2293.28,
      "text": "신가폴 출장을 다녀올 거라"
    },
    {
      "start": 2293.28,
      "end": 2294.24,
      "text": "그럴 것 같습니다"
    },
    {
      "start": 2294.24,
      "end": 2298.56,
      "text": "월하는 어차피 내일하고 모레인데 방송을 내용이 있을리가 없고"
    },
    {
      "start": 2298.56,
      "end": 2303.96,
      "text": "어쨌든 오랜만에 방송했는데"
    },
    {
      "start": 2303.96,
      "end": 2307.24,
      "text": "다음 주 이럴에는 다음 주 주말에 꼭 방송하도록 하겠습니다"
    },
    {
      "start": 2307.24,
      "end": 2310.52,
      "text": "그리고 핵팀 때문에 짜증나서 맘에 잘 안 하고 있었는데"
    },
    {
      "start": 2310.52,
      "end": 2312.2,
      "text": "다시 맨날 거니까"
    },
    {
      "start": 2312.2,
      "end": 2322.43,
      "text": "파점하고 분석 자주 공유할게요"
    },
    {
      "start": 2322.43,
      "end": 2324.51,
      "text": "저는 좋은종랄 보내시고"
    },
    {
      "start": 2324.51,
      "end": 2327.07,
      "text": "꼽히는 본인 보니 왔던데"
    },
    {
      "start": 2327.07,
      "end": 2328.67,
      "text": "벗고 저도 보고 왔는데"
    },
    {
      "start": 2328.67,
      "end": 2331.07,
      "text": "예쁘다 라고 해요"
    },
    {
      "start": 2331.07,
      "end": 2332.43,
      "text": "여기서"
    },
    {
      "start": 2332.43,
      "end": 2336.35,
      "text": "날씨 좋을 때 가족들하고 선책도 많이 하시고"
    },
    {
      "start": 2336.35,
      "end": 2339.63,
      "text": "그렇게 기분 환기 한 다음에 맨날 더 집중해서 잘 하시고"
    },
    {
      "start": 2339.63,
      "end": 2343.63,
      "text": "어쨌든 좋은 계절 됐으면 좋겠습니다"
    },
    {
      "start": 2343.63,
      "end": 2345.95,
      "text": "좋은 주말 보내시고"
    },
    {
      "start": 2345.95,
      "end": 2347.23,
      "text": "마무리 잘 하시고"
    },
    {
      "start": 2347.23,
      "end": 2350.27,
      "text": "저는 이만 마치고 다음 주 주말에 뵙겠습니다"
    },
    {
      "start": 2350.27,
      "end": 2352.27,
      "text": "고맙습니다"
    }
  ]
}