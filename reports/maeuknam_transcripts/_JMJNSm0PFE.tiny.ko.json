      "start": 364.37,
      "end": 367.82,
      "text": "절반 역지 걸어놨어요"
    },
    {
      "start": 367.82,
      "end": 369.98,
      "text": "그래서 지금 보시면"
    },
    {
      "start": 369.98,
      "end": 371.9,
      "text": "일단 여기 쪼트러가 있고"
    },
    {
      "start": 371.9,
      "end": 373.26,
      "text": "절반 역지 걸어놨고"
    },
    {
      "start": 373.26,
      "end": 374.22,
      "text": "미시란 소념이기지만"
    },
    {
      "start": 374.22,
      "end": 376.06,
      "text": "3만 3,000 달라 정도 돼요"
    },
    {
      "start": 376.06,
      "end": 379.82,
      "text": "다음에 여기 오더 트레이드 들어가면"
    },
    {
      "start": 379.82,
      "end": 388.88,
      "text": "실험소념이 볼 수 있거든요"
    },
    {
      "start": 388.88,
      "end": 391.84,
      "text": "그러면 여기 보면"
    },
    {
      "start": 391.84,
      "end": 393.84,
      "text": "이게 아까 꼭 프리션 잡은 거예요"
    },
    {
      "start": 393.84,
      "end": 397.76,
      "text": "367 리요"
    },
    {
      "start": 397.76,
      "end": 399.76,
      "text": "그러면 이게 3,000 6000 달라는 제"
    },
    {
      "start": 399.76,
      "end": 402.56,
      "text": "그 수익을 받고"
    },
    {
      "start": 402.56,
      "end": 405.36,
      "text": "다음에 지금 이제"
    },
    {
      "start": 405.36,
      "end": 408.37,
      "text": "미시란 소념이기"
    },
    {
      "start": 408.37,
      "end": 409.65,
      "text": "3,000 7000 달라는 거예요"
    },
    {
      "start": 409.65,
      "end": 412.21,
      "text": "물론 여기에서 이제 역지 장에 나가면"
    },
    {
      "start": 412.21,
      "end": 415.17,
      "text": "한 뭐 한 5,000 달라 정도"
    },
    {
      "start": 415.17,
      "end": 416.69,
      "text": "소네가 날 수도 있어"
    },
    {
      "start": 416.69,
      "end": 418.53,
      "text": "5,000원인지 계속 안 해봐서 모르겠는데"
    },
    {
      "start": 418.53,
      "end": 420.37,
      "text": "그래 봤죠, 어쨌든 한 3,000 달라이지만"
    },
    {
      "start": 420.37,
      "end": 422.77,
      "text": "5,000 달라 수익이니까 수익이란 말이야"
    },
    {
      "start": 422.77,
      "end": 426.93,
      "text": "그래서 늘 하단대로 외매를 이렇게 차분하게 하면 되지"
    },
    {
      "start": 426.93,
      "end": 431.06,
      "text": "방송도 이제 못해놓고"
    },
    {
      "start": 431.06,
      "end": 434.85,
      "text": "참"
    },
    {
      "start": 434.85,
      "end": 437.25,
      "text": "안타깝습니다, 진짜요"
    },
    {
      "start": 437.25,
      "end": 439.65,
      "text": "제가 저도 왜 수학까지 와가지고"
    },
    {
      "start": 439.65,
      "end": 447.9,
      "text": "여기 지금"
    },
    {
      "start": 447.9,
      "end": 449.74,
      "text": "아무튼 그렇고"
    },
    {
      "start": 449.74,
      "end": 451.9,
      "text": "그"
    },
    {
      "start": 451.9,
      "end": 456.22,
      "text": "모르실 지금 일단 지난번 방송에서 말했던 것처럼"
    },
    {
      "start": 456.22,
      "end": 457.66,
      "text": "게다고 저는 생각을 해요"
    },
    {
      "start": 457.66,
      "end": 459.98,
      "text": "그래서 그래서 들어간 거고"
    },
    {
      "start": 459.98,
      "end": 461.82,
      "text": "다음에 역지 여기다 걸어놨고"
    },
    {
      "start": 461.82,
      "end": 464.94,
      "text": "여기보다 올라가면 그러면 아마"
    },
    {
      "start": 464.94,
      "end": 467.1,
      "text": "상방할 수도 있다고 생각을 하겠네요"
    },
    {
      "start": 467.1,
      "end": 469.98,
      "text": "물론 그렇다고 저는 롱을 7생각은 없어요"
    },
    {
      "start": 469.98,
      "end": 474.54,
      "text": "롱을 7생각은 없고"
    },
    {
      "start": 474.54,
      "end": 476.78,
      "text": "계속 하락 단점으로 보고 있기 때문에"
    },
    {
      "start": 476.78,
      "end": 477.98,
      "text": "그래서 지금은"
    },
    {
      "start": 477.98,
      "end": 479.42,
      "text": "지금 에비시 완성되고"
    },
    {
      "start": 479.42,
      "end": 481.34,
      "text": "그래서 앨비시 완성되고"
    },
    {
      "start": 481.34,
      "end": 482.3,
      "text": "비겨나고"
    },
    {
      "start": 482.3,
      "end": 485.02,
      "text": "시하락을 할 차례가 아닌가 라고 생각을 합니다"
    },
    {
      "start": 485.02,
      "end": 487.18,
      "text": "그러면 지난 방송에서처럼"
    },
    {
      "start": 487.18,
      "end": 489.18,
      "text": "제가 컴팅이 맞았다는"
    },
    {
      "start": 489.18,
      "end": 490.7,
      "text": "전체 관계가 안쯤에"
    },
    {
      "start": 490.7,
      "end": 494.14,
      "text": "여기가 1, 2, 3, 4, 5, 5, 5, 5, 5, 5,"
    },
    {
      "start": 494.14,
      "end": 496.14,
      "text": "그리고 에비시 반등에 나왔는데"
    },
    {
      "start": 496.14,
      "end": 497.34,
      "text": "에비시로 하락했다"
    },
    {
      "start": 497.34,
      "end": 499.1,
      "text": "그러면 이"
    },
    {
      "start": 499.1,
      "end": 500.38,
      "text": "컴팅에 틀렸거나"
    },
    {
      "start": 500.38,
      "end": 501.5,
      "text": "아니면 어떻게 되어야 된다"
    },
    {
      "start": 501.5,
      "end": 503.1,
      "text": "다시 상승을 해서"
    },
    {
      "start": 503.18,
      "end": 505.1,
      "text": "여기서 허락 인퀴실가 나와요"
    },
    {
      "start": 505.1,
      "end": 506.38,
      "text": "여기서부터 O"
    },
    {
      "start": 506.38,
      "end": 509.26,
      "text": "에비시 3, 5, 8, 7, 8, 4, 7, 8, 10"
    },
    {
      "start": 509.26,
      "end": 511.82,
      "text": "그래서 이렇게 될 거라고 저는 생각을 해요"
    },
    {
      "start": 511.82,
      "end": 513.82,
      "text": "그래서 당분간은"
    },
    {
      "start": 513.82,
      "end": 515.66,
      "text": "당분간은 가방 간점으로"
    },
    {
      "start": 515.66,
      "end": 517.66,
      "text": "물론 이 여기가 여기 얼마요"
    },
    {
      "start": 517.66,
      "end": 519.42,
      "text": "5만 2000원이 넘어가면"
    },
    {
      "start": 519.42,
      "end": 521.26,
      "text": "분석이 틀렸다고 생각을 하고"
    },
    {
      "start": 521.26,
      "end": 522.62,
      "text": "상방 간점을 볼 거지만"
    },
    {
      "start": 522.62,
      "end": 523.66,
      "text": "그 정까지는"
    },
    {
      "start": 523.66,
      "end": 524.86,
      "text": "이제 가방 간점을 보고"
    },
    {
      "start": 524.86,
      "end": 527.9,
      "text": "한 3만 5,000원까지는"
    },
    {
      "start": 527.9,
      "end": 530.22,
      "text": "문안하게 떨어질 거다 라고 해상을 하고"
    },
    {
      "start": 530.22,
      "end": 535.72,
      "text": "여기에서 다시 바터미 뚫렉이 보다는 크게 더불어봐도 다시 에비시로 반등히 오고"
    },
    {
      "start": 535.72,
      "end": 540.42,
      "text": "다음에 다시 곧정을 넘기지 못한 채로 다시 떨어질 것라 고생각을 합니다"
    },
    {
      "start": 540.42,
      "end": 546.1,
      "text": "이 작은 상승 구간에서도 현물도 샀어도 아칭 알트 많이 올랐죠?"
    },
    {
      "start": 546.1,
      "end": 550.02,
      "text": "적게는 뭐 1위 10%에서 많게는 4호 10% 올림코인들이 있어요"
    },
    {
      "start": 550.02,
      "end": 554.42,
      "text": "이 구간에서 분명히 현물들도 많이 올릴 거란 말아 이 구간에서는 엄청 올릴 거예요"
    },
    {
      "start": 554.42,
      "end": 556.42,
      "text": "두 새벼 오른코인들이 많이 나올 거예요"
    },
    {
      "start": 558.9,
      "end": 570.94,
      "text": "그렇기 때문에 이 구간도 잘 활용해 보시면 좋지 않을까 생각이 듭니다"
    },
    {
      "start": 570.94,
      "end": 578.6,
      "text": "어쨌든 뭐 지난 방송에서 했던 거랑 사실은"
    },
    {
      "start": 578.6,
      "end": 581.6,
      "text": "그냥 너무 무난하게 똑같이 흘러 왔는데"
    },
    {
      "start": 581.6,
      "end": 586.6,
      "text": "이게 대부분은 모른데스 얼마 만큼 이해하고 계신지"
    },
    {
      "start": 586.6,
      "end": 590.6,
      "text": "지금 채팅방 컷박범 보면 대부분은 다 이해하고 있는 것 같은데"
    },
    {
      "start": 590.6,
      "end": 597.36,
      "text": "그리고 유튜브 댓글만 꼭 일부 그렇단 말이야"
    },
    {
      "start": 597.36,
      "end": 602.36,
      "text": "그런데 그건 그렇고 만약에 만약에 분석이 틀릴 수도 있죠"
    },
    {
      "start": 602.36,
      "end": 608.36,
      "text": "그래서 이 상관 트렌드랑 뚫고 전꽃점 위로 올라간다고 하면"
    },
    {
      "start": 608.36,
      "end": 611.36,
      "text": "저는 그래도 약간 의심스러울 것 같긴 해요"
    },
    {
      "start": 611.36,
      "end": 614.36,
      "text": "그래서 선물을 놓은 안칠 거고 절대"
    },
    {
      "start": 614.36,
      "end": 618.36,
      "text": "현물를 차라리 여기서 괜찮게 봤던 어피트의 알티들"
    },
    {
      "start": 618.36,
      "end": 622.36,
      "text": "지금 특히 오생제 잘 나가는 코인들이 있죠"
    },
    {
      "start": 622.36,
      "end": 627.36,
      "text": "제가 이전부터 강조했지만 이제는 이제 자발트보다는 대형 코인 위주로"
    },
    {
      "start": 627.36,
      "end": 630.36,
      "text": "특히나 플랫폼 코인 위주로 보자고 제가 한 벗다듬서 한 2세 달"
    },
    {
      "start": 630.36,
      "end": 634.36,
      "text": "좀 대주의하게 하고 있는데 진짜 플랫폼 코인이 강된 것 같아요"
    },
    {
      "start": 634.36,
      "end": 638.36,
      "text": "플랫폼 코인 위주로 이 구간에서 차라리 매술해서"
    },
    {
      "start": 638.36,
      "end": 643.36,
      "text": "비트가 전꽃점을 6만 5000 넘인다라고 하면 알티들도 엄청 오를 테니까"
    },
    {
      "start": 643.36,
      "end": 646.36,
      "text": "차라리 그런 플랫폼 코인 상승을 먹는 게 낫지 않나"
    },
    {
      "start": 646.36,
      "end": 649.36,
      "text": "라고 생각이 듭니다"
    },
    {
      "start": 649.36,
      "end": 653.36,
      "text": "한 줄 요약하면 한 줄 요약하면"
    },
    {
      "start": 653.36,
      "end": 658.36,
      "text": "하락 인퍼스가 실패했다 여기서 저 지지를 분명히 받았죠"
    },
    {
      "start": 658.36,
      "end": 661.36,
      "text": "그다음에 ABC로 상승을 했다 ABC 상승을 했고"
    },
    {
      "start": 661.36,
      "end": 664.36,
      "text": "ABC 상승 하운티는 그냥 아주 간단해요"
    },
    {
      "start": 664.36,
      "end": 667.36,
      "text": "여기 A파도를 보고 여기 상각스러운다"
    },
    {
      "start": 667.36,
      "end": 672.36,
      "text": "저는 ABCD 보면 되어서 ABCB가 상각스러운다 왔다"
    },
    {
      "start": 672.36,
      "end": 675.36,
      "text": "지난번 댓글 보니까 여기 누가 봐도 인퍼스인데"
    },
    {
      "start": 675.36,
      "end": 678.36,
      "text": "누가 봐도 삼각스러우면 이게 어떻게 매운하시면"
    },
    {
      "start": 678.36,
      "end": 680.36,
      "text": "ABCD라고 하는 거는 진짜 객동이죠"
    },
    {
      "start": 680.36,
      "end": 683.36,
      "text": "아예 ABCD로 탑화동의 엘자도 모르는 거예요"
    },
    {
      "start": 683.36,
      "end": 686.36,
      "text": "P파가 삼각스러운다 왔잖아"
    },
    {
      "start": 686.36,
      "end": 688.36,
      "text": "그리고 ABCD로 돌아왔잖아"
    },
    {
      "start": 688.36,
      "end": 691.36,
      "text": "이거는 진짜 방송 한 달만 봐도 다 알겠다"
    },
    {
      "start": 691.36,
      "end": 692.36,
      "text": "그쵸?"
    },
    {
      "start": 692.36,
      "end": 697.36,
      "text": "또 그런 무시상 아플로드를 보니까 진짜 너무 화가 나다라고"
    },
    {
      "start": 697.36,
      "end": 701.36,
      "text": "아니 왜 내가 나 추구도 요구를 먹어야 되지"
    },
    {
      "start": 701.36,
      "end": 705.36,
      "text": "막 이런 생각이 들어가서 오늘 좀 부들려서 제가 방송을 켰는데"
    },
    {
      "start": 705.36,
      "end": 708.36,
      "text": "어떻게 보면 ABCD로 한테 징걸 수도 있죠"
    },
    {
      "start": 708.36,
      "end": 711.36,
      "text": "제가 휴식을 못 지하고"
    },
    {
      "start": 711.36,
      "end": 716.36,
      "text": "부들부들 제주도해서 지금 시담하고 이러고 있는데"
    },
    {
      "start": 716.36,
      "end": 719.36,
      "text": "뭐 어쨌든"
    },
    {
      "start": 719.36,
      "end": 722.36,
      "text": "덕분에 또 수익은 봤으니까"
    },
    {
      "start": 722.36,
      "end": 726.36,
      "text": "심 실험소녝이 3만 4천 달리 미션소녝이 3만 6천이니까"
    },
    {
      "start": 726.36,
      "end": 730.36,
      "text": "지금 이건만 해도 한 7,7,7만 원 되겠네"
    },
    {
      "start": 730.36,
      "end": 732.36,
      "text": "7만 달라니까 8,400만 원 정도 수익이네"
    },
    {
      "start": 733.36,
      "end": 735.36,
      "text": "앞으로 들 덕분에 도는 벌었네요"
    },
    {
      "start": 735.36,
      "end": 738.8,
      "text": "휴식은 못 채지만"
    },
    {
      "start": 738.8,
      "end": 740.8,
      "text": "아무튼 뭐 해서 ABC로 올라간 거고"
    },
    {
      "start": 740.8,
      "end": 742.8,
      "text": "제가 봤었을 때는"
    },
    {
      "start": 742.8,
      "end": 744.8,
      "text": "인퍼스 같지 않아요"
    },
    {
      "start": 744.8,
      "end": 746.8,
      "text": "물론 인퍼스일 수 있지"
    },
    {
      "start": 746.8,
      "end": 748.8,
      "text": "일파였고 2파가 삼각스러운다"
    },
    {
      "start": 748.8,
      "end": 750.8,
      "text": "오구 이제 3에 1이었고"
    },
    {
      "start": 750.8,
      "end": 751.8,
      "text": "3에 2가 나오고"
    },
    {
      "start": 751.8,
      "end": 753.8,
      "text": "3에 3에 올라가면"
    },
    {
      "start": 753.8,
      "end": 755.8,
      "text": "그러면 이게 이렇게 되겠죠"
    },
    {
      "start": 755.8,
      "end": 757.8,
      "text": "그러면 이게 인퍼스일 수 있지"
    },
    {
      "start": 757.8,
      "end": 759.8,
      "text": "그러면 어떻게 되냐"
    },
    {
      "start": 759.8,
      "end": 761.8,
      "text": "빌리 3에 3만 4, 3에 5"
    },
    {
      "start": 761.8,
      "end": 764.0,
      "text": "그다음에 1, 3-5"
    },
    {
      "start": 764.0,
      "end": 764.8,
      "text": "이렇게 되겠죠"
    },
    {
      "start": 764.8,
      "end": 767.8,
      "text": "이런 made 7만 달라까지는 올라가겠네"
    },
    {
      "start": 767.8,
      "end": 771.8,
      "text": "6만 종관에서 7만까지 가겠죠"
    },
    {
      "start": 771.8,
      "end": 795.42,
      "text": "아무튼 뭐"
    },
    {
      "start": 795.42,
      "end": 796.54,
      "text": "그럴 것 같벌"
    },
    {
      "start": 796.54,
      "end": 799.42,
      "text": "그렇게 컨깅 하면 되을 것에 올라가네요"
    },
    {
      "start": 799.42,
      "end": 800.42,
      "text": "근데 이제 마지막을"
    },
    {
      "start": 800.42,
      "end": 804.42,
      "text": "vẫn까지 1에 3에 1에 3에 3에 5라고 나오게 보다는"
    },
    {
      "start": 804.42,
      "end": 806.42,
      "text": "기존 관점 댓글을 그냥"
    },
    {
      "start": 806.42,
      "end": 807.42,
      "text": "ABC feelings깃고"
    },
    {
      "start": 809.42,
      "end": 810.42,
      "text": "잠깐만요"
    },
    {
      "start": 810.42,
      "end": 824.49,
      "text": "기존 관전자대로 ABC 하락했고 ABC 반등화에서 비나고 ABC로 내려간다라고 보는 게 맞는 것 같고"
    },
    {
      "start": 824.49,
      "end": 828.99,
      "text": "저는 아까 퍼지선 여기서 잡았기 때문에 손절라인으로 잡을 거예요"
    },
    {
      "start": 828.99,
      "end": 834.45,
      "text": "그래서 지난 번 손절라인으로 잡으라는 상단 트렌드 라인하고 조금 더 타이트하죠"
    },
    {
      "start": 834.45,
      "end": 837.05,
      "text": "그래서 손절라인은 타이트하면 할수록 좋은 거니까"
    },
    {
      "start": 837.05,
      "end": 841.89,
      "text": "손절리 짧으면 짧아서 좋은 거니까 그렇게 가져갈 거고 아무튼"
    },
    {
      "start": 844.26,
      "end": 848.02,
      "text": "지금 사실 신더 있게 샷트분석을 한 게 아니고"
    },
    {
      "start": 848.02,
      "end": 852.58,
      "text": "제주도 가기 전에 분석했던 거 기반으로 그냥"
    },
    {
      "start": 853.06,
      "end": 857.34,
      "text": "흘러가는 거대로 타이트를 맞춘 거라서 분석이"
    },
    {
      "start": 859.9,
      "end": 863.74,
      "text": "오랜 공을 드린 건 아니지만 그래도 그냥 그래 보여요"
    },
    {
      "start": 863.74,
      "end": 867.02,
      "text": "지난 분석에서 했던 거랑 그게 차이가 없어 보입니다"
    },
    {
      "start": 867.02,
      "end": 885.02,
      "text": "슈프가 자랑해달라고요? 슈가 자랑할 게 없어요"
    },
    {
      "start": 885.98,
      "end": 887.02,
      "text": "슈가 자랑"
    },
    {
      "start": 887.02,
      "end": 889.02,
      "text": "그게 슈서 뷰가 좋습니다"
    },
    {
      "start": 889.74,
      "end": 892.14,
      "text": "여기 슈서가 여기가 뷰가 좋네요"
    },
    {
      "start": 892.14,
      "end": 893.26,
      "text": "제주실 쪽인데"
    },
    {
      "start": 893.26,
      "end": 910.14,
      "text": "바다가 팔아코비는 한 번만 예쁘고"
    },
    {
      "start": 910.7,
      "end": 913.18,
      "text": "별거 없습니다. 이 슈서 자랑 이거"
    },
    {
      "start": 913.18,
      "end": 914.54,
      "text": "바 제주도 자랑"
    },
    {
      "start": 914.54,
      "end": 928.5,
      "text": "그냥 공화하게 쉬고 있습니다"
    },
    {
      "start": 928.5,
      "end": 929.46,
      "text": "공화하게"
    },
    {
      "start": 929.46,
      "end": 939.92,
      "text": "여기가 침실"
    },
    {
      "start": 947.44,
      "end": 949.28,
      "text": "이는 화장실"
    },
    {
      "start": 950.4,
      "end": 951.92,
      "text": "끝집니다. 뭐 없어요"
    },
    {
      "start": 951.92,
      "end": 952.96,
      "text": "보여드릴게요 없네"
    },
    {
      "start": 964.11,
      "end": 965.87,
      "text": "아니 혼자 왔어요"
    },
    {
      "start": 965.87,
      "end": 986.35,
      "text": "무도에요. 무도는"
    },
    {
      "start": 987.71,
      "end": 997.02,
      "text": "어릴 때 많이 가 가지고 이제 안 갈 것 같아요"
    },
    {
      "start": 997.02,
      "end": 998.46,
      "text": "오늘 머릿살 좋다고?"
    },
    {
      "start": 998.46,
      "end": 1000.46,
      "text": "못 왔을 거 있는데"
    },
    {
      "start": 1008.03,
      "end": 1011.23,
      "text": "구미워 안녕 오랜만이네 구미워"
    },
    {
      "start": 1011.23,
      "end": 1017.3,
      "text": "얼굴 다 띄친다고?"
    },
    {
      "start": 1017.3,
      "end": 1019.3,
      "text": "나 아직 센스도 안 했는데"
    },
    {
      "start": 1021.1,
      "end": 1022.06,
      "text": "화질 왜 이러니?"
    },
    {
      "start": 1022.06,
      "end": 1028.96,
      "text": "핸드폰으로 방송하고 있는 거예요"
    },
    {
      "start": 1028.96,
      "end": 1033.1,
      "text": "오메기 또 맛있죠"
    },
    {
      "start": 1033.1,
      "end": 1036.14,
      "text": "아무튼는 마이도 진짜 잡다며 너무 길었고"
    },
    {
      "start": 1036.14,
      "end": 1037.66,
      "text": "뭐"
    },
    {
      "start": 1038.38,
      "end": 1041.42,
      "text": "여기서 계속 칼하게 된다고 하면"
    },
    {
      "start": 1041.42,
      "end": 1043.66,
      "text": "그러면 이제"
    },
    {
      "start": 1047.28,
      "end": 1050.64,
      "text": "하나 간다고 하면 진짜 분석 그대로 가는 거고"
    },
    {
      "start": 1050.64,
      "end": 1052.0,
      "text": "여기서 상승하면은"
    },
    {
      "start": 1054.4,
      "end": 1056.08,
      "text": "머리도 복잡해지겠네요"
    },
    {
      "start": 1056.08,
      "end": 1065.7,
      "text": "올라가면 어떻게 할지 모르겠네"
    },
    {
      "start": 1065.7,
      "end": 1068.98,
      "text": "지금 여기 보면 시간 봉"
    },
    {
      "start": 1068.98,
      "end": 1071.3,
      "text": "핫다이번스가 있죠 여기 보시면"
    },
    {
      "start": 1071.3,
      "end": 1073.06,
      "text": "제가 보고 있을 때는"
    },
    {
      "start": 1073.06,
      "end": 1073.7,
      "text": "에이파동"
    },
    {
      "start": 1073.7,
      "end": 1075.54,
      "text": "그다음에 ABCD 삼각수 이름을 다음에"
    },
    {
      "start": 1075.54,
      "end": 1078.34,
      "text": "원 투슬이 포파이브 해가지고"
    },
    {
      "start": 1078.34,
      "end": 1080.74,
      "text": "ABC가 딱 정확히 완성이 된 것 같아요"
    },
    {
      "start": 1080.74,
      "end": 1083.78,
      "text": "그래서 아마 여기서부터 떨어져 줘 줘야"
    },
    {
      "start": 1083.78,
      "end": 1085.7,
      "text": "맞는 거고 한 번 놀라가면"
    },
    {
      "start": 1085.7,
      "end": 1087.94,
      "text": "그러면 이제 저는 여기서 엑지가 나가겠죠"
    },
    {
      "start": 1087.94,
      "end": 1088.98,
      "text": "이렇게 감망을 하겠죠"
    },
    {
      "start": 1088.98,
      "end": 1090.82,
      "text": "감망을 하고"
    },
    {
      "start": 1090.82,
      "end": 1093.7,
      "text": "아마 좀 머리를 쌓아야지 않을까"
    },
    {
      "start": 1093.7,
      "end": 1094.98,
      "text": "그러니까"
    },
    {
      "start": 1094.98,
      "end": 1096.18,
      "text": "그"
    },
    {
      "start": 1096.18,
      "end": 1098.58,
      "text": "전 이제 엑지 나간 맨 맨 안 할 거에요 당연히"
    },
    {
      "start": 1098.58,
      "end": 1100.66,
      "text": "근데 이제 만약에 제가 서울에 있었고"
    },
    {
      "start": 1100.66,
      "end": 1102.74,
      "text": "차트를 보고 있으더라고요 하면"
    },
    {
      "start": 1102.74,
      "end": 1104.34,
      "text": "아마 이 위로 올라가면 또"
    },
    {
      "start": 1104.34,
      "end": 1106.34,
      "text": "골머리 아파지지 않을까"
    },
    {
      "start": 1106.34,
      "end": 1109.5,
      "text": "생각이 듭니다"
    },
    {
      "start": 1109.5,
      "end": 1111.1,
      "text": "옷장에 여자 분이 어디 있어"
    },
    {
      "start": 1111.1,
      "end": 1113.5,
      "text": "없을 거예요 옷장에"
    },
    {
      "start": 1113.5,
      "end": 1118.16,
      "text": "옷장에 여자 없으면 혼자 있어요 혼자"
    },
    {
      "start": 1118.16,
      "end": 1120.48,
      "text": "아니 왜 하랑만 고집하냐고 물어보신"
    },
    {
      "start": 1120.48,
      "end": 1124.94,
      "text": "하락을 고집하는 게 아니고"
    },
    {
      "start": 1124.94,
      "end": 1126.22,
      "text": "하락을 고집하는 게 아니고"
    },
    {
      "start": 1126.22,
      "end": 1128.62,
      "text": "하락 할 거라고 생각을 하니까 그런 거에요"
    },
    {
      "start": 1128.62,
      "end": 1131.02,
      "text": "제가 무슨 비트코인 만에 쓰면 좋겠다 라고"
    },
    {
      "start": 1131.02,
      "end": 1132.86,
      "text": "그 생각하는 그런 분자가 아니에요"
    },
    {
      "start": 1132.86,
      "end": 1133.74,
      "text": "저는"
    },
    {
      "start": 1133.74,
      "end": 1140.69,
      "text": "장기적으로 비트코인 무조건"
    },
    {
      "start": 1140.69,
      "end": 1144.61,
      "text": "저는 뭐 한 3억에서 5억은 갈 거라고 생각하는 사람이에요"
    },
    {
      "start": 1144.61,
      "end": 1146.21,
      "text": "그게 지금 이제"
    },
    {
      "start": 1146.21,
      "end": 1148.29,
      "text": "일권 영이 있는데 여기 있는데"
    },
    {
      "start": 1148.29,
      "end": 1150.69,
      "text": "저는 비트코인은 여기 막 한"
    },
    {
      "start": 1150.69,
      "end": 1153.57,
      "text": "20만 달러 30만 달러 갈 수 있으라고 생각하는 사람이에요"
    },
    {
      "start": 1153.57,
      "end": 1156.29,
      "text": "향후 5년 10년 뒤에 전 장기 엄청나게"
    },
    {
      "start": 1156.29,
      "end": 1158.37,
      "text": "긍정적으로 비트코인을 바라보는 사람이에요"
    },
    {
      "start": 1158.37,
      "end": 1161.09,
      "text": "근데 그건 이제 5년 뒤 10년 뒤의 이야기지"
    },
    {
      "start": 1161.09,
      "end": 1164.29,
      "text": "당장은 하락할 수도 있잖아 당장은"
    },
    {
      "start": 1164.29,
      "end": 1166.93,
      "text": "저는 제가 하락한다고"
    },
    {
      "start": 1166.93,
      "end": 1169.17,
      "text": "제가 뭐 듣고는 것도 아니고"
    },
    {
      "start": 1169.17,
      "end": 1170.69,
      "text": "상승장 오면 나도 좋죠"
    },
    {
      "start": 1170.69,
      "end": 1172.05,
      "text": "알트코인 매우해서 수익 보고"
    },
    {
      "start": 1172.05,
      "end": 1175.01,
      "text": "근데 그냥 개관적으로 분석했을 때"
    },
    {
      "start": 1175.01,
      "end": 1177.81,
      "text": "하방에도 무게가 실리니까"
    },
    {
      "start": 1177.81,
      "end": 1180.05,
      "text": "하방 이야기를 하는 겁니다"
    },
    {
      "start": 1180.05,
      "end": 1180.45,
      "text": "왜요?"
    },
    {
      "start": 1180.45,
      "end": 1181.57,
      "text": "어휴 야 하지 마세요"
    },
    {
      "start": 1181.57,
      "end": 1185.97,
      "text": "제가 무슨 하락 무서도 아니고"
    },
    {
      "start": 1185.97,
      "end": 1189.01,
      "text": "그리고 그 지난 방송 이후에"
    },
    {
      "start": 1189.01,
      "end": 1191.49,
      "text": "사실 이제 연락을 많이 받았는데"
    },
    {
      "start": 1191.49,
      "end": 1194.61,
      "text": "그 전달을 여러분들한테 못 들은 이야기가 있어요"
    },
    {
      "start": 1194.61,
      "end": 1199.54,
      "text": "그 지난 방송에서 주요하게 이야기했던 게 뭐였냐면"
    },
    {
      "start": 1199.54,
      "end": 1202.5,
      "text": "이 구간 여기가 과연 상관 수염이니까 아닐까"
    },
    {
      "start": 1202.5,
      "end": 1205.54,
      "text": "지금 방은실을 보면 볼륨이 들어기 때문에"
    },
    {
      "start": 1205.54,
      "end": 1209.22,
      "text": "생각수랄이 아닌 것처럼 보이고"
    },
    {
      "start": 1209.22,
      "end": 1211.62,
      "text": "그다음에 그 뭐지"
    },
    {
      "start": 1211.62,
      "end": 1213.78,
      "text": "브레이븐 유코인 를 기린 데스를 보면"
    },
    {
      "start": 1213.78,
      "end": 1216.18,
      "text": "볼륨이 주력기 때문에 생각수랄 것처럼 보이고"
    },
    {
      "start": 1216.18,
      "end": 1219.46,
      "text": "뭐 그런 차이가 있는데"
    },
    {
      "start": 1219.46,
      "end": 1222.5,
      "text": "전체 거래소에 처음 거래량을 합쳐서"
    },
    {
      "start": 1222.5,
      "end": 1228.02,
      "text": "쓸 때 그 합쳐 보는 방법이 있다고 하더라고요"
    },
    {
      "start": 1228.02,
      "end": 1231.3,
      "text": "그래서 그분들 이제 시청자들이 합쳐 봤는데"
    },
    {
      "start": 1231.3,
      "end": 1233.38,
      "text": "여기가 볼륨이 증강에 왔다고 하더라고요"
    },
    {
      "start": 1233.38,
      "end": 1234.98,
      "text": "그런데 그런 그 관점이면"
    },
    {
      "start": 1234.98,
      "end": 1237.38,
      "text": "상당히 한 번도 남아 있거든요"
    },
    {
      "start": 1237.38,
      "end": 1238.74,
      "text": "그 관점이 맞다라고 하는"
    },
    {
      "start": 1238.74,
      "end": 1241.38,
      "text": "왜냐하면 여기가 그러면 상관수름이 아니고"
    },
    {
      "start": 1241.38,
      "end": 1243.06,
      "text": "마지막으로 오후일이 됐고"
    },
    {
      "start": 1243.06,
      "end": 1243.78,
      "text": "오후일이 되고"
    },
    {
      "start": 1243.78,
      "end": 1244.98,
      "text": "오후일 3위 되고"
    },
    {
      "start": 1244.98,
      "end": 1247.54,
      "text": "오후에 4가 이렇게 나오고"
    },
    {
      "start": 1247.54,
      "end": 1249.22,
      "text": "오후가 올라가는 거"
    },
    {
      "start": 1249.22,
      "end": 1252.19,
      "text": "일 거예요"
    },
    {
      "start": 1252.19,
      "end": 1254.75,
      "text": "그럴 수 있죠"
    },
    {
      "start": 1254.75,
      "end": 1258.43,
      "text": "그래서 그것 때문에 살짝 국정이긴 합니다"
    },
    {
      "start": 1258.43,
      "end": 1261.15,
      "text": "그러면 여기가"
    },
    {
      "start": 1261.15,
      "end": 1264.56,
      "text": "파том 컴퓨이"
    },
    {
      "start": 1264.56,
      "end": 1267.04,
      "text": "어, ABC에 일 계시는 거죠"
    },
    {
      "start": 1267.04,
      "end": 1269.86,
      "text": "ABC1 2 3 4 5"
    },
    {
      "start": 1269.86,
      "end": 1271.68,
      "text": "그리고 저쪽은 여기으로 잡아야겠죠"
    },
    {
      "start": 1271.68,
      "end": 1274.4,
      "text": "그러면 이제 1 편하고 2 편하고 이제"
    },
    {
      "start": 1274.4,
      "end": 1275.52,
      "text": "아까 얘기했던 것처럼"
    },
    {
      "start": 1275.52,
      "end": 1279.44,
      "text": "3의 1, 2, 3, 1, 2, 3, 4 5"
    },
    {
      "start": 1279.44,
      "end": 1283.2,
      "text": "그럼 그다음에 3의 4 5"
    },
    {
      "start": 1283.2,
      "end": 1287.84,
      "text": "이러면 이제 3 다시 5 다시 3의 완성되는 거고"
    },
    {
      "start": 1287.84,
      "end": 1289.04,
      "text": "여기서"
    },
    {
      "start": 1289.04,
      "end": 1290.88,
      "text": "여기서 5 다시 3의 완성되는 거고"
    },
    {
      "start": 1290.88,
      "end": 1293.28,
      "text": "5 다시 4 간하고 5 다시 5가 이렇게 와가지고"
    },
    {
      "start": 1293.28,
      "end": 1294.88,
      "text": "결국에는 한 뭐"
    },
    {
      "start": 1294.88,
      "end": 1297.6,
      "text": "그만 달러까지 가겠죠"
    },
    {
      "start": 1297.6,
      "end": 1300.48,
      "text": "그래서 지금 여기를 넘기는 게 안 넘기는"
    },
    {
      "start": 1300.48,
      "end": 1311.44,
      "text": "약간 중요한 것 같아요"
    },
    {
      "start": 1311.44,
      "end": 1314.16,
      "text": "그래서 여기가 마지막 까문을 범 되지 않을까 싶어요"
    },
    {
      "start": 1314.16,
      "end": 1316.16,
      "text": "여기 5만 3천"
    },
    {
      "start": 1316.16,
      "end": 1317.2,
      "text": "여기 고점이"
    },
    {
      "start": 1317.2,
      "end": 1322.48,
      "text": "여기를 마지막 까문을 범 될 것 같아요"
    },
    {
      "start": 1322.48,
      "end": 1324.8,
      "text": "그리고 시작 그"
    },
    {
      "start": 1324.8,
      "end": 1326.96,
      "text": "예상들을 만약에 떨어진다라고 하면"
    },
    {
      "start": 1326.96,
      "end": 1329.12,
      "text": "그러면 다시 반등이 오더라도"
    },
    {
      "start": 1329.12,
      "end": 1331.6,
      "text": "이번 등은 결국은 ABC 반등이었던 거고"
    },
    {
      "start": 1331.6,
      "end": 1333.52,
      "text": "여기 하라고 오빠가 있으니까"
    },
    {
      "start": 1333.52,
      "end": 1336.72,
      "text": "5, ABC3, 1, 2, 3 4 5"
    },
    {
      "start": 1336.72,
      "end": 1338.32,
      "text": "이만 달라에서만 8천 달라"
    },
    {
      "start": 1338.32,
      "end": 1339.68,
      "text": "여기 맹을 때 있죠"
    },
    {
      "start": 1339.68,
      "end": 1343.04,
      "text": "이라인까지 떨어지는 장기관점이 될 거예요"
    },
    {
      "start": 1343.04,
      "end": 1344.48,
      "text": "그래서"
    },
    {
      "start": 1344.48,
      "end": 1347.92,
      "text": "이때 똑같이 5만 6천을 가더라도"
    },
    {
      "start": 1347.92,
      "end": 1349.12,
      "text": "지금 가는이야"
    },
    {
      "start": 1349.12,
      "end": 1351.6,
      "text": "떨어졌다 가는 야가 천지차입니다"
    },
    {
      "start": 1351.6,
      "end": 1354.48,
      "text": "지금 가면 여기 전국점 넘겨서"
    },
    {
      "start": 1354.48,
      "end": 1356.56,
      "text": "8만 9만까지 가겠다는 거고"
    },
    {
      "start": 1356.56,
      "end": 1359.68,
      "text": "떨어졌다가 3만 2만 때가 떨어졌다가 다시 와서"
    },
    {
      "start": 1359.68,
      "end": 1361.12,
      "text": "여기 5만 6천을 가게 되면"
    },
    {
      "start": 1361.12,
      "end": 1363.6,
      "text": "그러면 다시 떨어지겠다는 부분이 있거든요"
    },
    {
      "start": 1363.6,
      "end": 1366.48,
      "text": "초밥 분들은 이걸 잘 구분해서 보셔야 돼요"
    },
    {
      "start": 1366.48,
      "end": 1368.56,
      "text": "똑같이 여기를 이 가격 가더라도"
    },
    {
      "start": 1368.56,
      "end": 1370.0,
      "text": "지금 가는 것과"
    },
    {
      "start": 1370.0,
      "end": 1372.56,
      "text": "조정을 받고 올라가는 것은"
    },
    {
      "start": 1372.56,
      "end": 1374.48,
      "text": "완전한 차이가 있다"
    },
    {
      "start": 1374.48,
      "end": 1376.4,
      "text": "이거를 초밥은들은 잘"
    },
    {
      "start": 1376.4,
      "end": 1378.56,
      "text": "이해를 하셔야 될 것 같아요"
    },
    {
      "start": 1378.56,
      "end": 1380.88,
      "text": "아무튼"
    },
    {
      "start": 1380.88,
      "end": 1382.8,
      "text": "오늘 방송은 여기까지 하겠습니다"
    },
    {
      "start": 1382.8,
      "end": 1384.8,
      "text": "다시는 아마"
    },
    {
      "start": 1384.8,
      "end": 1386.64,
      "text": "11월 중순까지 아마 다시는"
    },
    {
      "start": 1386.64,
      "end": 1389.04,
      "text": "방송이 없을 것 같아요"
    },
    {
      "start": 1389.04,
      "end": 1390.8,
      "text": "오늘은 제가 제지도 왔는데"
    },
    {
      "start": 1390.8,
      "end": 1394.64,
      "text": "앞으로 들때면 너무 열바다 가지고"
    },
    {
      "start": 1394.64,
      "end": 1398.08,
      "text": "그 저기 뭐야"
    },
    {
      "start": 1398.08,
      "end": 1400.08,
      "text": "일부러 포지션을 잡고"
    },
    {
      "start": 1400.08,
      "end": 1401.6,
      "text": "맹을 하고 다음에"
    },
    {
      "start": 1401.6,
      "end": 1404.88,
      "text": "방송도 이제 하려고 했는데"
    },
    {
      "start": 1404.88,
      "end": 1406.96,
      "text": "노트북으로 어떻게 방송하는지 모르겠더라고요"
    },
    {
      "start": 1406.96,
      "end": 1408.24,
      "text": "그래서 지금 핸드폰은"
    },
    {
      "start": 1408.24,
      "end": 1410.16,
      "text": "조작이 쉽게 핸드폰으로 지금 이렇게"
    },
    {
      "start": 1410.16,
      "end": 1413.36,
      "text": "켜서 화질이 아주 안 좋습니다"
    },
    {
      "start": 1413.36,
      "end": 1416.16,
      "text": "마이크로 핸드폰 마이크를 안 좋을 거고"
    },
    {
      "start": 1416.16,
      "end": 1417.92,
      "text": "아무튼"
    },
    {
      "start": 1417.92,
      "end": 1420.24,
      "text": "좀 많이 여러 칸 상황에서 예정에"
    },
    {
      "start": 1420.24,
      "end": 1421.36,
      "text": "어떤 방송을 했는데"
    },
    {
      "start": 1421.36,
      "end": 1422.88,
      "text": "시청해주셔서 고맙고"
    },
    {
      "start": 1422.88,
      "end": 1425.12,
      "text": "뭐 지금 10월달 연유가 많잖아요"
    },
    {
      "start": 1425.12,
      "end": 1427.52,
      "text": "지금도 연유 기간이 꺼내서"
    },
    {
      "start": 1427.52,
      "end": 1429.04,
      "text": "좋은 연유 보내주고"
    },
    {
      "start": 1429.04,
      "end": 1430.64,
      "text": "오늘 연유 만내요"
    },
    {
      "start": 1430.64,
      "end": 1432.16,
      "text": "좋은 연유 보내주고"
    },
    {
      "start": 1432.16,
      "end": 1433.12,
      "text": "맵을 잘 하시고"
    },
    {
      "start": 1433.12,
      "end": 1438.4,
      "text": "수행 많이 보시길 바라겠습니다"
    },
    {
      "start": 1438.4,
      "end": 1440.8,
      "text": "아니 다시 방송 기가 앞으로 달라고"
    },
    {
      "start": 1440.8,
      "end": 1442.16,
      "text": "아니 이러지들 마요"
    },
    {
      "start": 1442.16,
      "end": 1444.64,
      "text": "좀 휴식 좀 하자"
    },
    {
      "start": 1444.64,
      "end": 1448.4,
      "text": "진짜로 너무 세스 받았어 어제"
    },
    {
      "start": 1448.4,
      "end": 1450.56,
      "text": "아니 마쳤는데"
    },
    {
      "start": 1450.56,
      "end": 1452.32,
      "text": "그러니까 틀려서 응 먹는 건 다"
    },
    {
      "start": 1452.32,
      "end": 1453.04,
      "text": "아니 그 나지"
    },
    {
      "start": 1453.04,
      "end": 1455.6,
      "text": "틀리고 응 먹는 건 그럴 수 있어"
    },
    {
      "start": 1455.6,
      "end": 1457.12,
      "text": "틀려서 비난 받는 건 그래"
    },
    {
      "start": 1457.12,
      "end": 1459.68,
      "text": "내가 잘못했으니까 내 분석이 틀렸으니까"
    },
    {
      "start": 1459.68,
      "end": 1461.44,
      "text": "하는데 마쳤는데 틀렸다고"
    },
    {
      "start": 1461.44,
      "end": 1462.96,
      "text": "요칸이니까 너무 억울한 거야"
    },
    {
      "start": 1462.96,
      "end": 1470.58,
      "text": "그래가지고 방송을 켰어요"
    },
    {
      "start": 1470.58,
      "end": 1472.58,
      "text": "그리고 뭐 언제까지"
    },
    {
      "start": 1472.58,
      "end": 1474.9,
      "text": "얼마 언제까지 이렇게 계속 계속"
    },
    {
      "start": 1474.9,
      "end": 1477.14,
      "text": "그"
    },
    {
      "start": 1477.54,
      "end": 1481.38,
      "text": "해야 악플러들이 안 나올지 모르겠어요"
    },
    {
      "start": 1481.38,
      "end": 1484.82,
      "text": "대회도 다섯 번 나 가서 20등 4등 1등 1등"
    },
    {
      "start": 1484.82,
      "end": 1487.54,
      "text": "1등 하고 수익도 매번 인증하고"
    },
    {
      "start": 1487.54,
      "end": 1489.46,
      "text": "하는데도 아직까지도"
    },
    {
      "start": 1489.46,
      "end": 1491.62,
      "text": "명나는 사격 군인 나라는"
    },
    {
      "start": 1491.62,
      "end": 1494.02,
      "text": "그런 말을 하는 사람이"
    },
    {
      "start": 1494.02,
      "end": 1496.02,
      "text": "2끝 있더라고요 물론 별로 없지만"
    },
    {
      "start": 1496.02,
      "end": 1498.18,
      "text": "면 명중에 한 명 될까 말까지만"
    },
    {
      "start": 1498.18,
      "end": 1501.38,
      "text": "어쨌든 그런 걸 볼 때마다"
    },
    {
      "start": 1501.38,
      "end": 1502.5,
      "text": "좀 속이 상하네요"
    },
    {
      "start": 1502.5,
      "end": 1505.54,
      "text": "아무튼 다들 연유 잘 보내주고 계속"
    },
    {
      "start": 1505.54,
      "end": 1507.94,
      "text": "심 제가 뭐 주제를 주절이"
    },
    {
      "start": 1507.94,
      "end": 1510.34,
      "text": "열 받아서 제주도 와서 한탄을 하는데"
    },
    {
      "start": 1510.34,
      "end": 1513.3,
      "text": "아무튼 방송을까지 하겠습니다"
    },
    {
      "start": 1513.3,
      "end": 1517.46,
      "text": "어떻게 끊은거지 이거"
    },
    {
      "start": 1517.46,
      "end": 1518.58,
      "text": "그 저기 뭐야"
    },
    {
      "start": 1518.58,
      "end": 1521.94,
      "text": "좋아요 눌러주시면 고맙겠습니다"
    },
    {
      "start": 1521.94,
      "end": 1524.1,
      "text": "한 3천 명 그래도 보셨네"
    },
    {
      "start": 1524.1,
      "end": 1527.54,
      "text": "근데 저와 이거 533개에 애는 해요"
    },
    {
      "start": 1527.54,
      "end": 1531.3,
      "text": "좋아요 좀 눌러 주세요 여러분들"
    },
    {
      "start": 1531.3,
      "end": 1534.02,
      "text": "네 여러분들도 그 저기"
    },
    {
      "start": 1534.02,
      "end": 1535.3,
      "text": "잘 보낼 수고"
    },
    {
      "start": 1535.3,
      "end": 1538.45,
      "text": "수가 잘 보낼 수고"
    },
    {
      "start": 1538.45,
      "end": 1547.09,
      "text": "좋아요 눌러주시면도 고맙습니다 수진 많이 보세요"
    },
    {
      "start": 1547.09,
      "end": 1550.13,
      "text": "네 남은 시간 잘 보내겠습니다 고맙습니다"
    },
    {
      "start": 1550.13,
      "end": 1555.42,
      "text": "이렇게 끊은건가?"
    },
    {
      "start": 1555.42,
      "end": 1556.62,
      "text": "어 깨끗 끊은건에"
    },
    {
      "start": 1556.62,
      "end": 1559.1,
      "text": "끊은 버튼을 찾았습니다 이제 진짜 끊겠습니다"
    },
    {
      "start": 1559.1,
      "end": 1561.66,
      "text": "좋은 5시간 되시길 바라겠습니다"
    }
  ]
}