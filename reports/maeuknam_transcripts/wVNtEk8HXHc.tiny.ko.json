    {
      "start": 540.02,
      "end": 541.38,
      "text": "꼭 정리했었고"
    },
    {
      "start": 542.1,
      "end": 544.34,
      "text": "앱이 올라오는데 또 빠지고 있어가지고"
    },
    {
      "start": 544.34,
      "end": 546.5,
      "text": "지금 이제 올라갈지 않리미로"
    },
    {
      "start": 546.5,
      "end": 547.7,
      "text": "앱이 지금 나와서"
    },
    {
      "start": 547.7,
      "end": 550.18,
      "text": "이렇게 앱이 씨로 빠질지는 모른 상태지만"
    },
    {
      "start": 550.42,
      "end": 551.46,
      "text": "기준점 한 한 여기를 이렇게"
    },
    {
      "start": 551.46,
      "end": 553.06,
      "text": "여기를 깨면"
    },
    {
      "start": 553.06,
      "end": 554.82,
      "text": "이 달반에서 반등"
    },
    {
      "start": 554.82,
      "end": 557.46,
      "text": "이 나온 이 반대추세가 여기서 끝났다는 거니까"
    },
    {
      "start": 557.46,
      "end": 559.86,
      "text": "새로운 하락 외이브가 시작되는 거거든요."
    },
    {
      "start": 559.86,
      "end": 562.42,
      "text": "그러면 이걸 넘겨서"
    },
    {
      "start": 562.42,
      "end": 563.78,
      "text": "쭉 빠질 후 확률 높죠."
    },
    {
      "start": 563.78,
      "end": 565.38,
      "text": "그 못 말이냐면"
    },
    {
      "start": 565.38,
      "end": 567.46,
      "text": "이렇게 ABC의 내려갈 확률 높다는 거야."
    },
    {
      "start": 567.46,
      "end": 569.54,
      "text": "이게 깨시면"
    },
    {
      "start": 569.54,
      "end": 571.62,
      "text": "여기서 끝나고 이렇게 올라온다고 보다는"
    },
    {
      "start": 571.62,
      "end": 573.06,
      "text": "이렇게 쭉 빠질 후 높다는"
    },
    {
      "start": 573.06,
      "end": 575.62,
      "text": "물론 중간에 반등 반등은 올 수 있겠지만"
    },
    {
      "start": 575.62,
      "end": 576.82,
      "text": "내려갈 확률 높아요."
    },
    {
      "start": 576.82,
      "end": 578.1,
      "text": "한 20점까지만"
    },
    {
      "start": 578.1,
      "end": 580.98,
      "text": "여기가 26,800이거든요."
    },
    {
      "start": 580.98,
      "end": 584.34,
      "text": "여기까지는 여기까지가 깨지면 여기까지는 시간이 걸리겠지"
    },
    {
      "start": 584.34,
      "end": 587.54,
      "text": "내 롤 확률이 높다라고 생각하시면 되는 거고"
    },
    {
      "start": 587.54,
      "end": 589.94,
      "text": "근데 단기 보면 여기 한 시간"
    },
    {
      "start": 589.94,
      "end": 591.14,
      "text": "봉상다가 또 있어요."
    },
    {
      "start": 591.14,
      "end": 593.14,
      "text": "이렇게 가격이 꽉 빠졌는데"
    },
    {
      "start": 593.14,
      "end": 594.58,
      "text": "알았어요 올라갔어요."
    },
    {
      "start": 594.58,
      "end": 596.42,
      "text": "그리고 나서 반등이 오긴"
    },
    {
      "start": 596.42,
      "end": 599.7,
      "text": "왔는데 살짝 왔는데 또 비비고 있죠."
    },
    {
      "start": 599.7,
      "end": 601.14,
      "text": "보통은"
    },
    {
      "start": 601.14,
      "end": 602.5,
      "text": "위자로 올라온 경우가 많거든요."
    },
    {
      "start": 602.5,
      "end": 603.38,
      "text": "달걀스 걸리면"
    },
    {
      "start": 603.38,
      "end": 605.54,
      "text": "근데 지금 그래서 이렇게 맨대 싸움스내라고"
    },
    {
      "start": 605.54,
      "end": 607.7,
      "text": "있어서 모르겠어요."
    },
    {
      "start": 607.7,
      "end": 609.78,
      "text": "여기서 만약에 반등 안 나오면"
    },
    {
      "start": 609.78,
      "end": 611.7,
      "text": "흐를 감승 높아요."
    },
    {
      "start": 611.7,
      "end": 612.58,
      "text": "이렇게 하면"
    },
    {
      "start": 612.58,
      "end": 614.66,
      "text": "달걀스가 나한테 불겁게 내려가는 거니까"
    },
    {
      "start": 614.66,
      "end": 617.3,
      "text": "흐를 거예요 아마 가격에 계속"
    },
    {
      "start": 617.3,
      "end": 619.06,
      "text": "여기가 좀 중요한 점 지점이"
    },
    {
      "start": 619.06,
      "end": 620.98,
      "text": "가 생각하시면 될 것 같고"
    },
    {
      "start": 620.98,
      "end": 622.42,
      "text": "이더라도 마찬가지에요."
    },
    {
      "start": 622.42,
      "end": 623.86,
      "text": "이더라도 여기 깨지면"
    },
    {
      "start": 623.86,
      "end": 625.7,
      "text": "빛나는가 비슷하게 흘보고"
    },
    {
      "start": 625.7,
      "end": 626.82,
      "text": "여기 지켜주면"
    },
    {
      "start": 626.82,
      "end": 630.02,
      "text": "상반을 다시 한번 생각을 해볼 수 있습니다."
    },
    {
      "start": 630.02,
      "end": 631.7,
      "text": "그다음에 방송 제 6개에만에"
    },
    {
      "start": 631.7,
      "end": 632.8,
      "text": "복귀했을 때 춥"
    },
    {
      "start": 632.8,
      "end": 634.82,
      "text": "봤던 게 빛이 봤었고"
    },
    {
      "start": 634.82,
      "end": 636.82,
      "text": "삼성현자 코스피"
    },
    {
      "start": 636.82,
      "end": 640.02,
      "text": "하늘 테슬라 이렇게 발켓 봤었죠."
    },
    {
      "start": 640.02,
      "end": 642.1,
      "text": "그다음에 시청자 질문으로"
    },
    {
      "start": 642.1,
      "end": 643.7,
      "text": "쿠커 봤었는데 그 그대로"
    },
    {
      "start": 643.7,
      "end": 646.02,
      "text": "리뷰하고 방송 끌게요."
    },
    {
      "start": 646.02,
      "end": 646.9,
      "text": "그때 방송에 했을 때"
    },
    {
      "start": 646.9,
      "end": 648.1,
      "text": "하늘 이 정도였는데"
    },
    {
      "start": 648.1,
      "end": 649.46,
      "text": "여기 넘겨서 여기"
    },
    {
      "start": 649.46,
      "end": 651.86,
      "text": "참 380원 티필을 안 올라갈 것더라고요."
    },
    {
      "start": 651.86,
      "end": 654.9,
      "text": "말씀드렸네 쭉 잘 오르고 있어요."
    },
    {
      "start": 654.9,
      "end": 662.74,
      "text": "다음에 코스피 볼게요."
    },
    {
      "start": 662.74,
      "end": 664.42,
      "text": "코스피 지나면 방송 결스트에"
    },
    {
      "start": 664.42,
      "end": 666.02,
      "text": "이 지점이었고"
    },
    {
      "start": 666.02,
      "end": 667.86,
      "text": "빠질 것 같다라고 했는지 빠졌고"
    },
    {
      "start": 667.86,
      "end": 669.14,
      "text": "앞으로 덧받을 것 같아요."
    },
    {
      "start": 669.14,
      "end": 670.98,
      "text": "앱이치가 맞는 것 같아요."
    },
    {
      "start": 670.98,
      "end": 672.82,
      "text": "원투원투원투안이었던 것 같죠."
    },
    {
      "start": 672.82,
      "end": 673.78,
      "text": "역시내서 막"
    },
    {
      "start": 673.78,
      "end": 676.02,
      "text": "꽤 빠질 것이고 시간이 걸리겠지만"
    },
    {
      "start": 676.02,
      "end": 677.7,
      "text": "이런 게 아직는"
    },
    {
      "start": 677.7,
      "end": 678.74,
      "text": "내려올 건"
    },
    {
      "start": 678.74,
      "end": 679.94,
      "text": "거라고 생각을 해요 쭉"
    },
    {
      "start": 679.94,
      "end": 682.82,
      "text": "내사노대를 빠지고 있고"
    },
    {
      "start": 682.82,
      "end": 687.71,
      "text": "삼성도 마찬가지일 거예요."
    },
    {
      "start": 687.71,
      "end": 690.35,
      "text": "빠질 거라고 말씀드렸네 쭉 빠지는 추세고"
    },
    {
      "start": 690.35,
      "end": 691.15,
      "text": "뭐"
    },
    {
      "start": 692.62,
      "end": 695.1,
      "text": "그렇죠."
    },
    {
      "start": 695.1,
      "end": 697.1,
      "text": "좀 내려오고 있어요."
    },
    {
      "start": 697.1,
      "end": 698.7,
      "text": "특징은"
    },
    {
      "start": 698.7,
      "end": 703.18,
      "text": "특이쩌하면 딱 겹는 것 같고"
    },
    {
      "start": 703.18,
      "end": 705.74,
      "text": "외쯤 모양이 보이는데 외치를"
    },
    {
      "start": 705.74,
      "end": 706.54,
      "text": "탈락시키는"
    },
    {
      "start": 706.54,
      "end": 708.7,
      "text": "여기서 빨리 말하올리면"
    },
    {
      "start": 708.7,
      "end": 710.54,
      "text": "괜찮긴 한데"
    },
    {
      "start": 710.54,
      "end": 712.62,
      "text": "내일 하고 내일 모를 짱 중약했네요."
    },
    {
      "start": 712.62,
      "end": 714.54,
      "text": "여기 외치 다시 말아서 위로"
    },
    {
      "start": 714.54,
      "end": 716.62,
      "text": "올라갈지 않으러 할지 좀 중요할 것 같은데"
    },
    {
      "start": 716.62,
      "end": 717.82,
      "text": "코스피가 하방이라 삼성도"
    },
    {
      "start": 717.82,
      "end": 720.78,
      "text": "올라오고 싶지 않을 것 같고"
    },
    {
      "start": 720.78,
      "end": 725.9,
      "text": "다음에 탔슬라도 하방이라고 말씀드렸는데"
    },
    {
      "start": 725.9,
      "end": 727.34,
      "text": "대슬라도 계속 흐르고 있어요."
    },
    {
      "start": 727.34,
      "end": 730.54,
      "text": "대슬라도 더 빠질 가능성이 좀 있죠."
    },
    {
      "start": 730.54,
      "end": 732.3,
      "text": "물론 그때 이제"
    },
    {
      "start": 732.3,
      "end": 734.94,
      "text": "우리가 원했던 건"
    },
    {
      "start": 734.94,
      "end": 737.18,
      "text": "ABC 완성이 아니라 원트 원트"
    },
    {
      "start": 737.18,
      "end": 738.86,
      "text": "투였음을 잡혔다 그러면"
    },
    {
      "start": 738.86,
      "end": 740.7,
      "text": "코점을 넘기거든요."
    },
    {
      "start": 740.7,
      "end": 741.98,
      "text": "제가 너무 잘 빨리 얘기하고 있는"
    },
    {
      "start": 741.98,
      "end": 743.42,
      "text": "이게 안간 분은"
    },
    {
      "start": 743.42,
      "end": 744.54,
      "text": "지난방송 보시고"
    },
    {
      "start": 744.54,
      "end": 747.42,
      "text": "다음에 원트 원트면 6800을 지켜줬을"
    },
    {
      "start": 747.42,
      "end": 750.14,
      "text": "확률 높아 높지면 6800을 지켜줬고"
    },
    {
      "start": 750.14,
      "end": 752.86,
      "text": "1800을 뭐냐면 여기 가볍과"
    },
    {
      "start": 752.86,
      "end": 755.9,
      "text": "동일하고 있는 올라가다가 조정을 크게 받았지만"
    },
    {
      "start": 755.9,
      "end": 757.98,
      "text": "반대는 왔던 이 시염되어 계신"
    },
    {
      "start": 757.98,
      "end": 759.98,
      "text": "뚜껏 내려갔어요."
    },
    {
      "start": 759.98,
      "end": 763.74,
      "text": "그렇기 때문에 원트 원트을 감시는 별로 없고"
    },
    {
      "start": 763.74,
      "end": 765.34,
      "text": "이대로 쭉 빠질 가능성이 높다."
    },
    {
      "start": 765.34,
      "end": 767.98,
      "text": "ABC가 막기 때문에 최선 절방까지는"
    },
    {
      "start": 767.98,
      "end": 769.18,
      "text": "빠질 형률 높죠."
    },
    {
      "start": 769.18,
      "end": 770.78,
      "text": "그럼 최선 절방이면"
    },
    {
      "start": 770.78,
      "end": 773.26,
      "text": "여기까지는 190듀 낙가진 빠질 거고"
    },
    {
      "start": 773.26,
      "end": 774.7,
      "text": "여기 딱히 맘을 때가 없으니까"
    },
    {
      "start": 774.7,
      "end": 777.1,
      "text": "산빨까지 빠질 형률을 해보겠죠."
    },
    {
      "start": 777.1,
      "end": 778.3,
      "text": "그래서 이제 신어보는 맛인데"
    },
    {
      "start": 778.3,
      "end": 780.3,
      "text": "여기에서는 욕싱되지 말고"
    },
    {
      "start": 780.3,
      "end": 781.82,
      "text": "우리 여기서 사잖아요."
    },
    {
      "start": 781.82,
      "end": 783.18,
      "text": "이만큼 먹었으면 됐으니까"
    },
    {
      "start": 783.18,
      "end": 784.7,
      "text": "반의여도 파는 게 맞게 따라서"
    },
    {
      "start": 784.7,
      "end": 786.22,
      "text": "말씀드렸는데"
    },
    {
      "start": 786.22,
      "end": 788.14,
      "text": "방향을 가고 있고 다음에"
    },
    {
      "start": 788.14,
      "end": 804.13,
      "text": "카카오볼께요."
    },
    {
      "start": 804.13,
      "end": 806.53,
      "text": "카카오도 이제"
    },
    {
      "start": 806.53,
      "end": 808.21,
      "text": "카카오도 매술했죠."
    },
    {
      "start": 808.21,
      "end": 809.97,
      "text": "저는 물렸어요."
    },
    {
      "start": 809.97,
      "end": 811.73,
      "text": "카카오도 여기서 샀고"
    },
    {
      "start": 811.73,
      "end": 813.73,
      "text": "여기서 샀고"
    },
    {
      "start": 813.73,
      "end": 817.17,
      "text": "뭔가 2000원을 샀고 정말 300원이니까 빠졌어요."
    },
    {
      "start": 817.17,
      "end": 819.41,
      "text": "근데 쭉 흥적이긴 해요."
    },
    {
      "start": 819.41,
      "end": 821.17,
      "text": "이게 반등이 왔어야 될지 하는데"
    },
    {
      "start": 821.17,
      "end": 823.25,
      "text": "반등이 안아가지고"
    },
    {
      "start": 823.25,
      "end": 824.93,
      "text": "근데 또"
    },
    {
      "start": 824.93,
      "end": 826.85,
      "text": "물론 기준점 여기 흔적라는 여긴니까"
    },
    {
      "start": 826.85,
      "end": 829.41,
      "text": "근데 차트는 역시 너무 예뻐요."
    },
    {
      "start": 829.41,
      "end": 830.85,
      "text": "덜 받은 지켓고"
    },
    {
      "start": 830.85,
      "end": 833.09,
      "text": "내로든 거에 상당히 걸렸고"
    },
    {
      "start": 833.09,
      "end": 834.69,
      "text": "반등하고 소정하고"
    },
    {
      "start": 834.69,
      "end": 838.69,
      "text": "올라갈 거를 보고 여기서 매술한 거라"
    },
    {
      "start": 838.69,
      "end": 841.33,
      "text": "여기를 보고 매술한 건데"
    },
    {
      "start": 841.33,
      "end": 842.61,
      "text": "선젤라인이 짧죠."
    },
    {
      "start": 842.61,
      "end": 845.33,
      "text": "손이 띄 괜찮고"
    },
    {
      "start": 845.33,
      "end": 847.97,
      "text": "확률도 괜찮고 해서 했는데 흐르고 있어요."
    },
    {
      "start": 847.97,
      "end": 849.65,
      "text": "근데 왜 회의적이라면"
    },
    {
      "start": 849.65,
      "end": 851.65,
      "text": "카카오도 당연히 코스피 정도 했는데"
    },
    {
      "start": 851.65,
      "end": 853.17,
      "text": "코스피가 지금 빠질 것 같은데"
    },
    {
      "start": 853.17,
      "end": 854.93,
      "text": "카카오도 언제 올라가려면"
    },
    {
      "start": 854.93,
      "end": 857.49,
      "text": "카카오도 굉장히 한 호재가 이상해 안에"
    },
    {
      "start": 857.49,
      "end": 859.41,
      "text": "이번 주에는 터져야 되는데"
    },
    {
      "start": 859.41,
      "end": 861.09,
      "text": "과연 카카오도 이번 주"
    },
    {
      "start": 861.09,
      "end": 863.65,
      "text": "안에 뉴스은 아울치를 주먹하면서"
    },
    {
      "start": 863.65,
      "end": 865.09,
      "text": "카카오도 보면 될 것 같아요."
    },
    {
      "start": 865.09,
      "end": 866.69,
      "text": "그러다가 여기 오만"
    },
    {
      "start": 866.69,
      "end": 869.65,
      "text": "사만 7000, 사만 8500원으로 손절을 차야돼요."
    },
    {
      "start": 869.65,
      "end": 872.45,
      "text": "이렇게 들고 있으면 없습니다."
    },
    {
      "start": 872.45,
      "end": 889.89,
      "text": "오늘 따라외도 채팅창이 또 왜 또"
    },
    {
      "start": 889.89,
      "end": 893.73,
      "text": "이렇게 뭐 매형남이랑 바이비트랑"
    },
    {
      "start": 893.73,
      "end": 899.38,
      "text": "대회 짝우치는 거라고"
    },
    {
      "start": 899.38,
      "end": 902.59,
      "text": "제가 뭐라고"
    },
    {
      "start": 902.59,
      "end": 904.27,
      "text": "바이비틱 아이예"
    },
    {
      "start": 904.27,
      "end": 905.95,
      "text": "삼성"
    },
    {
      "start": 905.95,
      "end": 907.23,
      "text": "징권이나 코스피"
    },
    {
      "start": 907.23,
      "end": 907.87,
      "text": "저게 뭐야."
    },
    {
      "start": 907.87,
      "end": 909.07,
      "text": "키움준권 부다 더"
    },
    {
      "start": 909.07,
      "end": 911.15,
      "text": "시각청이 또 거래랑 많고"
    },
    {
      "start": 911.15,
      "end": 913.07,
      "text": "대단한 글로벌을 회사에요"
    },
    {
      "start": 913.07,
      "end": 915.71,
      "text": "동네 부모가게 아니에요"
    },
    {
      "start": 915.71,
      "end": 918.43,
      "text": "전 세계에서 손가락에 뽑는"
    },
    {
      "start": 918.43,
      "end": 919.87,
      "text": "그런 큰 곳에서"
    },
    {
      "start": 919.87,
      "end": 921.55,
      "text": "1등 3성 징권이라고 할게요"
    },
    {
      "start": 921.55,
      "end": 923.55,
      "text": "3성 징권이 뭐라고"
    },
    {
      "start": 923.55,
      "end": 924.11,
      "text": "아니지요."
    },
    {
      "start": 924.11,
      "end": 925.23,
      "text": "랑"
    },
    {
      "start": 925.23,
      "end": 926.35,
      "text": "짝우"
    },
    {
      "start": 926.35,
      "end": 929.79,
      "text": "저를 스포 내줘서 밀어주고 대회를 주작해요"
    },
    {
      "start": 929.79,
      "end": 933.39,
      "text": "한국에 있는 저 트레이더 하나가 뭐라고"
    },
    {
      "start": 933.39,
      "end": 950.75,
      "text": "남상이 심하죠?"
    },
    {
      "start": 950.75,
      "end": 952.51,
      "text": "알람 올렸네"
    },
    {
      "start": 952.51,
      "end": 954.67,
      "text": "아 리플로 천심 리플로우인데"
    },
    {
      "start": 958.54,
      "end": 966.88,
      "text": "마지막으로 나였던 리플로 천천히 잘 되나"
    },
    {
      "start": 966.88,
      "end": 970.0,
      "text": "이플로우 들어가는 근거는 이거였어요"
    },
    {
      "start": 970.0,
      "end": 970.96,
      "text": "그"
    },
    {
      "start": 970.96,
      "end": 974.9,
      "text": "텔레그램 방에만 공유했는데"
    },
    {
      "start": 974.9,
      "end": 976.9,
      "text": "고점 찍고 그때 이제"
    },
    {
      "start": 976.9,
      "end": 978.74,
      "text": "SCC에서 승소했다고 해서"
    },
    {
      "start": 978.74,
      "end": 980.74,
      "text": "고점 찍고 나서"
    },
    {
      "start": 980.74,
      "end": 982.18,
      "text": "아 승소는 아니구나"
    },
    {
      "start": 982.18,
      "end": 983.62,
      "text": "어쨌든"
    },
    {
      "start": 983.62,
      "end": 986.1,
      "text": "그 리플리 진권이 아니냐에 대해서"
    },
    {
      "start": 986.1,
      "end": 987.06,
      "text": "이슈가 있었죠"
    },
    {
      "start": 987.06,
      "end": 989.38,
      "text": "그렇듯 그 뒤로 고점 찍고"
    },
    {
      "start": 989.38,
      "end": 992.02,
      "text": "이렇게 외치모양으로 내려오고 있었다가"
    },
    {
      "start": 992.02,
      "end": 993.38,
      "text": "외치 끝에서 반대에 나와"
    },
    {
      "start": 993.38,
      "end": 996.5,
      "text": "그래서 내 시간 몽상다가 예쁘게 걸렸어요"
    },
    {
      "start": 996.5,
      "end": 997.98,
      "text": "내 시간, 뭐는 상승가 이만"
    },
    {
      "start": 997.98,
      "end": 1000.42,
      "text": "또 추세 전환이고 외치도 추세 전환이라"
    },
    {
      "start": 1000.42,
      "end": 1003.3,
      "text": "창방을 보고로워들어갔습니다"
    },
    {
      "start": 1003.3,
      "end": 1006.58,
      "text": "그래서 기진점은 손절 기진점은 뭐라요"
    },
    {
      "start": 1006.58,
      "end": 1008.5,
      "text": "오늘 반등이 있었던"
    },
    {
      "start": 1008.5,
      "end": 1009.94,
      "text": "여기가"
    },
    {
      "start": 1009.94,
      "end": 1011.14,
      "text": "빼지지 않으면"
    },
    {
      "start": 1011.14,
      "end": 1013.7,
      "text": "이 가격이 빼지지 않으면"
    },
    {
      "start": 1013.7,
      "end": 1016.1,
      "text": "창방으로 가면 꽤 많은 수익이 있을 거고"
    },
    {
      "start": 1016.1,
      "end": 1018.42,
      "text": "그렇지 않으면 여기서 손절을 칠 거예요"
    },
    {
      "start": 1018.42,
      "end": 1021.22,
      "text": "근데 손절하니까 다섯 조금 거리가 있어서"
    },
    {
      "start": 1021.22,
      "end": 1023.46,
      "text": "손해를 많이 감수해야 되기 때문에"
    },
    {
      "start": 1023.46,
      "end": 1026.34,
      "text": "주의깊게 매수진이 팔하고 말씀드렸고"
    },
    {
      "start": 1026.34,
      "end": 1028.82,
      "text": "저도 여기서 로봇을 들어가서요"
    },
    {
      "start": 1028.82,
      "end": 1029.7,
      "text": "그러니까"
    },
    {
      "start": 1029.7,
      "end": 1032.1,
      "text": "이것도 사실"
    },
    {
      "start": 1032.1,
      "end": 1034.74,
      "text": "정말 엄미리 솔직히하게 말씀드리면"
    },
    {
      "start": 1034.74,
      "end": 1036.66,
      "text": "그 일등 팀이 실격 당했으면"
    },
    {
      "start": 1036.66,
      "end": 1039.46,
      "text": "리플롱 무리해서 여기서 안 들어갔어요"
    },
    {
      "start": 1039.46,
      "end": 1043.14,
      "text": "리플롱을 들어갔어야 될 타임이 있는 여기거든요"
    },
    {
      "start": 1043.14,
      "end": 1045.46,
      "text": "여기를 진입했을 때 여기서 들어가는 거예요"
    },
    {
      "start": 1045.46,
      "end": 1047.62,
      "text": "시작하러 아니면 여기서 지전 걸어봤고요"
    },
    {
      "start": 1047.62,
      "end": 1049.7,
      "text": "여기서 숨절리지도 않는데"
    },
    {
      "start": 1049.7,
      "end": 1051.22,
      "text": "고민을 하다가"
    },
    {
      "start": 1051.22,
      "end": 1053.62,
      "text": "이제 늦게 바꾸냐 리플롱 여기서 여기서 봤어요"
    },
    {
      "start": 1053.62,
      "end": 1056.02,
      "text": "여기서 그래서 제 진입하게 여기거든요"
    },
    {
      "start": 1056.02,
      "end": 1057.54,
      "text": "평당히 너무 안 좋죠"
    },
    {
      "start": 1057.54,
      "end": 1059.22,
      "text": "여기서 샀는 거랑"
    },
    {
      "start": 1059.22,
      "end": 1060.58,
      "text": "여기는 천지차예요"
    },
    {
      "start": 1060.58,
      "end": 1063.95,
      "text": "손절이 200mAh"
    },
    {
      "start": 1063.95,
      "end": 1069.39,
      "text": "저 평소에는 이렇게 손절 리스가 큰 걸 감사면서 메수진이 파지 않는데"
    },
    {
      "start": 1069.39,
      "end": 1072.43,
      "text": "일등 팀 어떻게든 이겨 보겠다고 무리해서 조금 진입했는데"
    },
    {
      "start": 1072.43,
      "end": 1073.79,
      "text": "결가는 나와 봐야 알겠죠"
    },
    {
      "start": 1073.79,
      "end": 1077.23,
      "text": "물론 이게 다시 이렇게 꼴일 말고 올라가면"
    },
    {
      "start": 1077.23,
      "end": 1080.91,
      "text": "그러면 여기서 드러면으로 잘한 거기는 한데"
    },
    {
      "start": 1081.31,
      "end": 1083.07,
      "text": "안 되면 여기서 먼저 실겁니다"
    },
    {
      "start": 1083.07,
      "end": 1117.49,
      "text": "한 분 뭐 그렇합니다"
    },
    {
      "start": 1117.49,
      "end": 1119.97,
      "text": "비트가 어쨌든 제일 지금"
    },
    {
      "start": 1119.97,
      "end": 1122.21,
      "text": "상당히 중요한 데 얼마 안 남았어요"
    },
    {
      "start": 1122.21,
      "end": 1127.01,
      "text": "이 가격이 가격 1시켜준지 안 지켜준지 보세요"
    },
    {
      "start": 1127.01,
      "end": 1133.33,
      "text": "잠깐만 30분 봄 보면 한 번 더 반등 깨고 올라갈 수 있나 볼게요"
    },
    {
      "start": 1133.33,
      "end": 1134.69,
      "text": "가능성을 봅시다"
    },
    {
      "start": 1134.69,
      "end": 1144.0,
      "text": "30분 봄 가능성 예를 들어서 여기를 깨도"
    },
    {
      "start": 1144.0,
      "end": 1148.08,
      "text": "이렇게 깨겠면요"
    },
    {
      "start": 1148.08,
      "end": 1150.72,
      "text": "꽤 잡아서 바로 붙잡아놓은 게 말아올리면"
    },
    {
      "start": 1150.72,
      "end": 1152.4,
      "text": "알았어요 이렇게 그러지 않아서"
    },
    {
      "start": 1152.4,
      "end": 1155.68,
      "text": "더블다이번에 이렇게 한 번 나이번에 쓴"
    },
    {
      "start": 1155.68,
      "end": 1159.28,
      "text": "30분 뭐 또 이렇게 더블다이번에 걸릴 수 있거든요"
    },
    {
      "start": 1159.28,
      "end": 1161.12,
      "text": "모양도 외치고"
    },
    {
      "start": 1161.12,
      "end": 1162.72,
      "text": "못 말은 자 알겠죠"
    },
    {
      "start": 1162.72,
      "end": 1166.24,
      "text": "그래서 여기를 깨도라도 꽤 잡아서 붙잡았던 거면"
    },
    {
      "start": 1166.24,
      "end": 1169.12,
      "text": "상반가를 확률 높기 때문에 상반을 보셔야 되고"
    },
    {
      "start": 1169.12,
      "end": 1176.08,
      "text": "그렇지 않고 흐르면은 여기서 반등 이렇게 나온다고 하더라도 또 빠질 확률이 있어요"
    },
    {
      "start": 1176.08,
      "end": 1181.2,
      "text": "그래서 맨은 어떤 식으로 하는 거냐면 이 자리가 왔을 때 지정가루를 받아보고"
    },
    {
      "start": 1181.2,
      "end": 1185.12,
      "text": "여기 이탈에서 아래서에가 밀려가지고 더블다이번에 안 날 것 같다고 생각하면"
    },
    {
      "start": 1185.12,
      "end": 1187.36,
      "text": "이 잊지 없는 것거든요"
    },
    {
      "start": 1187.36,
      "end": 1190.08,
      "text": "시시간은 모인탈이 하다가 손절을 정하는 겁니다"
    },
    {
      "start": 1190.08,
      "end": 1192.24,
      "text": "보통 전 맨을 그렇게 들어가요"
    },
    {
      "start": 1192.24,
      "end": 1194.4,
      "text": "이렇게 분석을 했을 때 참고하세요"
    },
    {
      "start": 1194.4,
      "end": 1210.16,
      "text": "찝질이는 거예요"
    },
    {
      "start": 1210.16,
      "end": 1213.84,
      "text": "킬격사요 자세히 발표는 안 했는데 그 공지에 있어요"
    },
    {
      "start": 1213.84,
      "end": 1217.2,
      "text": "발표에 공지가하면 부정 행위를 발견해서"
    },
    {
      "start": 1217.2,
      "end": 1218.72,
      "text": "킬격끝다고 되어 있어요"
    },
    {
      "start": 1218.72,
      "end": 1222.72,
      "text": "근데 그"
    },
    {
      "start": 1222.72,
      "end": 1226.56,
      "text": "개내가 디스튜드 를 만들어서 자기 디스튜드 가입해라"
    },
    {
      "start": 1226.56,
      "end": 1230.32,
      "text": "라고 기도했었는데 그 디스튜드에 들어갔던 사람이"
    },
    {
      "start": 1230.32,
      "end": 1234.64,
      "text": "말해준 걸로 제가 봤었을 때"
    },
    {
      "start": 1234.64,
      "end": 1242.03,
      "text": "뭐가 있었느냐면 이 코인으로 부정을 했대요"
    },
    {
      "start": 1242.03,
      "end": 1249.82,
      "text": "좀 이상하다 와 더라고요"
    },
    {
      "start": 1249.82,
      "end": 1255.1,
      "text": "대회 딱 시작하고서 한 번에 올라가는 거로 떨어지는 것이죠"
    },
    {
      "start": 1255.1,
      "end": 1259.34,
      "text": "올라간 거로운 쇼트, 롱 쇼트, 롱 쇼트, 롱 쇼트, 이렇게 딱"
    },
    {
      "start": 1259.34,
      "end": 1263.74,
      "text": "이것만 맨에서 1등 2만 5천 불어치같아요"
    },
    {
      "start": 1263.74,
      "end": 1269.34,
      "text": "여기서 롱, 6쇼트, 롱 쇼트, 롱 쇼트, 롱 쇼트, 롱"
    },
    {
      "start": 1269.34,
      "end": 1275.5,
      "text": "이거 해서 2만 5천 불 끝"
    },
    {
      "start": 1275.5,
      "end": 1278.94,
      "text": "그래서 이게 아마"
    },
    {
      "start": 1278.94,
      "end": 1282.86,
      "text": "의도적인 무빙이지 않았을까 라고 이야기를 하더라고요"
    },
    {
      "start": 1282.86,
      "end": 1288.3,
      "text": "이거는 근데 이제 발표에 들어가 있던 사람이 해준 말이에요"
    },
    {
      "start": 1288.3,
      "end": 1292.88,
      "text": "피셔를 아니고 근데 좀 티 나죠"
    },
    {
      "start": 1292.88,
      "end": 1306.62,
      "text": "좀 티 나죠"
    },
    {
      "start": 1306.62,
      "end": 1309.02,
      "text": "그래서 아마 저 제가 그랬었거든요"
    },
    {
      "start": 1309.02,
      "end": 1311.58,
      "text": "저 팀 아마 엠틴 같다"
    },
    {
      "start": 1311.58,
      "end": 1313.98,
      "text": "보통 뭐가 있냐면"
    },
    {
      "start": 1313.98,
      "end": 1315.98,
      "text": "한국에도 지금 똑같은데"
    },
    {
      "start": 1315.98,
      "end": 1317.82,
      "text": "예를 들면"
    },
    {
      "start": 1317.82,
      "end": 1319.82,
      "text": "근데 얘기하면 또 싸움을 낙때인데"
    },
    {
      "start": 1319.82,
      "end": 1322.3,
      "text": "어쨌든 한국에서 되게 유명한 여러분는 모르지 마"
    },
    {
      "start": 1322.3,
      "end": 1325.58,
      "text": "조단이 돈을 굴린다고 알려져 있는"
    },
    {
      "start": 1325.58,
      "end": 1329.5,
      "text": "되게 해베로부터 또 투자 많이 받은 한국 인 운영 팀이 있어요"
    },
    {
      "start": 1329.5,
      "end": 1332.78,
      "text": "근데 말이 그 환드 팀이지"
    },
    {
      "start": 1332.78,
      "end": 1334.78,
      "text": "사실은 MM 주작 팀이거든요"
    },
    {
      "start": 1334.78,
      "end": 1337.5,
      "text": "어피트 코인 관리하면서 거기서"
    },
    {
      "start": 1337.5,
      "end": 1340.7,
      "text": "개민들 등권 처먹는 팀이 있어요"
    },
    {
      "start": 1340.7,
      "end": 1342.14,
      "text": "팀 이름도 아닌데"
    },
    {
      "start": 1342.14,
      "end": 1344.3,
      "text": "검찰 이번에"
    },
    {
      "start": 1344.3,
      "end": 1347.34,
      "text": "세달전거 내달전의 검찰의 기소도 됐던 팀인데"
    },
    {
      "start": 1347.34,
      "end": 1349.26,
      "text": "좀 조사 받고 검찰 조사 받고 있거든요"
    },
    {
      "start": 1349.26,
      "end": 1353.33,
      "text": "근데 뭐 진의 진이기도 하고"
    },
    {
      "start": 1353.33,
      "end": 1355.73,
      "text": "그래서 어쨌든 팀 이름은 말 안 할게요"
    },
    {
      "start": 1355.73,
      "end": 1357.41,
      "text": "아시는 분 아실 텐데"
    },
    {
      "start": 1357.41,
      "end": 1358.69,
      "text": "어쨌든 그런 팀이에요"
    },
    {
      "start": 1358.69,
      "end": 1360.93,
      "text": "말만 운영 사고"
    },
    {
      "start": 1360.93,
      "end": 1363.73,
      "text": "말만 폰도 조성해서"
    },
    {
      "start": 1363.73,
      "end": 1366.21,
      "text": "코인 회사에 투자한다고 하지 MM 하면서"
    },
    {
      "start": 1366.21,
      "end": 1367.49,
      "text": "작전하면서"
    },
    {
      "start": 1367.49,
      "end": 1369.17,
      "text": "벌어먹는 팀인데"
    },
    {
      "start": 1369.17,
      "end": 1371.49,
      "text": "그 악 1등 팀이었던 러시아 팀 딱"
    },
    {
      "start": 1371.49,
      "end": 1372.93,
      "text": "그 느낌 났어요 MM 팀 같애"
    },
    {
      "start": 1372.93,
      "end": 1374.21,
      "text": "그래서 왠지"
    },
    {
      "start": 1374.21,
      "end": 1376.37,
      "text": "바이비세 상장들 있는 코인 중에 하나"
    },
    {
      "start": 1376.37,
      "end": 1378.13,
      "text": "맡아서 관리하는 팀인데"
    },
    {
      "start": 1378.13,
      "end": 1381.09,
      "text": "이건 대응하시고 진의 코인 관리하면서"
    },
    {
      "start": 1381.09,
      "end": 1382.93,
      "text": "시대적으로 개가 중 1등 하는 것 같다라고 제가"
    },
    {
      "start": 1382.93,
      "end": 1385.09,
      "text": "듣고 남겼는데 딱 그건 것 같아요"
    },
    {
      "start": 1385.09,
      "end": 1388.13,
      "text": "정확게 MM 팀이 자기가 상장식인"
    },
    {
      "start": 1388.13,
      "end": 1390.05,
      "text": "스킬서 관리하는 코인"
    },
    {
      "start": 1390.05,
      "end": 1392.05,
      "text": "주작 시세 주작 계가지고"
    },
    {
      "start": 1392.05,
      "end": 1394.21,
      "text": "신유를 1등 하면서"
    },
    {
      "start": 1394.21,
      "end": 1410.11,
      "text": "자기네 회성과 했던 것 같아요"
    },
    {
      "start": 1410.11,
      "end": 1412.59,
      "text": "그 제거 추천인 코드 그런 거는"
    },
    {
      "start": 1412.59,
      "end": 1414.11,
      "text": "커뮤니스트로 커뮤니트 공지 보자"
    },
    {
      "start": 1414.11,
      "end": 1416.19,
      "text": "대회 나가는 공지라는"
    },
    {
      "start": 1416.19,
      "end": 1421.9,
      "text": "그 가입 코드 있으니까 그 확인하시면 돼요"
    },
    {
      "start": 1421.9,
      "end": 1423.98,
      "text": "아무튼 피곤으로"
    },
    {
      "start": 1423.98,
      "end": 1425.98,
      "text": "차트들 돌려 봤고"
    },
    {
      "start": 1427.1,
      "end": 1429.9,
      "text": "뭐 대회 마지막까지"
    },
    {
      "start": 1429.9,
      "end": 1432.86,
      "text": "열심히 해가지고 1등 마무리해서"
    },
    {
      "start": 1432.86,
      "end": 1434.86,
      "text": "저희 팀으로 나아주신 분들께"
    },
    {
      "start": 1434.86,
      "end": 1437.1,
      "text": "상금이 최대한 분배대 수 있도록"
    },
    {
      "start": 1437.1,
      "end": 1438.06,
      "text": "노력하겠습니다"
    },
    {
      "start": 1438.06,
      "end": 1439.74,
      "text": "오늘은 저 기분 좋아가지고"
    },
    {
      "start": 1439.74,
      "end": 1442.3,
      "text": "맨에 안 하고 실고"
    },
    {
      "start": 1442.3,
      "end": 1445.1,
      "text": "나 가서 소중한 일어나고야겠네요"
    },
    {
      "start": 1445.1,
      "end": 1447.74,
      "text": "내부터 또 열심히 달려가고 됐어"
    },
    {
      "start": 1447.74,
      "end": 1450.3,
      "text": "파필로 리더일 동안 수 있게 가입해 주세요"
    },
    {
      "start": 1450.3,
      "end": 1452.86,
      "text": "가입 하시면 어차피 가입한 분들한테 다"
    },
    {
      "start": 1452.86,
      "end": 1454.62,
      "text": "상금 분배대니까"
    },
    {
      "start": 1454.62,
      "end": 1457.1,
      "text": "저희 팀이 사실 이제 거의 확실했지 하잖아요"
    },
    {
      "start": 1457.1,
      "end": 1459.26,
      "text": "어딴이 팀 난라가가지고"
    },
    {
      "start": 1459.26,
      "end": 1460.7,
      "text": "그러니까 서로 좋은 거예요"
    },
    {
      "start": 1460.7,
      "end": 1462.38,
      "text": "저는 명애를 얻고"
    },
    {
      "start": 1462.38,
      "end": 1465.74,
      "text": "내가 그래도 대회에서 가장 인기 있는 팀이었다"
    },
    {
      "start": 1465.74,
      "end": 1467.5,
      "text": "나는 명애를 얻고 여러분들은"
    },
    {
      "start": 1467.5,
      "end": 1476.3,
      "text": "상금 분배대 를 받고"
    },
    {
      "start": 1476.3,
      "end": 1481.18,
      "text": "아 축하 해주시는 거 감자한데 아직 대회가 많이 나와가지고"
    },
    {
      "start": 1481.18,
      "end": 1483.18,
      "text": "축하 바뀐 이름입니다"
    },
    {
      "start": 1483.18,
      "end": 1485.58,
      "text": "마지막까지 좀 잘 해볼게요"
    },
    {
      "start": 1485.58,
      "end": 1489.42,
      "text": "제가 또 1등 찍어놓고 계속 격차 벌리면서"
    },
    {
      "start": 1489.42,
      "end": 1492.54,
      "text": "견제하는 건 구치기하는 건 잘하잖아요"
    },
    {
      "start": 1492.54,
      "end": 1494.94,
      "text": "지난 3개년도로 다 그렇게 웃으니깐"
    },
    {
      "start": 1494.94,
      "end": 1497.66,
      "text": "2020년 21년 20년에다"
    },
    {
      "start": 1497.66,
      "end": 1499.98,
      "text": "올해도 그렇게 안 번호수 하나씩 돌아"
    },
    {
      "start": 1499.98,
      "end": 1503.82,
      "text": "노력하겠습니다 요즘 스트레스가 진짜 말해 아니라서"
    },
    {
      "start": 1503.82,
      "end": 1505.66,
      "text": "제가 뒷코방이랑"
    },
    {
      "start": 1505.66,
      "end": 1510.62,
      "text": "다음에 이런 대회 텔레방에서 진짜 말을 좀"
    },
    {
      "start": 1510.62,
      "end": 1513.02,
      "text": "예민하게 했거든요"
    },
    {
      "start": 1513.02,
      "end": 1515.66,
      "text": "제가 이런 말 했을 오늘"
    },
    {
      "start": 1515.66,
      "end": 1518.14,
      "text": "어떤 사람의 장애퇴이 어렵다"
    },
    {
      "start": 1518.14,
      "end": 1520.14,
      "text": "텔레 대회방에 이렇게 썼길래 제가"
    },
    {
      "start": 1520.14,
      "end": 1522.46,
      "text": "1개는 일기장에서 세월하고 했거든요"
    },
    {
      "start": 1522.46,
      "end": 1525.5,
      "text": "아 근데 그걸 제가 그렇게 해놓고서"
    },
    {
      "start": 1525.5,
      "end": 1529.1,
      "text": "아 나 이렇게 깎이라지 스트레스 받는 거를 이렇게"
    },
    {
      "start": 1529.1,
      "end": 1531.1,
      "text": "팀에 만드는 데 했는데"
    },
    {
      "start": 1531.1,
      "end": 1532.22,
      "text": "했는데"
    },
    {
      "start": 1532.22,
      "end": 1534.78,
      "text": "어쨌든 미안해요"
    },
    {
      "start": 1534.78,
      "end": 1537.66,
      "text": "텔레방에는 분석길만 올리라고"
    },
    {
      "start": 1537.66,
      "end": 1539.42,
      "text": "공지가 되어 있어서"
    },
    {
      "start": 1539.42,
      "end": 1541.18,
      "text": "잡담 한 명이 하기 시작하면"
    },
    {
      "start": 1541.18,
      "end": 1542.7,
      "text": "나 첫 명이 잡담을 하니까"
    },
    {
      "start": 1542.7,
      "end": 1547.9,
      "text": "조금 자제를 시키고 있는데 그 자제를 시키는 방식이 제가 너무 예민했던 것 같아서"
    },
    {
      "start": 1547.9,
      "end": 1549.18,
      "text": "사가 드리고"
    },
    {
      "start": 1549.18,
      "end": 1552.8,
      "text": "내리부터는 좀 더 편한 한 모습"
    },
    {
      "start": 1552.8,
      "end": 1557.58,
      "text": "특고방이랑 텔레방의 마트 하도록 하겠습니다"
    },
    {
      "start": 1557.58,
      "end": 1561.58,
      "text": "아무튼 오늘 방송은 빨리 마칠게요"
    },
    {
      "start": 1561.58,
      "end": 1564.06,
      "text": "좋아요 한 번씩 부탁드리고"
    },
    {
      "start": 1564.06,
      "end": 1567.58,
      "text": "되게 마지막까지 열심히 해가지고"
    },
    {
      "start": 1567.58,
      "end": 1569.18,
      "text": "기대해 부끄러워도록 하겠습니다"
    },
    {
      "start": 1569.18,
      "end": 1571.18,
      "text": "좋은반되시고"
    },
    {
      "start": 1571.18,
      "end": 1573.34,
      "text": "조만간 방송도 한번 키겠습니다"
    },
    {
      "start": 1573.34,
      "end": 1575.34,
      "text": "네 고맙습니다"
    }
  ]
}