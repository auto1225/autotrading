      "end": 817.25,
      "text": "만약에 내가"
    },
    {
      "start": 817.25,
      "end": 819.25,
      "text": "만약에 헌물로라다"
    },
    {
      "start": 819.25,
      "end": 821.98,
      "text": "라고 하면"
    },
    {
      "start": 821.98,
      "end": 823.98,
      "text": "이 쯤에 한번 물려보는 것도"
    },
    {
      "start": 823.98,
      "end": 828.22,
      "text": "나쁘지 않은 것 같아요."
    },
    {
      "start": 828.22,
      "end": 829.22,
      "text": "그리고"
    },
    {
      "start": 829.22,
      "end": 830.22,
      "text": "이때 한번"
    },
    {
      "start": 830.22,
      "end": 832.22,
      "text": "전체"
    },
    {
      "start": 832.22,
      "end": 833.22,
      "text": "비트코인 앞으로"
    },
    {
      "start": 833.22,
      "end": 834.22,
      "text": "그날 맬서"
    },
    {
      "start": 834.22,
      "end": 836.22,
      "text": "그 맥만 원이면"
    },
    {
      "start": 836.22,
      "end": 837.22,
      "text": "이때 한 30만 정도"
    },
    {
      "start": 837.22,
      "end": 838.22,
      "text": "매수하고"
    },
    {
      "start": 838.22,
      "end": 839.22,
      "text": "8만"
    },
    {
      "start": 839.22,
      "end": 840.22,
      "text": "초관에서 한"
    },
    {
      "start": 840.22,
      "end": 841.22,
      "text": "70만 정도"
    },
    {
      "start": 841.22,
      "end": 842.22,
      "text": "매수에서"
    },
    {
      "start": 842.22,
      "end": 844.22,
      "text": "전체 병원은"
    },
    {
      "start": 844.22,
      "end": 845.22,
      "text": "매수고 해보는 것도"
    },
    {
      "start": 845.22,
      "end": 846.22,
      "text": "두 번으로"
    },
    {
      "start": 846.22,
      "end": 847.22,
      "text": "괜찮은 100인 것 같아요."
    },
    {
      "start": 847.22,
      "end": 848.22,
      "text": "제가 많이 헌물로"
    },
    {
      "start": 848.22,
      "end": 850.22,
      "text": "하님도 한 달에"
    },
    {
      "start": 850.22,
      "end": 860.84,
      "text": "한 달에 한번"
    },
    {
      "start": 860.84,
      "end": 862.84,
      "text": "조금씩 더 큰"
    },
    {
      "start": 862.84,
      "end": 864.84,
      "text": "너무 심플하네요."
    },
    {
      "start": 864.84,
      "end": 866.84,
      "text": "여기가 너무"
    },
    {
      "start": 866.84,
      "end": 870.98,
      "text": "컴퓨트니"
    },
    {
      "start": 870.98,
      "end": 872.98,
      "text": "너무 심플한"
    },
    {
      "start": 872.98,
      "end": 874.98,
      "text": "컴퓨트니"
    },
    {
      "start": 874.98,
      "end": 875.98,
      "text": "이건 이상 다르게 볼"
    },
    {
      "start": 875.98,
      "end": 876.98,
      "text": "컴퓨트니"
    },
    {
      "start": 876.98,
      "end": 877.98,
      "text": "입고"
    },
    {
      "start": 877.98,
      "end": 878.98,
      "text": "씩 다르게 볼"
    },
    {
      "start": 878.98,
      "end": 879.98,
      "text": "컴퓨트니"
    },
    {
      "start": 879.98,
