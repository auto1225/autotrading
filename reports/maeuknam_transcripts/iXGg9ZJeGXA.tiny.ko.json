{
  "id": "iXGg9ZJeGXA",
  "title": "[2024.09.01] Maeoknam_Bitcoin Analysis Broadcast #Bitcoin #bitcoin #btc #chartanalysis",
  "url": "https://www.youtube.com/watch?v=iXGg9ZJeGXA",
  "duration": 2269.123625,
  "language": "ko",
  "model": "tiny",
  "elapsed_seconds": 41.4,
  "segments": [
    {
      "start": 420.21,
      "end": 422.21,
      "text": "네 안녕하세요 반갑습니다."
    },
    {
      "start": 422.21,
      "end": 426.53,
      "text": "방송 시작하자마자 들어와 주신 이 전분 반갑고"
    },
    {
      "start": 426.53,
      "end": 428.77,
      "text": "좋아요 한 번씩 부탁드리겠습니다."
    },
    {
      "start": 428.77,
      "end": 430.97,
      "text": "방송 시작하자마자"
    },
    {
      "start": 432.17,
      "end": 435.86,
      "text": "잘 들릴수 나요?"
    },
    {
      "start": 435.86,
      "end": 438.7,
      "text": "지난번에 방송 소리 커졌다고 하던데"
    },
    {
      "start": 438.7,
      "end": 445.89,
      "text": "아 네 다행입니다."
    },
    {
      "start": 445.89,
      "end": 460.87,
      "text": "간단하게 구월이라 트레임들 공지하고 넘어 가겠습니다."
    },
    {
      "start": 460.87,
      "end": 465.95,
      "text": "구월에도 트레임들 내 아침 아웃시이부터인가?"
    },
    {
      "start": 465.95,
      "end": 467.39,
      "text": "열리구요."
    },
    {
      "start": 472.53,
      "end": 476.53,
      "text": "구월 트레임대에 면 좀 특이하게 3만 달라"
    },
    {
      "start": 476.53,
      "end": 479.89,
      "text": "대략한 4,000만 원 이 정도 되죠."
    },
    {
      "start": 479.89,
      "end": 481.93,
      "text": "추가 증정금 이벤트가 있습니다."
    },
    {
      "start": 481.93,
      "end": 483.57,
      "text": "이거는 제가 한 건 아니고"
    },
    {
      "start": 483.57,
      "end": 487.65,
      "text": "오케이, 엑스 측에서 갑자기 만들어졌어요."
    },
    {
      "start": 487.65,
      "end": 490.69,
      "text": "요청을 드린 적이 없는데"
    },
    {
      "start": 490.69,
      "end": 494.29,
      "text": "너무 감사하게도 만들어주셔서"
    },
    {
      "start": 494.29,
      "end": 499.41,
      "text": "그냥 선착순으로 거리한 사람 600명한테"
    },
    {
      "start": 499.41,
      "end": 504.53,
      "text": "각각 50명의 스티치, 대학한 65,000원 정도 되겠죠."
    },
    {
      "start": 504.53,
      "end": 508.69,
      "text": "테리금 뻔었을 진정한다고 합니다."
    },
    {
      "start": 508.69,
      "end": 514.57,
      "text": "그리고 메인 상금은 1등이"
    },
    {
      "start": 514.57,
      "end": 517.37,
      "text": "5,000나죠."
    },
    {
      "start": 517.37,
      "end": 519.69,
      "text": "기억이 안 나는 1등 5,000원"
    },
    {
      "start": 519.69,
      "end": 521.97,
      "text": "2등 1,500원, 3등 1,500원"
    },
    {
      "start": 521.97,
      "end": 524.01,
      "text": "4등부터 10등까지 전만 원"
    },
    {
      "start": 524.01,
      "end": 526.81,
      "text": "수익크부터까지 5,000원, 1,500원, 100,000원, 100,000원"
    },
    {
      "start": 526.81,
      "end": 528.81,
      "text": "수익크부터까지 각 100만 원"
    },
    {
      "start": 528.81,
      "end": 533.01,
      "text": "다음에 룰렛볶이 해서"
    },
    {
      "start": 533.01,
      "end": 535.37,
      "text": "한 분은 계속 2,000만 원인가?"
    },
    {
      "start": 535.37,
      "end": 536.17,
      "text": "3,000만 원입니다."
    },
    {
      "start": 536.17,
      "end": 536.89,
      "text": "기억이 안 나요."
    },
    {
      "start": 536.89,
      "end": 538.65,
      "text": "대회인데 내가 왜 기억을 못하지?"
    },
    {
      "start": 538.65,
      "end": 540.41,
      "text": "2,000만 원인가 들어요."
    },
    {
      "start": 540.41,
      "end": 545.13,
      "text": "대회의 공지는 컴퓨티 가시면 자세히 있으니까"
    },
    {
      "start": 545.13,
      "end": 547.13,
      "text": "거기에 있는 그 맥을 확인하시면 됩니다."
    },
    {
      "start": 547.13,
      "end": 552.05,
      "text": "대학한 2억 정도 배달 상금 드리고 있고"
    },
    {
      "start": 552.05,
      "end": 558.93,
      "text": "진짜 이 이렇게 대회는 이제 한지 이제 작년 한 11월부터"
    },
    {
      "start": 558.93,
      "end": 564.33,
      "text": "옛날 12월부터 했는 오케이X에서 아직 1년 안 됐는데"
    },
    {
      "start": 564.33,
      "end": 568.13,
      "text": "이 역 1년 가까이 이고 있는데 잘 하고 있는 것 같습니다."
    },
    {
      "start": 568.13,
      "end": 572.13,
      "text": "개인적으로는 이 정도 규모의 상금은"
    },
    {
      "start": 572.13,
      "end": 575.97,
      "text": "사실 개인이 주기 엄청나게 부담스럽군"
    },
    {
      "start": 575.97,
      "end": 583.89,
      "text": "패매 있고 다른 유튜버분들이나 인플런스 분들도"
    },
    {
      "start": 583.89,
      "end": 588.29,
      "text": "최대 상금 1억 원 9억 원 5,000만 원 8원 하고 하는데"
    },
    {
      "start": 588.29,
      "end": 593.25,
      "text": "실제 지급 상금은 금액은 절대 1억."
    },
    {
      "start": 593.25,
      "end": 597.65,
      "text": "실제 지급 상금이 한 이 1000만 원에서 1000만 원같은 것 같아요."
    },
    {
      "start": 597.65,
      "end": 600.77,
      "text": "3,000won이 많으면서도 상금을 최대 1억까지 주겠다는"
    },
    {
      "start": 600.77,
      "end": 614.52,
      "text": "3회가 없어서 그래서 뭐 대회는 늘 뜻이만 좋습니다."
    },
    {
      "start": 614.52,
      "end": 619.26,
      "text": "그리고 지금 이제 오케X 공식 대회도 하고 있거든요."
    },
    {
      "start": 619.26,
      "end": 624.48,
      "text": "제가 이번에는 정말로 리딩을 정말 열심히 했어요."
    },
    {
      "start": 624.48,
      "end": 631.18,
      "text": "물론 제 리딩을 보고 같이 따라 살아 팔아 이런 요돈은 아니었고"
    },
    {
      "start": 631.18,
      "end": 635.8,
      "text": "지금 나는 이렇게 간점을 보고 있다는 공유의 목적이었고"
    },
    {
      "start": 635.8,
      "end": 641.3,
      "text": "그러니까 정보의 공유 지식의 공유, 지식의 전날 이런 목적이었죠."
    },
    {
      "start": 641.3,
      "end": 645.3,
      "text": "이 시간에 내가 생각하는 적 없으면 어떤 고민을 하고 있을까"
    },
    {
      "start": 645.3,
      "end": 650.04,
      "text": "어떻게 시장을 바라볼까를 실시간으로 동시에 알 수 있으니까 좋은 거죠."
    },
    {
      "start": 650.04,
      "end": 659.12,
      "text": "그래서 이제 텔레그램 방통에서 이렇게 추가 상금도 걸었구나 이렇게 하고 있는데"
    },
    {
      "start": 659.12,
      "end": 665.34,
      "text": "지금까지 아마 아웃범인가 열 번인가를 타점을 공유를 했고"
    },
    {
      "start": 665.34,
      "end": 670.9,
      "text": "전부 다 손실란 맵는 없었습니다."
    },
    {
      "start": 670.9,
      "end": 672.9,
      "text": "전부 시이 남맵이었어요."
    },
    {
      "start": 672.9,
      "end": 680.32,
      "text": "그러니까 열 번에 맵을 연속 수익이라고 하면은 정말 괜찮은 반입이셔요."
    },
    {
      "start": 680.32,
      "end": 687.74,
      "text": "사실 제 팀의 나오는 밴입이 근처 최고인 것 같아요."
    },
    {
      "start": 687.74,
      "end": 691.54,
      "text": "물론 우승상금을 앵분에 내서 나눠갔는다."
    },
    {
      "start": 691.54,
      "end": 703.91,
      "text": "라는 좋은 취지도 있지만, 나는 이렇게 제가 맵에 사점을 공유해드리는 게 참 좋은 것 같습니다."
    },
    {
      "start": 703.91,
      "end": 708.81,
      "text": "그리고 이제 분석을 넘어 가겠습니다."
    },
    {
      "start": 708.87,
      "end": 717.05,
      "text": "근데 이제 오늘 하나 분석하기 전에 강조 드리고 싶은 점은 진한 분석이 틀렸어요 제가"
    },
    {
      "start": 718.05,
      "end": 728.03,
      "text": "진한 분석에 틀렸는데 여기를 이렇게 엔딩으로 보고 여기에 쇼 들어 가서"
    },
    {
      "start": 728.03,
      "end": 732.49,
      "text": "이제 빠질 거를 예상으로 쇼 들어 가겠다고 했는데"
    },
    {
      "start": 733.61,
      "end": 736.33,
      "text": "분석이 틀렸습니다."
    },
    {
      "start": 736.33,
      "end": 741.48,
      "text": "하지만 도는 벌었습니다."
    },
    {
      "start": 741.68,
      "end": 743.64,
      "text": "그래서 드리고 싶은 말씀이 있는데,"
    },
    {
      "start": 743.64,
      "end": 748.8,
      "text": "그리고 나니까 이제 안 좋은 투에 댓글이 두 개가 달렸어요."
    },
    {
      "start": 748.8,
      "end": 754.2,
      "text": "사실 진짜 뭐 100개 댓글 중에서 안 좋은 댓글 두 개면 많이 달린 건 아니오 진짜."
    },
    {
      "start": 754.2,
      "end": 757.18,
      "text": "저는 악플에 안 달린 편인데."
    },
    {
      "start": 757.18,
      "end": 759.52,
      "text": "또 틀렸는 분석이,"
    },
    {
      "start": 759.52,
      "end": 762.48,
      "text": "얘는 어떻게 볼 때가 다 매번 틀리냐 이런,"
    },
    {
      "start": 762.48,
      "end": 768.16,
      "text": "약간의 실망간, 나쁘게 편한 비하니, 그냥 댓글이 없는데."
    },
    {
      "start": 768.16,
      "end": 770.2,
      "text": "매번 틀리지는 않습니다."
    },
    {
      "start": 770.2,
      "end": 774.92,
      "text": "왜냐하면 매번 틀리면 시청자들을 바보가 아니기 때문에"
    },
    {
      "start": 774.92,
      "end": 778.08,
      "text": "방송을 불리겠고요."
    },
    {
      "start": 778.08,
      "end": 782.32,
      "text": "매번 틀리면 저 계속 손해보는데 어떻게 하겠어요."
    },
    {
      "start": 782.32,
      "end": 784.84,
      "text": "이번 날도 있다가도 수 인정할 거지만"
    },
    {
      "start": 785.84,
      "end": 788.28,
      "text": "그러가적으로는 벌었습니다."
    },
    {
      "start": 788.28,
      "end": 791.88,
      "text": "그렇고, 근데 당부하고 싶은 말씀은"
    },
    {
      "start": 792.88,
      "end": 796.96,
      "text": "이게 롱이냐, 소신냐, 홀자, 맞추기 게임이 아니에요."
    },
    {
      "start": 796.96,
      "end": 800.24,
      "text": "초보 분들, 지금 제 방송을 보시는 분들은"
    },
    {
      "start": 800.24,
      "end": 802.6,
      "text": "저에게 뭐 또 멋있는 적, 가호 잡고,"
    },
    {
      "start": 802.6,
      "end": 804.64,
      "text": "뭐 대단 척 하려고 하네."
    },
    {
      "start": 804.64,
      "end": 806.24,
      "text": "라고 이제 좀,"
    },
    {
      "start": 806.24,
      "end": 807.48,
      "text": "좀,"
    },
    {
      "start": 807.48,
      "end": 809.92,
      "text": "아니 그렇게 보실 수 있는데,"
    },
    {
      "start": 809.92,
      "end": 811.64,
      "text": "진짜 홀장 맞추기가 아니에요."
    },
    {
      "start": 811.64,
      "end": 815.4,
      "text": "이게 홀자그를 맞춰도 오히려 돈을 못 본 경우가 있고"
    },
    {
      "start": 815.4,
      "end": 817.84,
      "text": "틀려도 돈을 벌 수도 있거든요."
    },
    {
      "start": 817.84,
      "end": 821.32,
      "text": "그래서 제가 하고 싶은 점은 뭐냐면"
    },
    {
      "start": 821.32,
      "end": 824.56,
      "text": "분석을 맞춰서 여기서 위로 간다, 아래로 간다,"
    },
    {
      "start": 824.56,
      "end": 827.64,
      "text": "또 물론 하는 거지만 중요한 점은"
    },
    {
      "start": 827.64,
      "end": 832.92,
      "text": "내가 어떤 금벌으로 분석을 정확하게 해서"
    },
    {
      "start": 832.92,
      "end": 834.64,
      "text": "손절라인을 명확하게 잡고"
    },
    {
      "start": 834.64,
      "end": 836.2,
      "text": "이쪽 가격을 명확하게 잡고,"
    },
    {
      "start": 836.2,
      "end": 837.92,
      "text": "손이 빌 세팅하고,"
    },
    {
      "start": 837.92,
      "end": 841.32,
      "text": "황률을 높은 확률으로 진입을 해서"
    },
    {
      "start": 841.32,
      "end": 842.8,
      "text": "안정적으로 벌어보겠다."
    },
    {
      "start": 842.8,
      "end": 845.8,
      "text": "만약에 저도 이제 분석을 틀리면 손실에 날 수 있죠."
    },
    {
      "start": 845.8,
      "end": 849.72,
      "text": "있지만 손실 나는 횟수를 최대한 줄이고"
    },
    {
      "start": 849.72,
      "end": 852.32,
      "text": "손실이 나는 금액을 최대한 줄이고"
    },
    {
      "start": 852.32,
      "end": 855.4,
      "text": "반대로 수익라는 횟수를 가장 늘리고"
    },
    {
      "start": 855.4,
      "end": 857.28,
      "text": "수익 볼 때 많이 벌고,"
    },
    {
      "start": 857.28,
      "end": 860.08,
      "text": "라는 이제 전략을 베이스로 해서"
    },
    {
      "start": 860.08,
      "end": 863.24,
      "text": "어떻게 하면 맞는 전략을 구사할까였고,"
    },
    {
      "start": 863.24,
      "end": 864.72,
      "text": "그래서 그 정도로 지난 분석에서"
    },
    {
      "start": 864.72,
      "end": 869.12,
      "text": "는 여기 찍고 떨어질 거라고 분석을 했습니다만."
    },
    {
      "start": 869.12,
      "end": 871.92,
      "text": "그리고 저는 여기서 쇼트러 가겠다고 말씀드리고"
    },
    {
      "start": 871.92,
      "end": 875.68,
      "text": "쇼트러 가지만 결국에는 돈을 벌었어요."
    },
    {
      "start": 875.68,
      "end": 879.12,
      "text": "왜냐하면 이 엔딩 하단 라인에서"
    },
    {
      "start": 879.12,
      "end": 884.62,
      "text": "반입절을 했고 다시 올라갔을 때"
    },
    {
      "start": 884.62,
      "end": 887.62,
      "text": "약손절을 했습니다."
    },
    {
      "start": 887.62,
      "end": 889.62,
      "text": "약손절을 해서"
    },
    {
      "start": 889.62,
      "end": 892.02,
      "text": "결과도 그런 걸 벌었어요."
    },
    {
      "start": 892.02,
      "end": 893.5,
      "text": "이 맨만보아도,"
    },
    {
      "start": 893.5,
      "end": 912.77,
      "text": "이런 거 저거 이 맨만보아도"
    },
    {
      "start": 912.77,
      "end": 913.97,
      "text": "딱 하고 싶은 말인데,"
    },
    {
      "start": 913.97,
      "end": 915.09,
      "text": "이따 할게요."
    },
    {
      "start": 915.09,
      "end": 919.37,
      "text": "채팅 이상이 올라왔을 때가 제일 맛있으면 될게요."
    },
    {
      "start": 919.37,
      "end": 924.7,
      "text": "아..."
    },
    {
      "start": 924.7,
      "end": 925.46,
      "text": "그래서"
    },
    {
      "start": 925.46,
      "end": 927.9,
      "text": "어머..."
    },
    {
      "start": 927.9,
      "end": 930.86,
      "text": "근데 이 자리가 만약에 다시 온다 하더라도"
    },
    {
      "start": 930.86,
      "end": 933.66,
      "text": "저는 쇼트러 갈 거예요."
    },
    {
      "start": 933.66,
      "end": 937.1,
      "text": "저는 이제 분석이 틀리고 선저를 나가면"
    },
    {
      "start": 937.1,
      "end": 939.82,
      "text": "물론 선저를 안 나오 수익으로 봤지만"
    },
    {
      "start": 939.82,
      "end": 941.26,
      "text": "어쨌든 그런 경우가 울면은"
    },
    {
      "start": 941.26,
      "end": 942.26,
      "text": "생각을 해봐요."
    },
    {
      "start": 942.26,
      "end": 944.34,
      "text": "맨만보았기 잘 못 된 것인가?"
    },
    {
      "start": 944.34,
      "end": 947.18,
      "text": "아니면 분석은 맞았는데"
    },
    {
      "start": 947.18,
      "end": 950.54,
      "text": "맨만보았기 잘 못된 것인가?"
    },
    {
      "start": 950.54,
      "end": 954.3,
      "text": "같은 상황이 오더라도 같은 분석을 할 것인가?"
    },
    {
      "start": 954.3,
      "end": 956.06,
      "text": "같은 맨만보았기,"
    },
    {
      "start": 956.06,
      "end": 958.98,
      "text": "제가 생각하는 것인가를 생각하는 것인가?"
    },
    {
      "start": 958.98,
      "end": 964.62,
      "text": "이 자리는 그때 제가 방송에서 분명히 말씀드렸지만"
    },
    {
      "start": 964.62,
      "end": 969.22,
      "text": "선저를 하게 될 때더라도 들어갈 자리다라고 말씀을 드렸어요."
    },
    {
      "start": 969.22,
      "end": 971.46,
      "text": "왜냐하면"
    },
    {
      "start": 971.46,
      "end": 973.66,
      "text": "선저라이 너무 영화까지는 상당 트렌드라이,"
    },
    {
      "start": 973.66,
      "end": 975.26,
      "text": "선저를 되게 짧지 않아."
    },
    {
      "start": 975.26,
      "end": 976.54,
      "text": "선저를 음악큼만 하면 되는데"
    },
    {
      "start": 976.54,
      "end": 979.78,
      "text": "요 선저를 가고 하고 들어가야죠."
    },
    {
      "start": 979.78,
      "end": 981.9,
      "text": "수익 보면 반이 쪄려기서"
    },
    {
      "start": 981.9,
      "end": 985.1,
      "text": "완전히 여기 살건데."
    },
    {
      "start": 985.1,
      "end": 987.66,
      "text": "그러면 수익은 이만큼 볼 수 있는 기회가 있고"
    },
    {
      "start": 987.66,
      "end": 991.74,
      "text": "소년 유만큼 볼 수 있는 데 충분히 들어가할 만 하잖아요."
    },
    {
      "start": 991.74,
      "end": 993.1,
      "text": "확률적으로 괜찮고."
    },
    {
      "start": 993.1,
      "end": 996.06,
      "text": "이 전에도 계속 외찌들이 나왔었고"
    },
    {
      "start": 996.06,
      "end": 1000.86,
      "text": "외찌 나올 때마다 들어왔던 수 탓점이 계속 선공을 했었고"
    },
    {
      "start": 1000.86,
      "end": 1005.61,
      "text": "여기서도 쪘러 가서"
    },
    {
      "start": 1005.61,
      "end": 1010.91,
      "text": "여기서 입절했었죠."
    },
    {
      "start": 1010.91,
      "end": 1013.55,
      "text": "이때도 선공을 했고"
    },
    {
      "start": 1013.55,
      "end": 1020.78,
      "text": "다음에 여기에서도 외찌를 부어서"
    },
    {
      "start": 1020.78,
      "end": 1023.02,
      "text": "여기서 쇼셔도 돼서"
    },
    {
      "start": 1023.02,
      "end": 1024.82,
      "text": "선공을 했죠."
    },
    {
      "start": 1024.82,
      "end": 1031.0,
      "text": "여기서도 여기서 입절을 하였고"
    },
    {
      "start": 1031.0,
      "end": 1032.68,
      "text": "이번에도 여기서 들어와서"
    },
    {
      "start": 1032.68,
      "end": 1034.92,
      "text": "여기서 입절을 할 계획이였어요."
    },
    {
      "start": 1034.92,
      "end": 1037.92,
      "text": "하지만 분석이 틀릴 때도 있고"
    },
    {
      "start": 1037.92,
      "end": 1040.44,
      "text": "계획들은 안 들 때도 있는데"
    },
    {
      "start": 1040.44,
      "end": 1041.96,
      "text": "손해를 가고를 해야죠."
    },
    {
      "start": 1041.96,
      "end": 1043.88,
      "text": "이때도 그럼 손해를 가고 아느냐"
    },
    {
      "start": 1043.88,
      "end": 1044.4,
      "text": "했죠."
    },
    {
      "start": 1044.4,
      "end": 1047.0,
      "text": "여기 상당 라인 돌리면 선저 채워야죠."
    },
    {
      "start": 1047.0,
      "end": 1049.84,
      "text": "이때도 선 해볼 가고라느냐"
    },
    {
      "start": 1049.84,
      "end": 1052.44,
      "text": "라고 생각하고 했습니다."
    },
    {
      "start": 1052.44,
      "end": 1054.68,
      "text": "하고 하고 들어갑니다."
    },
    {
      "start": 1054.68,
      "end": 1057.88,
      "text": "이번에도 손해볼 가고 들어갔는데"
    },
    {
      "start": 1057.88,
      "end": 1060.16,
      "text": "하던 라인까지 떨어져서"
    },
    {
      "start": 1060.16,
      "end": 1061.68,
      "text": "정확히 얘기하면 반 입절 안했고"
    },
    {
      "start": 1061.68,
      "end": 1063.16,
      "text": "욕심 맨날 대학이 아니라"
    },
    {
      "start": 1063.16,
      "end": 1064.52,
      "text": "3분의 일 잊어냈어요."
    },
    {
      "start": 1064.52,
      "end": 1067.8,
      "text": "그리고 여기서 약 손절을 했으면 불구하고"
    },
    {
      "start": 1067.8,
      "end": 1069.48,
      "text": "3분의 일을 손절하고"
    },
    {
      "start": 1069.48,
      "end": 1071.72,
      "text": "3분의 일을 잊어냈으면 불구하고"
    },
    {
      "start": 1071.72,
      "end": 1072.76,
      "text": "수익으로 끝났습니다."
    },
    {
      "start": 1072.76,
      "end": 1082.42,
      "text": "이매면"
    },
    {
      "start": 1082.42,
      "end": 1085.82,
      "text": "그래서 너무 분석이"
    },
    {
      "start": 1085.82,
      "end": 1089.86,
      "text": "제가 분석을 보고 공부하시는 건 좋은데"
    },
    {
      "start": 1089.86,
      "end": 1091.86,
      "text": "아 외영남의 로미를"
    },
    {
      "start": 1091.86,
      "end": 1096.22,
      "text": "그냥 무지성으로 타자 소시를 쇼타자 이렇게 하시면 안 돼요."
    },
    {
      "start": 1097.18,
      "end": 1098.62,
      "text": "그리고 분명 말씀드렸는데"
    },
    {
      "start": 1098.62,
      "end": 1103.18,
      "text": "여기 돌리는 순간 상방 오버시팅 나올 거라고 말씀드렸고"
    },
    {
      "start": 1103.18,
      "end": 1105.98,
      "text": "이 상방 오버시팅이 나오는 게"
    },
    {
      "start": 1105.98,
      "end": 1106.94,
      "text": "주주주 줄 갈게 아니야."
    },
    {
      "start": 1106.94,
      "end": 1109.9,
      "text": "올라갔다가 떨어질 거라고 말씀드렸잖아요."
    },
    {
      "start": 1109.9,
      "end": 1113.46,
      "text": "에비시 나오고 떨어질 거라"
    },
    {
      "start": 1113.46,
      "end": 1115.86,
      "text": "고 좀 못 넘길 거라."
    },
    {
      "start": 1115.86,
      "end": 1119.98,
      "text": "근데 올라갔다 다시 내려오게 되었습니다."
    },
    {
      "start": 1119.98,
      "end": 1122.98,
      "text": "그래서 물론 여기서 쇼스를 타셨고"
    },
    {
      "start": 1122.98,
      "end": 1125.62,
      "text": "이 쇼타처럼은"
    },
    {
      "start": 1125.62,
      "end": 1127.3,
      "text": "대방인 공개했잖아요."
    },
    {
      "start": 1127.3,
      "end": 1131.1,
      "text": "쇼트로 갈 거다 알아서 계획을 했다는 걸 공개했고"
    },
    {
      "start": 1131.1,
      "end": 1133.46,
      "text": "진입하며 진입했다고 얘기하고"
    },
    {
      "start": 1133.46,
      "end": 1136.42,
      "text": "반입죠 아 나 완익을 빨리 했구나"
    },
    {
      "start": 1136.42,
      "end": 1137.74,
      "text": "완익을 여기서 했어요."
    },
    {
      "start": 1137.74,
      "end": 1139.86,
      "text": "이쪽은 빨리 했습니다."
    },
    {
      "start": 1139.86,
      "end": 1141.86,
      "text": "왜냐하면 있다 말씀드릴 건데"
    },
    {
      "start": 1141.86,
      "end": 1146.66,
      "text": "이제 외찌 이로가 한 번도 올라갈 가능성이 있었거든요."
    },
    {
      "start": 1146.66,
      "end": 1149.56,
      "text": "이렇게 보시면"
    },
    {
      "start": 1149.56,
      "end": 1151.0,
      "text": "여기가"
    },
    {
      "start": 1151.0,
      "end": 1153.8,
      "text": "한 번도 올라가 줄 수 있다 떨어질 수도 있고"
    },
    {
      "start": 1153.8,
      "end": 1156.36,
      "text": "아니면 이대로 빠질 수도 있고"
    },
    {
      "start": 1156.36,
      "end": 1159.28,
      "text": "여기서 온 게 오다 확률이 그쵸 반 반이다."
    },
    {
      "start": 1159.28,
      "end": 1161.64,
      "text": "그래서 반반이면 들고 스피러 없다."
    },
    {
      "start": 1161.64,
      "end": 1163.76,
      "text": "이 좋은 자리 중에 다시 들어가자"
    },
    {
      "start": 1163.76,
      "end": 1169.82,
      "text": "여기는 일단 내리사에서 내렸고"
    },
    {
      "start": 1169.82,
      "end": 1171.02,
      "text": "아무튼"
    },
    {
      "start": 1171.02,
      "end": 1185.56,
      "text": "그러고 나서 이제"
    },
    {
      "start": 1185.56,
      "end": 1188.28,
      "text": "그러고 나서 이제 버터 맵을 했는데"
    },
    {
      "start": 1188.28,
      "end": 1189.88,
      "text": "최근에 저도 이제"
    },
    {
      "start": 1189.88,
      "end": 1190.72,
      "text": "놀랐어요."
    },
    {
      "start": 1190.72,
      "end": 1191.6,
      "text": "최근에"
    },
    {
      "start": 1191.6,
      "end": 1193.6,
      "text": "밥돈이"
    },
    {
      "start": 1193.6,
      "end": 1196.28,
      "text": "맵을 엄청 열심히 했더라고요 이거 보세요."
    },
    {
      "start": 1196.28,
      "end": 1198.16,
      "text": "진짜 열심히 했더라고요."
    },
    {
      "start": 1198.16,
      "end": 1199.76,
      "text": "그다음에"
    },
    {
      "start": 1199.76,
      "end": 1201.44,
      "text": "그"
    },
    {
      "start": 1201.44,
      "end": 1203.96,
      "text": "이제 이런 말씀을 드리고 싶어요."
    },
    {
      "start": 1203.96,
      "end": 1205.68,
      "text": "한 좀 전에"
    },
    {
      "start": 1205.68,
      "end": 1223.01,
      "text": "누가 무슨 댓글 다릈냐면"
    },
    {
      "start": 1223.01,
      "end": 1225.62,
      "text": "귀엽다"
    },
    {
      "start": 1225.62,
      "end": 1227.78,
      "text": "마자 쓸 때 분석이 맞죠?"
    },
    {
      "start": 1227.78,
      "end": 1229.86,
      "text": "이러고 틀렸을 때 분석한 틀렸지만"
    },
    {
      "start": 1229.86,
      "end": 1231.22,
      "text": "대형에서 둔 버렸으면"
    },
    {
      "start": 1231.22,
      "end": 1234.02,
      "text": "여러분도 공부하세요."
    },
    {
      "start": 1234.02,
      "end": 1236.18,
      "text": "이게 뭐?"
    },
    {
      "start": 1236.18,
      "end": 1239.39,
      "text": "비기 비포는 못가?"
    },
    {
      "start": 1239.39,
      "end": 1243.15,
      "text": "비포는 걸로 다 신고 나이겠는데"
    },
    {
      "start": 1248.66,
      "end": 1251.3,
      "text": "그러면 대박소 왜 봐요?"
    },
    {
      "start": 1251.3,
      "end": 1253.38,
      "text": "보지 마세요."
    },
    {
      "start": 1253.38,
      "end": 1254.58,
      "text": "그리고"
    },
    {
      "start": 1254.58,
      "end": 1256.5,
      "text": "이제 범계 나야 라는 분이"
    },
    {
      "start": 1256.5,
      "end": 1258.1,
      "text": "실시간 맵에 안 하는 사람은"
    },
    {
      "start": 1258.1,
      "end": 1260.1,
      "text": "일단 걸는 게 맞다."
    },
    {
      "start": 1260.1,
      "end": 1261.46,
      "text": "라고 하셨는데"
    },
    {
      "start": 1261.46,
      "end": 1262.58,
      "text": "아 나 칼 수 시켜는데"
    },
    {
      "start": 1262.58,
      "end": 1264.66,
      "text": "칼국수 왔다."
    },
    {
      "start": 1264.66,
      "end": 1266.58,
      "text": "오늘 방송 짧게 해야겠네."
    },
    {
      "start": 1266.58,
      "end": 1268.02,
      "text": "칼국수는 면이 뿐이크가"
    },
    {
      "start": 1268.02,
      "end": 1269.22,
      "text": "안 돼요 밥이었으면"
    },
    {
      "start": 1269.22,
      "end": 1272.34,
      "text": "딱다가 천천히 먹을 텐데"
    },
    {
      "start": 1272.34,
      "end": 1290.59,
      "text": "잠깐만요."
    },
    {
      "start": 1290.59,
      "end": 1292.43,
      "text": "아무튼"
    },
    {
      "start": 1292.43,
      "end": 1295.07,
      "text": "실시간 맵으면 안 하는 사람 일단 걸는 게 맞다."
    },
    {
      "start": 1295.07,
      "end": 1297.63,
      "text": "그래서 이게 무슨 논리인가 했더니"
    },
    {
      "start": 1297.63,
      "end": 1298.91,
      "text": "아 나"
    },
    {
      "start": 1298.91,
      "end": 1300.27,
      "text": "지난번에도"
    },
    {
      "start": 1300.27,
      "end": 1303.07,
      "text": "누가 이중전투네 댓글라 다라는데 이런 댓글였어요."
    },
    {
      "start": 1303.07,
      "end": 1305.07,
      "text": "정확한 단어는"
    },
    {
      "start": 1305.07,
      "end": 1306.11,
      "text": "기억이 안 난다."
    },
    {
      "start": 1306.11,
      "end": 1326.22,
      "text": "보수가요 댓글을"
    },
    {
      "start": 1326.22,
      "end": 1327.5,
      "text": "제 최근에 댓글에 그것을"
    },
    {
      "start": 1327.5,
      "end": 1329.18,
      "text": "영상 올릴 때마다 틀리네"
    },
    {
      "start": 1329.18,
      "end": 1331.9,
      "text": "오른다 하면 내고 내린다 모르고"
    },
    {
      "start": 1331.9,
      "end": 1335.66,
      "text": "제가 싫어했다고 불렀습니다."
    },
    {
      "start": 1335.66,
      "end": 1337.18,
      "text": "싫어 눌렀습니다."
    },
    {
      "start": 1337.18,
      "end": 1339.42,
      "text": "그래서 이렇게 답변 드렸습니다."
    },
    {
      "start": 1339.42,
      "end": 1342.22,
      "text": "어제 분석 틀려서 미안하고 유람입니다."
    },
    {
      "start": 1342.22,
      "end": 1343.98,
      "text": "하지만 단순히 오르고 내린다는"
    },
    {
      "start": 1343.98,
      "end": 1345.58,
      "text": "그렇게 현혹되지 마시고"
    },
    {
      "start": 1345.58,
      "end": 1347.26,
      "text": "어떤 근거를 통해 결과를"
    },
    {
      "start": 1347.26,
      "end": 1349.42,
      "text": "합리적으로 도착할는지"
    },
    {
      "start": 1349.42,
      "end": 1352.7,
      "text": "사고가 정한 보수가는 추측하는 방송입니다."
    },
    {
      "start": 1352.7,
      "end": 1355.5,
      "text": "자 이렇게 해놨으면 드렸고요."
    },
    {
      "start": 1355.5,
      "end": 1359.34,
      "text": "다음에 최근에 되게 깊은 댓글에 달렸어요."
    },
    {
      "start": 1359.34,
      "end": 1360.94,
      "text": "3년 전에 깡통차고 오랫는데"
    },
    {
      "start": 1360.94,
      "end": 1363.02,
      "text": "덕분에 다 복구하고 결혼합니다."
    },
    {
      "start": 1363.02,
      "end": 1364.62,
      "text": "정말 감사합니다."
    },
    {
      "start": 1364.62,
      "end": 1367.26,
      "text": "돈도 보셨고 결혼도 하시고"
    },
    {
      "start": 1367.26,
      "end": 1368.78,
      "text": "너무 부럽더라고요."
    },
    {
      "start": 1368.78,
      "end": 1371.98,
      "text": "그래서 이렇게 정말 축하합니다."
    },
    {
      "start": 1371.98,
      "end": 1374.22,
      "text": "댓글 제가 댓글에 잘 되댔 끌아앉으니"
    },
    {
      "start": 1374.22,
      "end": 1378.46,
      "text": "남겼더니 채팅방에서 카톡방에서"
    },
    {
      "start": 1378.46,
      "end": 1381.58,
      "text": "어 엉남 형님이 나 결혼한다는"
    },
    {
      "start": 1381.58,
      "end": 1382.7,
      "text": "좋아해 눌러졌다."
    },
    {
      "start": 1382.7,
      "end": 1384.54,
      "text": "그래서 이분이 얻던 이분이라 하시더라고요."
    },
    {
      "start": 1384.54,
      "end": 1386.94,
      "text": "그래서 올해 10월인가 11월인가"
    },
    {
      "start": 1386.94,
      "end": 1389.18,
      "text": "다음 달인가 바람다리 결혼하시는데요."
    },
    {
      "start": 1389.18,
      "end": 1399.73,
      "text": "너무 축하드립니다."
    },
    {
      "start": 1399.73,
      "end": 1401.97,
      "text": "자 다음에 제가 드렁 마지막이에요."
    },
    {
      "start": 1401.97,
      "end": 1403.97,
      "text": "다른 유튜버처럼 실시간으로"
    },
    {
      "start": 1403.97,
      "end": 1405.73,
      "text": "맨날 해야 실내를 하지"
    },
    {
      "start": 1405.73,
      "end": 1411.54,
      "text": "이분 아마 다른 유튜버에 부계정이지 않을까 싶어요."
    },
    {
      "start": 1411.54,
      "end": 1413.38,
      "text": "맨지."
    },
    {
      "start": 1413.38,
      "end": 1416.26,
      "text": "다른 유튜버처럼 실시간을 맨날 해야 실내를 하지"
    },
    {
      "start": 1416.26,
      "end": 1418.82,
      "text": "뒤로 양방처서 손실을 안 보겠지만"
    },
    {
      "start": 1418.82,
      "end": 1423.3,
      "text": "최소한 니 그 잘한 채는 안 벗어도 되니까."
    },
    {
      "start": 1423.3,
      "end": 1427.22,
      "text": "제 방송 몸이 잘한 채 로 보였다 봅니다."
    },
    {
      "start": 1427.22,
      "end": 1429.46,
      "text": "일단 요감이고 일단"
    },
    {
      "start": 1429.46,
      "end": 1433.78,
      "text": "네 이건 그냥 진짜 간단한 지능인데"
    },
    {
      "start": 1433.78,
      "end": 1437.54,
      "text": "맨날 탓점이 다 남아요."
    },
    {
      "start": 1437.54,
      "end": 1439.3,
      "text": "그래서 양방을 치수가 없어요."
    },
    {
      "start": 1439.3,
      "end": 1441.22,
      "text": "그러니까 저분에 놀리는 뭐냐면"
    },
    {
      "start": 1441.22,
      "end": 1444.82,
      "text": "방송에서 뭐 보이는 거 롱이나 소 아공건 아치고"
    },
    {
      "start": 1444.82,
      "end": 1446.82,
      "text": "롱 하나 치고"
    },
    {
      "start": 1446.82,
      "end": 1449.94,
      "text": "다음에 해칑용을 소스를 치면"
    },
    {
      "start": 1449.94,
      "end": 1452.9,
      "text": "그러면 이제 롱 쇼치면 이제 손에가 또 이 도이잖아요."
    },
    {
      "start": 1452.9,
      "end": 1455.3,
      "text": "수익도 손에도 없잖아요."
    },
    {
      "start": 1455.3,
      "end": 1457.86,
      "text": "그러고 나서 포지션을 다고 다 되면"
    },
    {
      "start": 1457.86,
      "end": 1459.62,
      "text": "손에도 실도 없다."
    },
    {
      "start": 1459.62,
      "end": 1461.62,
      "text": "하지만 방송 명수의 긴가 있다."
    },
    {
      "start": 1461.62,
      "end": 1465.3,
      "text": "그래서 방송을 한 사람들은 라이브에만 하면"
    },
    {
      "start": 1465.3,
      "end": 1467.94,
      "text": "탓큰이다 라고 하는데"
    },
    {
      "start": 1467.94,
      "end": 1470.82,
      "text": "저거는"
    },
    {
      "start": 1470.82,
      "end": 1480.24,
      "text": "이게"
    },
    {
      "start": 1480.24,
      "end": 1482.88,
      "text": "아 석션이 얘기하고 싶네 석션 얘기 못했고"
    },
    {
      "start": 1482.88,
      "end": 1486.88,
      "text": "아 석션 얘기할 때 그냥 지능이 낮은 거예요."
    },
    {
      "start": 1486.88,
      "end": 1488.96,
      "text": "그냥 라이브 방송을 하면서"
    },
    {
      "start": 1488.96,
      "end": 1492.08,
      "text": "핸드폰으로 반대포션 잡으면 되거든요."
    },
    {
      "start": 1492.08,
      "end": 1493.68,
      "text": "아니면 주을 모였어 쓰면서"
    },
    {
      "start": 1493.68,
      "end": 1497.52,
      "text": "라이브 방송을 하더라도 핵징을 가능하다."
    },
    {
      "start": 1497.52,
      "end": 1499.84,
      "text": "그렇죠? 그리고"
    },
    {
      "start": 1499.84,
      "end": 1502.16,
      "text": "수인단 계정만 보준다면"
    },
    {
      "start": 1502.16,
      "end": 1505.52,
      "text": "지난번 인증하고 인증 내 여기 달라져야죠."
    },
    {
      "start": 1505.52,
      "end": 1509.36,
      "text": "연속해서 계속 다 모든 내면에 내하고 인증을 하는데"
    },
    {
      "start": 1509.36,
      "end": 1511.68,
      "text": "지난번에 분명 수익 받던데"
    },
    {
      "start": 1511.68,
      "end": 1515.44,
      "text": "다음에는 손으로 바뀌어 있고 해야죠."
    },
    {
      "start": 1515.44,
      "end": 1519.36,
      "text": "그러니까 연속성이 기록이 연속성이 나는 게 있을 수가 없어요."
    },
    {
      "start": 1519.36,
      "end": 1520.8,
      "text": "여기 탓자면 다 나나 있잖아요."
    },
    {
      "start": 1521.6,
      "end": 1524.64,
      "text": "한 계정만 가지고 내멸을 한다."
    },
    {
      "start": 1524.64,
      "end": 1526.64,
      "text": "한 계정만 가지고."
    },
    {
      "start": 1526.64,
      "end": 1531.04,
      "text": "아 맞다. 그래서 제가 비트곗때는"
    },
    {
      "start": 1531.04,
      "end": 1533.28,
      "text": "비트곗때는"
    },
    {
      "start": 1533.28,
      "end": 1536.56,
      "text": "방송 시작할 때 유아이디를 공개하고 시작했거든요."
    },
    {
      "start": 1536.56,
      "end": 1541.02,
      "text": "같은 유아이딘지 한 번 더 그래가지고."
    },
    {
      "start": 1541.02,
      "end": 1546.54,
      "text": "그런데 오케엑스 쓰고 나는 내 별로 그런 요청이 없어서"
    },
    {
      "start": 1546.54,
      "end": 1550.94,
      "text": "아무튼 뭐 그러고 지난 방송이 8월 23일 날 있었고"
    },
    {
      "start": 1550.94,
      "end": 1555.98,
      "text": "그때 쇼 들어가 아빠가 다니다고 아 3분에 일절하고"
    },
    {
      "start": 1555.98,
      "end": 1558.78,
      "text": "외치에서 약승도 침이 2거예요."
    },
    {
      "start": 1558.78,
      "end": 1561.02,
      "text": "이렇게 했고."
    },
    {
      "start": 1561.02,
      "end": 1563.9,
      "text": "그런데 최근에는 맵을 열심히 내 승률이 안 좋았어요."
    },
    {
      "start": 1563.9,
      "end": 1566.62,
      "text": "보시면 13만 달라 손을 나왕 같고"
    },
    {
      "start": 1566.62,
      "end": 1572.06,
      "text": "그리고 29만 번 것도 있고 또 승률이 안 좋죠."
    },
    {
      "start": 1572.06,
      "end": 1575.66,
      "text": "이렇게 해서 방송 키개 직전에 맵을 이제"
    },
    {
      "start": 1575.66,
      "end": 1580.38,
      "text": "닿으면 대략 35만 9천 5개 달라를 일주일 동안 벌었고"
    },
    {
      "start": 1580.38,
      "end": 1588.51,
      "text": "그냥 4억 9천 만원 정도 대략한 5억 정도 일주일 동안 수익이 있었습니다."
    },
    {
      "start": 1589.71,
      "end": 1595.23,
      "text": "이게 왜 이제 어차피 저는 요구를 먹어요."
    },
    {
      "start": 1595.23,
      "end": 1613.02,
      "text": "수익을 인젠하면 이런 요구를 먹습니다."
    },
    {
      "start": 1613.02,
      "end": 1616.86,
      "text": "최근 인젠가면 이런 요구를 먹어요."
    },
    {
      "start": 1616.86,
      "end": 1630.45,
      "text": "그리고 수익인지는 안 하면 이런 요구를 먹습니다."
    },
    {
      "start": 1630.45,
      "end": 1633.89,
      "text": "실력도 없는 게 주둥이로만 나를 내내 사기 끈."
    },
    {
      "start": 1633.89,
      "end": 1638.53,
      "text": "그래서 해도 형 먹고 아에도 응원한다."
    },
    {
      "start": 1638.53,
      "end": 1643.89,
      "text": "어차피 응원을 꺼면 실내는 주장에서 수익 인증을 하자 인거고"
    },
    {
      "start": 1643.89,
      "end": 1645.33,
      "text": "자랑을 하려고 하는 게 아니에요."
    },
    {
      "start": 1645.33,
      "end": 1649.09,
      "text": "실내를 주려고 솔직히하게 손에 남 것도 보여드리고"
    },
    {
      "start": 1649.09,
      "end": 1650.93,
      "text": "신난 것도 보여드리고."
    },
    {
      "start": 1650.93,
      "end": 1655.17,
      "text": "그리고 지카아대 계자로 없음을 하는 거고 계자로 오픈하는 거는"
    },
    {
      "start": 1655.17,
      "end": 1658.13,
      "text": "여러분들 친한 친구들한테 높은 하기 쉽지 않아요."
    },
    {
      "start": 1658.13,
      "end": 1660.85,
      "text": "진짜로 손에 수익이에요."
    },
    {
      "start": 1660.85,
      "end": 1663.09,
      "text": "왜냐하면 손에 봤을 때 너무 기분 나쁘거든요."
    },
    {
      "start": 1663.09,
      "end": 1667.57,
      "text": "그리고 수익 난거 얘기해봤자 자랑한다고 생각하고."
    },
    {
      "start": 1667.57,
      "end": 1672.93,
      "text": "그래서 친한 지인들이나 가족들한테 높은하기가 그리쉬운 건 아닌데."
    },
    {
      "start": 1672.93,
      "end": 1679.73,
      "text": "대중한테 공개하는 거는 많은 사람들이 자이로 피곤 꼼꼼하게 공개를 사안하기 때문에"
    },
    {
      "start": 1679.73,
      "end": 1682.53,
      "text": "공개를 하는 겁니다."
    },
    {
      "start": 1682.53,
      "end": 1687.09,
      "text": "그리고 그래서 너무 기분 나쁘게 보지 마시고."
    },
    {
      "start": 1687.81,
      "end": 1690.69,
      "text": "그리고 또 한 가지 들고 싶은 말씀은"
    },
    {
      "start": 1690.69,
      "end": 1693.73,
      "text": "자꾸 방송 끝나으면 댓글에"
    },
    {
      "start": 1693.73,
      "end": 1697.33,
      "text": "선환영영력 감사합니다라고 자꾸 댓글 다는데"
    },
    {
      "start": 1697.33,
      "end": 1700.05,
      "text": "아니 차트 분석 방송하는데 분선환영영력이에요."
    },
    {
      "start": 1700.05,
      "end": 1702.93,
      "text": "나 그렇게 자꾸 좋은 사람으로 뭘지 봐."
    },
    {
      "start": 1702.93,
      "end": 1707.25,
      "text": "제발 제발 좋은 사람으로 뭘지 봐."
    },
    {
      "start": 1707.25,
      "end": 1710.29,
      "text": "알았죠? 이미지 매킹하지 말라고."
    },
    {
      "start": 1710.29,
      "end": 1712.61,
      "text": "또께 좋은 사람 아니에요. 그냥 돈"
    },
    {
      "start": 1712.61,
      "end": 1716.45,
      "text": "맵을 잘하는 사람이야 나는 그냥."
    },
    {
      "start": 1716.45,
      "end": 1717.57,
      "text": "좋은 사람을 뭘지 마요."
    },
    {
      "start": 1717.57,
      "end": 1720.77,
      "text": "그 놈에 선환영영영 무슨 선환영영이 있어 내가"
    },
    {
      "start": 1720.77,
      "end": 1723.09,
      "text": "영향력도 없고 선하지도 않아."
    },
    {
      "start": 1723.09,
      "end": 1725.33,
      "text": "그러니까 뭘지 마 제발."
    },
    {
      "start": 1725.33,
      "end": 1726.93,
      "text": "알았죠?"
    },
    {
      "start": 1726.93,
      "end": 1731.06,
      "text": "네 분석을 넘어 하겠습니다."
    },
    {
      "start": 1731.06,
      "end": 1735.06,
      "text": "아무튼 지난 그래서 이제 복기를 하면은 중요한 타점은"
    },
    {
      "start": 1735.06,
      "end": 1736.5,
      "text": "두 개가 있었다."
    },
    {
      "start": 1736.5,
      "end": 1741.22,
      "text": "두 개가 있었는데 여기 셔타점이 있었고"
    },
    {
      "start": 1741.22,
      "end": 1743.54,
      "text": "외치에서 셔타점 있었고"
    },
    {
      "start": 1743.54,
      "end": 1749.46,
      "text": "반익을 당연히 외치라인 하단에서 한 번 했었어야 했고"
    },
    {
      "start": 1749.46,
      "end": 1752.58,
      "text": "그리고 제가 만약에 여기 넘기면 빠르게 위로 시팀"
    },
    {
      "start": 1752.58,
      "end": 1754.34,
      "text": "얇고 합다라고 말씀드렸잖아요."
    },
    {
      "start": 1754.34,
      "end": 1758.66,
      "text": "여기가 그래서 당연히 저도 선저를 했고 여기선"
    },
    {
      "start": 1758.66,
      "end": 1761.54,
      "text": "타점을 기다렸다가 여기에서"
    },
    {
      "start": 1761.54,
      "end": 1763.06,
      "text": "이제 셔타점으로 갔는데"
    },
    {
      "start": 1763.06,
      "end": 1768.91,
      "text": "이 타점을 참 좋은 타점이었던 것 같습니다."
    },
    {
      "start": 1768.91,
      "end": 1771.31,
      "text": "여기서 핸버가 있었고"
    },
    {
      "start": 1771.31,
      "end": 1774.75,
      "text": "한 번에 수라움이 왜"
    },
    {
      "start": 1774.75,
      "end": 1778.27,
      "text": "올라갔다가 고점 짧게 뚫고 떨어진다."
    },
    {
      "start": 1778.27,
      "end": 1782.11,
      "text": "는 게 늘 패턴과 공식이죠."
    },
    {
      "start": 1782.11,
      "end": 1784.03,
      "text": "그 공식대로 그대로 나왔고 그래서"
    },
    {
      "start": 1784.03,
      "end": 1787.07,
      "text": "텔레그램 방에서는 여기 수렘 중입니다."
    },
    {
      "start": 1787.07,
      "end": 1790.43,
      "text": "올라가면 짧게 올라갈 거고 짧게 올라갔을 때"
    },
    {
      "start": 1790.43,
      "end": 1791.95,
      "text": "셔쳐서"
    },
    {
      "start": 1791.95,
      "end": 1793.31,
      "text": "아저씨는 8 예정입니다."
    },
    {
      "start": 1793.31,
      "end": 1799.38,
      "text": "아저씨는 굉장히 안 됐었고 텔레그램에서는"
    },
    {
      "start": 1799.38,
      "end": 1800.98,
      "text": "여기가 괜찮은 타점이었어요."
    },
    {
      "start": 1800.98,
      "end": 1803.14,
      "text": "여기서 타점 들어와서 20명만 달라를"
    },
    {
      "start": 1803.14,
      "end": 1805.14,
      "text": "벌어서 정말 다인 거예요."
    },
    {
      "start": 1805.14,
      "end": 1807.54,
      "text": "타점 하나만 사먹을 걸 벌어서."
    },
    {
      "start": 1808.66,
      "end": 1817.71,
      "text": "이 맨명가 참 잘 됐던 맨명인 것 같습니다."
    },
    {
      "start": 1817.71,
      "end": 1820.19,
      "text": "그리고 지도면 참 고민이 많아요."
    },
    {
      "start": 1820.19,
      "end": 1823.55,
      "text": "어쨌든 에비씨 아 그리고 이제 여러분들이 지난 거지만"
    },
    {
      "start": 1823.55,
      "end": 1826.91,
      "text": "아저씨와서 얇게 이때 외치도 보셨어요."
    },
    {
      "start": 1826.91,
      "end": 1827.55,
      "text": "해요."
    },
    {
      "start": 1827.55,
      "end": 1828.91,
      "text": "별거죠."
    },
    {
      "start": 1829.55,
      "end": 1834.67,
      "text": "뭐 못 본 게 안 본 게 오히려 잘된 거긴 한데"
    },
    {
      "start": 1834.67,
      "end": 1836.35,
      "text": "왜냐하면 에비씨 완성됐으니까"
    },
    {
      "start": 1836.35,
      "end": 1837.63,
      "text": "쇼트러서 내려갈 거다."
    },
    {
      "start": 1837.63,
      "end": 1840.03,
      "text": "음, 씹 받고 외찔을 갔으면"
    },
    {
      "start": 1840.03,
      "end": 1842.35,
      "text": "여기서 쇼트랑 잊어를 했었어야 되니까."
    },
    {
      "start": 1842.35,
      "end": 1843.15,
      "text": "근데"
    },
    {
      "start": 1843.15,
      "end": 1846.91,
      "text": "외찔까지 보셨는 게 더"
    },
    {
      "start": 1847.39,
      "end": 1849.39,
      "text": "만약에 외찔가 나 수도 있으니까"
    },
    {
      "start": 1849.39,
      "end": 1853.55,
      "text": "우리는 공부한 차원에서 시아를 확장 하는 차원에서"
    },
    {
      "start": 1854.75,
      "end": 1858.75,
      "text": "여기 쇼트도 많이 올라오면 좋은 자리였다."
    },
    {
      "start": 1858.75,
      "end": 1861.47,
      "text": "올라오면 여기가 이렇게 올라오게 되면"
    },
    {
      "start": 1862.43,
      "end": 1865.07,
      "text": "여기서 아래 스타일과 이렇게 올라가거든요."
    },
    {
      "start": 1866.03,
      "end": 1868.67,
      "text": "그러면 다이번스가 이렇게 먹을 거예요."
    },
    {
      "start": 1868.67,
      "end": 1870.19,
      "text": "가격은 올라갔지만"
    },
    {
      "start": 1870.19,
      "end": 1873.47,
      "text": "아래 스타일 보조지표는 내려가면서"
    },
    {
      "start": 1873.47,
      "end": 1876.51,
      "text": "하나도 의미하자, 하락 다이버전스 라고 하죠."
    },
    {
      "start": 1876.51,
      "end": 1878.75,
      "text": "이렇게 될 거예요. 그래서"
    },
    {
      "start": 1878.75,
      "end": 1882.99,
      "text": "손질 라이브 명확하고 다이버전스 걸릴 거 명확하고"
    },
    {
      "start": 1882.99,
      "end": 1884.51,
      "text": "어,"
    },
    {
      "start": 1884.83,
      "end": 1887.47,
      "text": "에비씨 D volling 했지."
    },
    {
      "start": 1887.47,
      "end": 1888.67,
      "text": "괜찮은 탑점이었어."
    },
    {
      "start": 1888.67,
      "end": 1892.59,
      "text": "여기서 되게 패팅하려고 기대를 하고 있었는데"
    },
    {
      "start": 1892.59,
      "end": 1895.15,
      "text": "너무 좋은 자리에 그런지 못 자 않았습니다."
    },
    {
      "start": 1895.15,
      "end": 1898.35,
      "text": "그리고 여기는 에비씨가 완성됐다고 하기 위해"
    },
    {
      "start": 1898.35,
      "end": 1900.99,
      "text": "유독시파도 짧았어. 에이파도 위에 비해서."
    },
    {
      "start": 1900.99,
      "end": 1906.35,
      "text": "그래서 조금 한 번도 갈 수도 있지 않겠나라고 생각할 수도 있었을 것 같아요."
    },
    {
      "start": 1906.35,
      "end": 1909.23,
      "text": "제가 아니라 여러분 이라도"
    },
    {
      "start": 1909.63,
      "end": 1913.79,
      "text": "아무튼 디트코인에서는 외찔을 찾는 게"
    },
    {
      "start": 1913.79,
      "end": 1915.55,
      "text": "차다스에 하면 참 좋은 젤라이브가 되어있는 것 같아요."
    },
    {
      "start": 1915.55,
      "end": 1918.11,
      "text": "왜냐하면 늘 선저리 짧아."
    },
    {
      "start": 1918.11,
      "end": 1921.47,
      "text": "여기 들어가면 손질, 바로 미국 이쪽은 여기까지니까."
    },
    {
      "start": 1921.47,
      "end": 1925.31,
      "text": "저 외찔을 찾아 들어가는 램에가 참 특군에서는"
    },
    {
      "start": 1925.31,
      "end": 1928.11,
      "text": "유화한 것 같습니다."
    },
    {
      "start": 1928.11,
      "end": 1930.83,
      "text": "그리고 이제 고점치고 나서"
    },
    {
      "start": 1930.83,
      "end": 1937.73,
      "text": "제가 봤을 때는 여기서부터"
    },
    {
      "start": 1937.73,
      "end": 1940.77,
      "text": "여기까지가"
    },
    {
      "start": 1940.77,
      "end": 1944.37,
      "text": "하락 인팔 수 오프하동으로 빠졌다고 생각을 하거든요."
    },
    {
      "start": 1944.37,
      "end": 1947.41,
      "text": "그러니까 그 말은 인팔스로 빠졌으면"
    },
    {
      "start": 1947.41,
      "end": 1952.37,
      "text": "에비씨 반대에 대해서 다시 빠지 있는 그림이겠죠."
    },
    {
      "start": 1952.37,
      "end": 1956.29,
      "text": "그래서 실제로 여기에서 롱에 들어갔어요."
    },
    {
      "start": 1956.29,
      "end": 1962.82,
      "text": "롱에 들어갔습니다."
    },
    {
      "start": 1962.82,
      "end": 1967.14,
      "text": "근데 그래서 에비씨 나고도 좋은데 떨어질 때"
    },
    {
      "start": 1967.14,
      "end": 1969.62,
      "text": "인팔스가 아니지 여기 구간이."
    },
    {
      "start": 1969.62,
      "end": 1973.98,
      "text": "그래서 되게 고민이 많아요. 이거 뭐지."
    },
    {
      "start": 1973.98,
      "end": 1975.74,
      "text": "패걸린 상황입니다."
    },
    {
      "start": 1975.74,
      "end": 1980.53,
      "text": "지금 볼 수 있는 건"
    },
    {
      "start": 1980.53,
      "end": 1985.25,
      "text": "역시나 매트 이로 나오지 않을 것과 연장이."
    },
    {
      "start": 1985.25,
      "end": 1987.33,
      "text": "그러니까 이거를 일단 인팔스로 보는 이유는"
    },
    {
      "start": 1987.33,
      "end": 1990.77,
      "text": "추세가 세계예요. 잘 보세요."
    },
    {
      "start": 1990.77,
      "end": 1994.77,
      "text": "여러분들 이거 제가 늘 이제 컴퓨트 힘든 추세 로고라고 했잖아요."
    },
    {
      "start": 1994.77,
      "end": 2000.29,
      "text": "인팔스인지 볼 때는 추세가 세 개가 나오면 인팔스인데"
    },
    {
      "start": 2000.29,
      "end": 2002.77,
      "text": "이렇게 이렇게 이렇게 떨어져 나요."
    },
    {
      "start": 2002.77,
      "end": 2003.97,
      "text": "한 추세."
    },
    {
      "start": 2003.97,
      "end": 2007.09,
      "text": "보이죠 여러분? 이게 한 추세가 딱 보냈죠."
    },
    {
      "start": 2007.09,
      "end": 2008.85,
      "text": "그다음에 금락했잖아."
    },
    {
      "start": 2008.85,
      "end": 2010.45,
      "text": "또 한 추세."
    },
    {
      "start": 2010.45,
      "end": 2012.77,
      "text": "반등 이후에 또 떨어져 한 추세."
    },
    {
      "start": 2012.77,
      "end": 2017.92,
      "text": "그래서 세계에 추세 하나 둘 셋."
    },
    {
      "start": 2017.92,
      "end": 2019.68,
      "text": "그래서 인팔스가 없다."
    },
    {
      "start": 2019.68,
      "end": 2022.24,
      "text": "라고 판단을 하는 거예요."
    },
    {
      "start": 2022.24,
      "end": 2025.68,
      "text": "10월봉으로 보완을 때 여기 새북한 등 잘 안 되거든요."
    },
    {
      "start": 2025.68,
      "end": 2032.42,
      "text": "의미 없으니까 사실 필요 없어요."
    },
    {
      "start": 2032.42,
      "end": 2035.7,
      "text": "인팔스인데 에비씨 왜 다시 인팔스로 떨어져야 된"
    },
    {
      "start": 2035.7,
      "end": 2039.22,
      "text": "에비씨로 떨어져고 있다 라고 하면 우리는 일단"
    },
    {
      "start": 2039.22,
      "end": 2043.62,
      "text": "오프연장 외찔을 의심을 해봐야죠."
    },
    {
      "start": 2043.62,
      "end": 2046.82,
      "text": "지금 외찾도 두 가지인데 이렇게 하고 붙어."
    },
    {
      "start": 2046.82,
      "end": 2048.34,
      "text": "저는 너무 좋아."
    },
    {
      "start": 2048.34,
      "end": 2050.34,
      "text": "이렇게 보실 수도 있고요."
    },
    {
      "start": 2050.34,
      "end": 2056.34,
      "text": "그래서 여기까지 왼쪽 안성이다 라고 보시는 분들이 좀 있을 거예요."
    },
    {
      "start": 2056.34,
      "end": 2059.62,
      "text": "근데 제가 봤을 때는"
    },
    {
      "start": 2059.62,
      "end": 2062.82,
      "text": "아니랑 형률이 꽤 높으니까"
    },
    {
      "start": 2062.82,
      "end": 2066.66,
      "text": "이 손절라에는 반드시 잘 들어가실 분치키셔야 되고"
    },
    {
      "start": 2066.66,
      "end": 2073.23,
      "text": "저는 아마 안 들어갈 것 같아요 이 자리에."
    },
    {
      "start": 2073.23,
      "end": 2076.03,
      "text": "막 들어갈난 아이고 또 몰라도 상황 대화해야 돼."
    },
    {
      "start": 2076.03,
      "end": 2081.44,
      "text": "안 들어갈 형률이 60대로 할 mean 40%인 것 같고."
    },
    {
      "start": 2081.44,
      "end": 2087.87,
      "text": "왜냐하면 왼쪽이 여기 바닥에 너무 평평이 이런 애치지 잘 안 나오거든요."
    },
    {
      "start": 2087.95,
      "end": 2092.51,
      "text": "그래서 아직 완성 중 떨어지는 중인 거 아닌가?"
    },
    {
      "start": 2092.51,
      "end": 2100.74,
      "text": "라는 생각도 들어요."
    },
    {
      "start": 2100.74,
      "end": 2107.9,
      "text": "웜트 앱이 3, 3, 4, 5 이런 식으로."
    },
    {
      "start": 2107.9,
      "end": 2110.78,
      "text": "여기 이렇게 떨어져 이렇게 이렇게 하면서"
    },
    {
      "start": 2110.78,
      "end": 2113.1,
      "text": "다이번에서 걸릴 거거든요."
    },
    {
      "start": 2113.1,
      "end": 2116.22,
      "text": "이게 좀 더 예쁜 그림이 있네요."
    },
    {
      "start": 2116.22,
      "end": 2118.54,
      "text": "여기 진짜 바받다."
    },
    {
      "start": 2118.54,
      "end": 2121.34,
      "text": "그래서 이거를 일단 보고 있고"
    },
    {
      "start": 2121.34,
      "end": 2125.34,
      "text": "그러면 만약 이렇게 나오시면 롱이 들어가기 정말 좋죠."
    },
    {
      "start": 2125.34,
      "end": 2128.54,
      "text": "왜냐하면 다 완성 됐고, 하락 다 해보실"
    },
    {
      "start": 2128.54,
      "end": 2131.5,
      "text": "꼭 안 상승하고 해서 걸려있고"
    },
    {
      "start": 2131.5,
      "end": 2133.26,
      "text": "왼쪽 안성입니다."
    },
    {
      "start": 2133.26,
      "end": 2136.06,
      "text": "반드가는 손도 있고"
    },
    {
      "start": 2136.06,
      "end": 2140.06,
      "text": "제가 늘 강조한 손입빈 손절라니 명확함소 짧고"
    },
    {
      "start": 2140.06,
      "end": 2143.74,
      "text": "이쪽으로는 길고 그래서 이렇게 들어가게 되기고"
    },
    {
      "start": 2143.74,
      "end": 2146.46,
      "text": "그 다음, 이것까지만 이야기하고 광속을게요."
    },
    {
      "start": 2146.46,
      "end": 2150.82,
      "text": "조형부심은 눌러주세요."
    },
    {
      "start": 2150.82,
      "end": 2153.22,
      "text": "지금 이제 불기측도 보긴 해야 돼요."
    },
    {
      "start": 2153.22,
      "end": 2157.14,
      "text": "여기가 에비시인데"
    },
    {
      "start": 2157.14,
      "end": 2159.54,
      "text": "그리고 이렇게 올라갈.."
    },
    {
      "start": 2159.54,
      "end": 2160.98,
      "text": "그러니까 지금 인퍼를 시잖아요."
    },
    {
      "start": 2160.98,
      "end": 2167.3,
      "text": "그러면 인퍼를 쓰 A, B, C 이렇게 보는 게 메인 관점 이거 정석이에요."
    },
    {
      "start": 2167.3,
      "end": 2169.14,
      "text": "이제 정석입니다."
    },
    {
      "start": 2169.14,
      "end": 2174.72,
      "text": "이제 서브관점은 이게 아니라"
    },
    {
      "start": 2174.72,
      "end": 2176.24,
      "text": "이러고 올라가는 거거든요."
    },
    {
      "start": 2176.24,
      "end": 2178.48,
      "text": "왜냐하면 여기를 런닝 플라이스로 보는 거예요."
    },
    {
      "start": 2178.48,
      "end": 2180.48,
      "text": "A, B, C."
    },
    {
      "start": 2180.48,
      "end": 2184.32,
      "text": "특히 C가 인퍼를 쓰니까 런닝 플라간성이 있죠."
    },
    {
      "start": 2184.32,
      "end": 2187.84,
      "text": "평소에 런닝 플라이스 가능성을 10총도로 본다면"
    },
    {
      "start": 2187.84,
      "end": 2192.16,
      "text": "지금 런닝 플라이스 가능성을 한 20,25 정도로 보시고"
    },
    {
      "start": 2192.16,
      "end": 2197.57,
      "text": "서브관점인데 조금 높은 서브관점 보시면 되겠습니다."
    },
    {
      "start": 2197.57,
      "end": 2199.01,
      "text": "이건 다 불켰네."
    },
    {
      "start": 2199.01,
      "end": 2202.13,
      "text": "그래서 어찌 됐든 근데 어찌 됐든"
    },
    {
      "start": 2202.13,
      "end": 2205.09,
      "text": "런닝 플라이스로 올라가건"
    },
    {
      "start": 2205.09,
      "end": 2209.33,
      "text": "아니면 이제 인퍼를 쓰 A, 반등비"
    },
    {
      "start": 2209.33,
      "end": 2212.93,
      "text": "B, C 떨어지고 여기는 공통 런타점입니다."
    },
    {
      "start": 2212.93,
      "end": 2215.09,
      "text": "그쵸?"
    },
    {
      "start": 2215.09,
      "end": 2218.05,
      "text": "그래서 이 구간만, 금음통 농사점이 있기 때문에"
    },
    {
      "start": 2218.05,
      "end": 2219.73,
      "text": "진입하기 좋다."
    },
    {
      "start": 2219.73,
      "end": 2223.65,
      "text": "나는 이제 말씀을 드리고 방송을 마치��록 하겠습니다."
    },
    {
      "start": 2223.65,
      "end": 2225.33,
      "text": "자천분 넘게 보고 계신데"
    },
    {
      "start": 2225.33,
      "end": 2228.05,
      "text": "방송 너무 빨리 거 30만을 끝났네."
    },
    {
      "start": 2228.05,
      "end": 2229.25,
      "text": "미안하고."
    },
    {
      "start": 2229.25,
      "end": 2232.53,
      "text": "근데 심플하게 분석 공유 드림모도 괜찮을 것 같아서"
    },
    {
      "start": 2232.53,
      "end": 2233.73,
      "text": "공유 드렸고요."
    },
    {
      "start": 2233.73,
      "end": 2235.89,
      "text": "오늘은 배가 너무 고프고"
    },
    {
      "start": 2235.89,
      "end": 2238.69,
      "text": "칼국수 불고 있기 때문에"
    },
    {
      "start": 2240.05,
      "end": 2241.97,
      "text": "이만 마치도록 하겠습니다."
    },
    {
      "start": 2241.97,
      "end": 2244.37,
      "text": "서게에서 고맙고 주말 전역인데"
    },
    {
      "start": 2244.37,
      "end": 2248.93,
      "text": "한주 마무리 잘하시고 좋은 방 대식을 바라겠습니다."
    },
    {
      "start": 2248.93,
      "end": 2250.93,
      "text": "이만 마치겠습니다. 고맙습니다."
    }
  ]
}