      "start": 1530.9,
      "end": 1533.86,
      "text": "그 파동컨팀만 하면 이렇게 당기가 내비시 나온 것 같긴 하거든요."
    },
    {
      "start": 1533.86,
      "end": 1535.38,
      "text": "이렇게 ABC"
    },
    {
      "start": 1535.38,
      "end": 1540.06,
      "text": "단한 것 같은데"
    },
    {
      "start": 1540.06,
      "end": 1541.74,
      "text": "이 더도 똑같은 것 같아요."
    },
    {
      "start": 1541.74,
      "end": 1544.46,
      "text": "이 셰쩡 여기서 또 컴팀 해야 되는 것 빼고는"
    },
    {
      "start": 1545.58,
      "end": 1547.18,
      "text": "다른 게 없는 것 같은데"
    },
    {
      "start": 1547.98,
      "end": 1550.81,
      "text": "그리고"
    },
    {
      "start": 1550.81,
      "end": 1552.49,
      "text": "이 더 저 점이 여기잖아요."
    },
    {
      "start": 1553.21,
      "end": 1554.37,
      "text": "진저 점이"
    },
    {
      "start": 1554.37,
      "end": 1557.24,
      "text": "찍었을 때"
    },
    {
      "start": 1558.2,
      "end": 1559.8,
      "text": "3,8이 언더로 내려왔다."
    },
    {
      "start": 1559.8,
      "end": 1561.88,
      "text": "올라가는 거기 때문에"
    },
    {
      "start": 1561.88,
      "end": 1568.3,
      "text": "추세도"
    },
    {
      "start": 1568.3,
      "end": 1569.74,
      "text": "추세랑 또"
    },
    {
      "start": 1569.74,
      "end": 1571.34,
      "text": "뚜롭고"
    },
    {
      "start": 1571.34,
      "end": 1573.34,
      "text": "이 더도 추세가 딱 맞죠."
    },
    {
      "start": 1573.34,
      "end": 1574.94,
      "text": "이렇게 ABC가"
    },
    {
      "start": 1574.94,
      "end": 1576.22,
      "text": "ABC를 뚜렸죠."
    },
    {
      "start": 1576.22,
      "end": 1576.94,
      "text": "그래서"
    },
    {
      "start": 1576.94,
      "end": 1579.58,
      "text": "결국에는 이 ABC가"
    },
    {
      "start": 1579.58,
      "end": 1581.42,
      "text": "끝났다는 건데 여기서"
    },
    {
      "start": 1581.42,
      "end": 1583.26,
      "text": "그렇게 봤을 때는 조정 있다가"
    },
    {
      "start": 1583.26,
      "end": 1586.54,
      "text": "또 여길 뚫지 않고 한 번 더 올라가는"
    },
    {
      "start": 1586.54,
      "end": 1588.14,
      "text": "그림이 맞는 그림인 것 같아요."
    },
    {
      "start": 1588.14,
      "end": 1589.74,
      "text": "이 더 도와줘않지 않나지."
    },
    {
      "start": 1589.74,
      "end": 1590.78,
      "text": "그래서"
    },
    {
      "start": 1590.78,
      "end": 1592.3,
      "text": "조정 때는"
    },
    {
      "start": 1592.3,
      "end": 1594.7,
      "text": "이정도 조정 오면 롱을 계속 보는 게"
    },
    {
      "start": 1594.7,
      "end": 1600.1,
      "text": "당분간 맞는 것 같아요."
    },
    {
      "start": 1600.1,
      "end": 1601.3,
      "text": "그리야 손이 비도 맞고"
    },
    {
      "start": 1601.3,
      "end": 1614.41,
      "text": "항상 조금 더 높으니까"
    },
    {
      "start": 1614.41,
      "end": 1616.81,
      "text": "외치로 보면 중간의 볼림이 튀었다고"
    },
    {
      "start": 1616.81,
      "end": 1618.01,
      "text": "안 튀었는데"
    },
    {
      "start": 1619.13,
      "end": 1628.01,
      "text": "한께도 안 튀었는데"
    },
    {
      "start": 1628.01,
      "end": 1629.21,
      "text": "볼림 주고 있는데"
    },
    {
      "start": 1629.21,
      "end": 1634.39,
      "text": "이렇게 잘"
    },
    {
      "start": 1634.39,
      "end": 1638.71,
      "text": "여기 3번 더 올라가면 예쁘겠네요."
    },
    {
      "start": 1638.71,
      "end": 1641.51,
      "text": "3번 더 올라가주면"
    },
    {
      "start": 1641.51,
      "end": 1657.46,
      "text": "예쁜 숫자리가 나올 수 있을 것 같아요."
    },
    {
      "start": 1657.46,
      "end": 1659.3,
      "text": "그리고 이번 주에 중여한"
    },
    {
      "start": 1659.3,
      "end": 1661.46,
      "text": "그 발표들이 많아요."
    },
    {
      "start": 1661.46,
      "end": 1663.38,
      "text": "저도 원래 크게 신경 안 쓰는데"
    },
    {
      "start": 1663.38,
      "end": 1665.86,
      "text": "이번 좀 특히 많아서"
    },
    {
      "start": 1665.86,
      "end": 1667.38,
      "text": "주요"
    },
    {
      "start": 1667.38,
      "end": 1668.9,
      "text": "외신 뉴스 좀 동전해주신"
    },
    {
      "start": 1668.9,
      "end": 1674.17,
      "text": "좀 챙겨 보시면 좋을 것 같습니다."
    },
    {
      "start": 1674.17,
      "end": 1675.69,
      "text": "지금 한 5,000분 보신데"
    },
    {
      "start": 1675.69,
      "end": 1676.73,
      "text": "저의가 800개는"
    },
    {
      "start": 1676.73,
      "end": 1678.65,
      "text": "저의 한 번 10패덕끼리겠습니다."
    },
    {
      "start": 1678.65,
      "end": 1686.26,
      "text": "장기적으로 얼마까지 떨어질 것 같냐고"
    },
    {
      "start": 1686.26,
      "end": 1688.02,
      "text": "저는 근데"
    },
    {
      "start": 1688.02,
      "end": 1689.22,
      "text": "오른다고 보는 사람이"
    },
    {
      "start": 1689.22,
      "end": 1690.1,
      "text": "이렇게 올라가다 저"
    },
    {
      "start": 1690.1,
      "end": 1692.18,
      "text": "떨어졌다 다시 올라다가"
    },
    {
      "start": 1692.18,
      "end": 1694.02,
      "text": "이렇게"
    },
    {
      "start": 1694.02,
      "end": 1698.26,
      "text": "여기 보다 여기가 먼저 그럴 수 있답니다."
    },
    {
      "start": 1698.26,
      "end": 1700.42,
      "text": "내년이면 여기 가 있지 않으니까"
    },
    {
      "start": 1700.42,
      "end": 1702.1,
      "text": "3,000만 달랐다"
    },
    {
      "start": 1702.1,
      "end": 1703.22,
      "text": "3,000만 후반"
    },
    {
      "start": 1703.22,
      "end": 1704.9,
      "text": "그랬다가 한"
    },
    {
      "start": 1704.9,
      "end": 1706.74,
      "text": "여기까지 떨어질 거라고 보는데"
    },
    {
      "start": 1706.74,
      "end": 1708.74,
      "text": "한 8,000까지는 가지 않을까"
    },
    {
      "start": 1708.74,
      "end": 1722.47,
      "text": "당기하라 근처트 근처트 근처트"
    },
    {
      "start": 1722.47,
      "end": 1728.14,
      "text": "한 거 같가 참고하시면 돼요."
    },
    {
      "start": 1728.14,
      "end": 1731.42,
      "text": "그래도 시간 다시 ABC를 한 번 더"
    },
    {
      "start": 1731.42,
      "end": 1732.78,
      "text": "나온다고 해도"
    },
    {
      "start": 1732.78,
      "end": 1734.54,
      "text": "일하니까 제가 빠져될 것 같네."
    },
    {
      "start": 1734.54,
      "end": 1737.34,
      "text": "이렇게 조정하다 올라가다 다시 빠져요."
    },
    {
      "start": 1737.34,
      "end": 1741.18,
      "text": "이렇게 ABC로터지 올라갈 위치가 되지"
    },
    {
      "start": 1741.18,
      "end": 1742.7,
      "text": "여기까지 빠질 것 같아요."
    },
    {
      "start": 1742.7,
      "end": 1744.46,
      "text": "소스를 보게 되면"
    },
    {
      "start": 1744.46,
      "end": 1746.22,
      "text": "외찍 하나씩 쇼스들어가면"
    },
    {
      "start": 1746.22,
      "end": 1755.7,
      "text": "이랬니까 쇼스들 보시면 될 것 같아요."
    },
    {
      "start": 1755.7,
      "end": 1757.22,
      "text": "오늘 방송은 짧게 여기서"
    },
    {
      "start": 1757.22,
      "end": 1761.38,
      "text": "마치도록 하겠습니다."
    },
    {
      "start": 1761.38,
      "end": 1764.02,
      "text": "저의 안 눌러주는데 저의 형식 부탁드리고요."
    },
    {
      "start": 1764.02,
      "end": 1766.02,
      "text": "반 방송은"
    },
    {
      "start": 1766.02,
      "end": 1767.54,
      "text": "이번 주장 갔다 와서"
    },
    {
      "start": 1767.54,
      "end": 1769.78,
      "text": "덧끌 주장 갔다 와서"
    },
    {
      "start": 1769.78,
      "end": 1772.26,
      "text": "워러일에다 워러일에라도"
    },
    {
      "start": 1772.26,
      "end": 1773.22,
      "text": "캐스 있으면"
    },
    {
      "start": 1773.22,
      "end": 1774.82,
      "text": "워롤에 꼭 했게요."
    },
    {
      "start": 1774.82,
      "end": 1775.78,
      "text": "워롤에라를"
    },
    {
      "start": 1775.78,
      "end": 1781.69,
      "text": "워낙 캐스 기획했다."
    },
    {
      "start": 1781.69,
      "end": 1783.93,
      "text": "다음주 워낙에 꼭 방송을 기다려 하겠습니다."
    },
    {
      "start": 1783.93,
      "end": 1785.77,
      "text": "아니면 피곤하지 않으면"
    },
    {
      "start": 1785.77,
      "end": 1787.37,
      "text": "이번 주 일호를 기억하니까"
    },
    {
      "start": 1787.37,
      "end": 1789.53,
      "text": "이번 주 일호를 주말 방송이라도"
    },
    {
      "start": 1789.53,
      "end": 1791.13,
      "text": "꼭 기다려 하겠습니다."
    },
    {
      "start": 1791.13,
      "end": 1793.29,
      "text": "되게 워낙에 마음에 잘 하시고요."
    },
    {
      "start": 1793.29,
      "end": 1796.09,
      "text": "그다음에 11월 대에도"
    },
    {
      "start": 1797.13,
      "end": 1801.29,
      "text": "1일은 진행 안 되니까 1이부터 진행된다는 거 이해하시고"
    },
    {
      "start": 1801.29,
      "end": 1804.57,
      "text": "맵에 차분히 잘 하시기를 바르겠습니다."
    },
    {
      "start": 1804.57,
      "end": 1806.57,
      "text": "신회에서 시청해 주셔서 고맙 고"
    },
    {
      "start": 1806.57,
      "end": 1808.89,
      "text": "오늘 방송은 너무 짧게 해서 미안한데"
    },
    {
      "start": 1808.89,
      "end": 1810.41,
      "text": "하지만 마치도록 하겠습니다."
    },
    {
      "start": 1810.41,
      "end": 1812.57,
      "text": "좋은만 대식을 바르겠습니다."
    },
    {
      "start": 1812.57,
      "end": 1814.33,
      "text": "맵에 차분하게 잘 하세요."
    },
    {
      "start": 1814.33,
      "end": 1815.05,
      "text": "아셨죠?"
    },
    {
      "start": 1815.05,
      "end": 1817.29,
      "text": "딱히 어렵대 없는"
    },
    {
      "start": 1817.29,
      "end": 1819.21,
      "text": "지금 상황인 것 같아서"
    },
    {
      "start": 1819.21,
      "end": 1820.73,
      "text": "차분하게만 컨텐하면"
    },
    {
      "start": 1820.73,
      "end": 1822.01,
      "text": "던분가는 맵에 하시는데"
    },
    {
      "start": 1822.01,
      "end": 1823.77,
      "text": "어려워먹을 것 같습니다."
    },
    {
      "start": 1823.77,
      "end": 1826.01,
      "text": "아무튼 이만 줄이겠습니다."
    },
    {
      "start": 1826.01,
      "end": 1827.61,
      "text": "좋은만 대식을 바르겠습니다."
    },
    {
      "start": 1827.61,
      "end": 1828.57,
      "text": "고맙습니다."
    }
  ]
}