{
  "id": "tHL-bxkeBHk",
  "title": "[2025.11.23] Bitcoin Analysis #BitcoinLiveBroadcast",
  "url": "https://www.youtube.com/watch?v=tHL-bxkeBHk",
  "duration": 1296.3933125,
  "language": "ko",
  "model": "tiny",
  "elapsed_seconds": 19.9,
  "segments": [
    {
      "start": 409.01,
      "end": 410.57,
      "text": "안녕하세요 반갑습니다."
    },
    {
      "start": 410.57,
      "end": 413.33,
      "text": "방송 기사 마자 들어와주시면 반갑고"
    },
    {
      "start": 413.33,
      "end": 415.61,
      "text": "좋아요 한 번씩 부탁드리겠습니다."
    },
    {
      "start": 416.61,
      "end": 418.61,
      "text": "방송을 키는"
    },
    {
      "start": 419.01,
      "end": 420.77,
      "text": "되는 고소짜리라"
    },
    {
      "start": 421.09,
      "end": 424.09,
      "text": "아마 여기서 더 가볍이 빠지거나 아니면"
    },
    {
      "start": 424.09,
      "end": 426.05,
      "text": "이거 위로 올리면"
    },
    {
      "start": 426.37,
      "end": 428.61,
      "text": "아마 여기가 더점이었을 것 같다."
    },
    {
      "start": 428.77,
      "end": 431.49,
      "text": "나는 아주 심프란 소리를 살려고"
    },
    {
      "start": 431.49,
      "end": 432.65,
      "text": "방송을 켰습니다."
    },
    {
      "start": 432.65,
      "end": 434.25,
      "text": "저도 지금 쪼 들어갔고"
    },
    {
      "start": 434.85,
      "end": 437.85,
      "text": "첫 들어간 근거는"
    },
    {
      "start": 437.85,
      "end": 439.37,
      "text": "첫 번째로는"
    },
    {
      "start": 439.37,
      "end": 441.37,
      "text": "상단장은 아니라 그렇게 긁고"
    },
    {
      "start": 441.37,
      "end": 443.21,
      "text": "하단시지 라인 근거면"
    },
    {
      "start": 443.21,
      "end": 444.57,
      "text": "외치가 보이죠?"
    },
    {
      "start": 444.57,
      "end": 446.57,
      "text": "외치가 완전히 다면"
    },
    {
      "start": 446.57,
      "end": 448.41,
      "text": "70% 음료로"
    },
    {
      "start": 448.41,
      "end": 450.41,
      "text": "하방으로 추세가 전환이 되죠."
    },
    {
      "start": 450.41,
      "end": 452.85,
      "text": "그런게 첫 번째로 하나가 있고"
    },
    {
      "start": 452.85,
      "end": 455.21,
      "text": "두 번째로는 15분 보면"
    },
    {
      "start": 455.21,
      "end": 457.05,
      "text": "이렇게 가격이 상승했는데"
    },
    {
      "start": 457.05,
      "end": 458.85,
      "text": "아래스 아이는 떨어지면서"
    },
    {
      "start": 458.85,
      "end": 460.65,
      "text": "하락 다행건세 올렸습니다."
    },
    {
      "start": 461.61,
      "end": 463.69,
      "text": "그리고 세 번째로는"
    },
    {
      "start": 463.69,
      "end": 466.61,
      "text": "이전에 이제 반드늘 떨어지는 중"
    },
    {
      "start": 466.61,
      "end": 468.25,
      "text": "반드늘만 했다가"
    },
    {
      "start": 468.25,
      "end": 470.41,
      "text": "여기 외물 때를 만들어놓고"
    },
    {
      "start": 470.41,
      "end": 471.21,
      "text": "떨어졌죠."
    },
    {
      "start": 471.21,
      "end": 473.45,
      "text": "올라올 때 이제 저항 구간이 있습니다."
    },
    {
      "start": 473.45,
      "end": 474.73,
      "text": "외물 때 때문에"
    },
    {
      "start": 474.73,
      "end": 476.81,
      "text": "이제 외물 때로 인한 저항"
    },
    {
      "start": 476.81,
      "end": 478.97,
      "text": "이런게 이제 근본적인 이유고"
    },
    {
      "start": 478.97,
      "end": 480.09,
      "text": "이제 뭐"
    },
    {
      "start": 480.09,
      "end": 482.25,
      "text": "외메 기법적으로 보면"
    },
    {
      "start": 482.25,
      "end": 484.65,
      "text": "상단 저항 라인이 명확히 있기 때문에"
    },
    {
      "start": 484.65,
      "end": 486.01,
      "text": "이거 위로 넘기면"
    },
    {
      "start": 486.01,
      "end": 487.69,
      "text": "이 분석이 틀린 거거든요."
    },
    {
      "start": 487.69,
      "end": 489.05,
      "text": "분석이 틀림 어떻게 해요?"
    },
    {
      "start": 489.05,
      "end": 490.25,
      "text": "손절을 차야죠?"
    },
    {
      "start": 490.25,
      "end": 492.57,
      "text": "내가 진입했던 포니션을 손절을 차야죠."
    },
    {
      "start": 492.57,
      "end": 495.21,
      "text": "그래서 손절과가 매우 짧다."
    },
    {
      "start": 495.21,
      "end": 496.89,
      "text": "그래서 손절을 치면"
    },
    {
      "start": 496.89,
      "end": 499.53,
      "text": "유만큼 손절을 치면 되고"
    },
    {
      "start": 499.53,
      "end": 503.37,
      "text": "이들을 보면 이만큼 이들을 볼 거기 때문에"
    },
    {
      "start": 503.37,
      "end": 504.73,
      "text": "손이 비가 빈찬다."
    },
    {
      "start": 504.73,
      "end": 507.53,
      "text": "아까 이런 세 가지 근거돌로"
    },
    {
      "start": 507.53,
      "end": 509.53,
      "text": "이유가 있어서"
    },
    {
      "start": 509.53,
      "end": 510.81,
      "text": "소스를 보는데"
    },
    {
      "start": 510.81,
      "end": 513.13,
      "text": "손절을 치더라도 조금 치고"
    },
    {
      "start": 513.13,
      "end": 515.85,
      "text": "수익을 보면 많이 볼 것 같다."
    },
    {
      "start": 515.85,
      "end": 518.01,
      "text": "그냥 소세진 입을 했고"
    },
    {
      "start": 518.01,
      "end": 519.21,
      "text": "방송을 켰고"
    },
    {
      "start": 519.21,
      "end": 522.09,
      "text": "다음에 가끔 이제 외메적으로"
    },
    {
      "start": 522.17,
      "end": 525.37,
      "text": "바닥이 확실히 나온지 않나지 몰라요."
    },
    {
      "start": 525.37,
      "end": 528.81,
      "text": "나온 이유에 이게 찐반등이면"
    },
    {
      "start": 528.81,
      "end": 530.17,
      "text": "이렇게 대놓고"
    },
    {
      "start": 530.17,
      "end": 532.33,
      "text": "쉬운 소자를 를 주는 경우에"
    },
    {
      "start": 532.33,
      "end": 533.77,
      "text": "함정일 경우가 있어요."
    },
    {
      "start": 533.77,
      "end": 535.13,
      "text": "이런 자리다."
    },
    {
      "start": 535.13,
      "end": 536.81,
      "text": "이런 경우에는 그냥 밀어서"
    },
    {
      "start": 536.81,
      "end": 538.81,
      "text": "위로를 올려가지고"
    },
    {
      "start": 538.81,
      "end": 539.69,
      "text": "깨버든요."
    },
    {
      "start": 539.69,
      "end": 542.17,
      "text": "하락 타이번스를 깨버리고"
    },
    {
      "start": 542.17,
      "end": 544.01,
      "text": "상단 저항 라인이 깨버리고"
    },
    {
      "start": 544.01,
      "end": 545.93,
      "text": "명을 때를 깨버린 경우 있는데"
    },
    {
      "start": 545.93,
      "end": 547.85,
      "text": "보통 이럴 때는"
    },
    {
      "start": 547.85,
      "end": 550.17,
      "text": "누가 봐도 소자린 내를 깨면"
    },
    {
      "start": 550.17,
      "end": 551.53,
      "text": "급등이 좀 나와요."
    },
    {
      "start": 551.53,
      "end": 552.97,
      "text": "그렇기 때문에 여기 수습을"
    },
    {
      "start": 552.97,
      "end": 555.69,
      "text": "쉬신 분들은 반드시"
    },
    {
      "start": 555.69,
      "end": 556.73,
      "text": "손절을 해야 됩니다."
    },
    {
      "start": 556.73,
      "end": 558.97,
      "text": "들고 가면 안 돼요."
    },
    {
      "start": 558.97,
      "end": 560.89,
      "text": "그리고 이런 경우는 좀"
    },
    {
      "start": 560.89,
      "end": 562.49,
      "text": "상승 느낌이 나죠."
    },
    {
      "start": 562.49,
      "end": 564.49,
      "text": "대놓고 하락을 줬는데"
    },
    {
      "start": 564.49,
      "end": 565.53,
      "text": "하락이 뺄 Que였다."
    },
    {
      "start": 565.53,
      "end": 567.13,
      "text": "그 뭐 하겠다는 거라."
    },
    {
      "start": 567.13,
      "end": 568.73,
      "text": "상승하겠다는 거라고 했으면"
    },
    {
      "start": 568.73,
      "end": 571.61,
      "text": "여기가 바닥이 흥룰이 좀 있습니다."
    },
    {
      "start": 571.61,
      "end": 577.62,
      "text": "그 말을 싱퓨하게 하려고"
    },
    {
      "start": 577.62,
      "end": 582.42,
      "text": "그 말을 싱퓨하게 하려고 방송을 켰습니다."
    },
    {
      "start": 582.42,
      "end": 584.66,
      "text": "그리고"
    },
    {
      "start": 584.66,
      "end": 586.82,
      "text": "지난 방송을 보면"
    },
    {
      "start": 586.82,
      "end": 589.86,
      "text": "뭐 단계분석에 틀렸죠."
    },
    {
      "start": 589.86,
      "end": 592.02,
      "text": "그러니까 원래는"
    },
    {
      "start": 592.02,
      "end": 596.42,
      "text": "여기 지금 11만 5000 넘겼을 때부터"
    },
    {
      "start": 596.42,
      "end": 598.74,
      "text": "뭐 저항지"
    },
    {
      "start": 598.74,
      "end": 600.18,
      "text": "조정받고 올라가거나"
    },
    {
      "start": 600.18,
      "end": 603.3,
      "text": "아니면 이대로 떨어지거나 둘 중에 하나인데"
    },
    {
      "start": 603.3,
      "end": 604.98,
      "text": "여기를 좀 높게 보고"
    },
    {
      "start": 604.98,
      "end": 607.94,
      "text": "올라갈 거를 좀 낫게 보다가"
    },
    {
      "start": 607.94,
      "end": 610.66,
      "text": "그러니까 떨어진다에 항상 무게를 두고 방송을 하다가"
    },
    {
      "start": 610.66,
      "end": 611.86,
      "text": "이만큼 빠졌었을 때"
    },
    {
      "start": 611.86,
      "end": 613.78,
      "text": "사람들이 다 너무"
    },
    {
      "start": 613.78,
      "end": 615.38,
      "text": "빠진다고 생각을 하는 거 같게."
    },
    {
      "start": 615.38,
      "end": 616.34,
      "text": "내 시장 분위기가"
    },
    {
      "start": 616.34,
      "end": 618.5,
      "text": "5대 5정도로 보겠다."
    },
    {
      "start": 618.5,
      "end": 619.3,
      "text": "그래서"
    },
    {
      "start": 619.3,
      "end": 622.1,
      "text": "반등 왔다가 떨어지지 않으니까"
    },
    {
      "start": 622.1,
      "end": 623.22,
      "text": "조금 생각을 했는데"
    },
    {
      "start": 623.22,
      "end": 625.22,
      "text": "반등 따인 없었습니다."
    },
    {
      "start": 625.22,
      "end": 627.22,
      "text": "계속 하락했어요."
    },
    {
      "start": 627.22,
      "end": 629.22,
      "text": "그래서 결과적으로"
    },
    {
      "start": 629.22,
      "end": 630.26,
      "text": "1번 알았어요."
    },
    {
      "start": 630.26,
      "end": 633.14,
      "text": "그러면 얼마나 지금 약속했냐"
    },
    {
      "start": 633.14,
      "end": 633.94,
      "text": "1번 알았어요."
    },
    {
      "start": 633.94,
      "end": 636.58,
      "text": "12, 20"
    },
    {
      "start": 636.58,
      "end": 638.58,
      "text": "3 정도까지 떨어졌는데"
    },
    {
      "start": 638.58,
      "end": 640.98,
      "text": "이 정도까지 떨어졌을 때는"
    },
    {
      "start": 640.98,
      "end": 642.5,
      "text": "최 글라에에는"
    },
    {
      "start": 642.5,
      "end": 643.38,
      "text": "이때"
    },
    {
      "start": 643.38,
      "end": 646.18,
      "text": "곧정대로 이때 20도 앞으로 30도가 가끔 하락 있었더니"
    },
    {
      "start": 646.18,
      "end": 647.38,
      "text": "이때 좀"
    },
    {
      "start": 647.38,
      "end": 648.82,
      "text": "한 번 있었고"
    },
    {
      "start": 648.82,
      "end": 650.34,
      "text": "그 전에도"
    },
    {
      "start": 650.34,
      "end": 652.34,
      "text": "그 전에는 없었죠."
    },
    {
      "start": 652.34,
      "end": 653.54,
      "text": "20초간까지 안 하면"
    },
    {
      "start": 653.54,
      "end": 655.86,
      "text": "그 전에는 이 옛날에"
    },
    {
      "start": 655.86,
      "end": 657.86,
      "text": "저 가격이 정말 싸서"
    },
    {
      "start": 657.86,
      "end": 659.38,
      "text": "이만큼 하락했던 게 여기"
    },
    {
      "start": 659.38,
      "end": 660.5,
      "text": "지금 아픈 지켜봐주고"
    },
    {
      "start": 660.5,
      "end": 662.58,
      "text": "비슷하게 왔거든요."
    },
    {
      "start": 662.58,
      "end": 665.54,
      "text": "그래서 보통 하락장 때 20초 반대에 찍히는데"
    },
    {
      "start": 665.54,
      "end": 668.81,
      "text": "여기 여기"
    },
    {
      "start": 668.81,
      "end": 670.57,
      "text": "최근에 좀 많이 빠졌습니다."
    },
    {
      "start": 670.57,
      "end": 672.81,
      "text": "그래서 과매도 구간이지 알았어요."
    },
    {
      "start": 672.81,
      "end": 673.53,
      "text": "아이상."
    },
    {
      "start": 673.53,
      "end": 675.61,
      "text": "그래서 뭐"
    },
    {
      "start": 675.61,
      "end": 677.69,
      "text": "전부를 사실 분들은"
    },
    {
      "start": 677.69,
      "end": 680.01,
      "text": "막 지금 가격부터"
    },
    {
      "start": 680.01,
      "end": 682.25,
      "text": "저는 개인적으로는"
    },
    {
      "start": 682.25,
      "end": 684.25,
      "text": "사람들의 뭐 왼을 때 하다니니까"
    },
    {
      "start": 684.25,
      "end": 686.97,
      "text": "제일 첫 번째 볼 때는 여기고"
    },
    {
      "start": 686.97,
      "end": 688.25,
      "text": "그 다음에 여기로 보겠죠."
    },
    {
      "start": 688.25,
      "end": 690.09,
      "text": "근데 여기 있는 안 줄 거예요."
    },
    {
      "start": 690.09,
      "end": 691.69,
      "text": "이 왼을 때는"
    },
    {
      "start": 691.69,
      "end": 695.29,
      "text": "줄기가 쉽지 않을 거예요. 누구나 다"
    },
    {
      "start": 695.29,
      "end": 696.97,
      "text": "사고 싶으니까."
    },
    {
      "start": 696.97,
      "end": 698.25,
      "text": "그래서 저 왼을 때"
    },
    {
      "start": 698.25,
      "end": 699.85,
      "text": "오기 전에 틴겨져 나갈 거 같아요."
    },
    {
      "start": 699.85,
      "end": 701.13,
      "text": "그래서"
    },
    {
      "start": 701.13,
      "end": 703.29,
      "text": "만약에"
    },
    {
      "start": 703.29,
      "end": 704.73,
      "text": "여기"
    },
    {
      "start": 704.73,
      "end": 707.45,
      "text": "휴방지 0.5개가 있는 것 같은데"
    },
    {
      "start": 707.45,
      "end": 708.49,
      "text": "이번 상승 파도"
    },
    {
      "start": 708.49,
      "end": 709.29,
      "text": "이"
    },
    {
      "start": 709.29,
      "end": 710.73,
      "text": "휴방지 0.5개가 있는데"
    },
    {
      "start": 710.73,
      "end": 711.85,
      "text": "제가"
    },
    {
      "start": 711.85,
      "end": 713.29,
      "text": "가격은"
    },
    {
      "start": 713.29,
      "end": 714.89,
      "text": "7만"
    },
    {
      "start": 714.89,
      "end": 717.85,
      "text": "천점 안 되는 7만 900"
    },
    {
      "start": 717.85,
      "end": 719.53,
      "text": "7만 천"
    },
    {
      "start": 719.53,
      "end": 721.13,
      "text": "정도인데"
    },
    {
      "start": 721.13,
      "end": 722.49,
      "text": "7만 900도 라인."
    },
    {
      "start": 722.49,
      "end": 725.45,
      "text": "왜냐하면 여기가 이제 전 곳점에서"
    },
    {
      "start": 725.45,
      "end": 726.41,
      "text": "저항 받았다가"
    },
    {
      "start": 726.41,
      "end": 727.61,
      "text": "또 롤면서 시퇴 나왔다."
    },
    {
      "start": 727.61,
      "end": 729.29,
      "text": "지적. 지적."
    },
    {
      "start": 729.29,
      "end": 730.89,
      "text": "보통 그런 데에서 또"
    },
    {
      "start": 730.89,
      "end": 731.85,
      "text": "지지가 나오기 전."
    },
    {
      "start": 731.85,
      "end": 733.61,
      "text": "하거든요."
    },
    {
      "start": 733.61,
      "end": 735.29,
      "text": "그래서 만약에"
    },
    {
      "start": 735.29,
      "end": 736.65,
      "text": "이렇게 하한 반등 없이"
    },
    {
      "start": 736.65,
      "end": 738.01,
      "text": "여기까지 빠진다면"
    },
    {
      "start": 738.01,
      "end": 740.25,
      "text": "그러면 여기는 진짜 들어가 보기"
    },
    {
      "start": 740.25,
      "end": 742.09,
      "text": "좋은 자리일 것 같아요."
    },
    {
      "start": 742.09,
      "end": 743.45,
      "text": "파도 이 어떻게 할지 모르겠지만"
    },
    {
      "start": 743.45,
      "end": 744.33,
      "text": "다만"
    },
    {
      "start": 744.33,
      "end": 745.61,
      "text": "좀 제가 기대하는 건"
    },
    {
      "start": 745.61,
      "end": 748.01,
      "text": "좀 반등 왔다가 빠져야"
    },
    {
      "start": 748.01,
      "end": 748.89,
      "text": "그리고 올라와야"
    },
    {
      "start": 748.89,
      "end": 749.77,
      "text": "1 봉상"
    },
    {
      "start": 749.77,
      "end": 751.21,
      "text": "올라갔다가 빠지면서"
    },
    {
      "start": 751.21,
      "end": 753.21,
      "text": "달건스가 걸리고"
    },
    {
      "start": 753.21,
      "end": 755.13,
      "text": "상다가 걸리고"
    },
    {
      "start": 755.13,
      "end": 757.93,
      "text": "그리고 다음 상승장을 할 수 있지 않을까"
    },
    {
      "start": 757.93,
      "end": 759.77,
      "text": "생각을 하고 있습니다."
    },
    {
      "start": 759.77,
      "end": 760.89,
      "text": "그래서 개인적으로는"
    },
    {
      "start": 760.89,
      "end": 762.25,
      "text": "시원하게"
    },
    {
      "start": 762.25,
      "end": 763.93,
      "text": "저도 몰려 있어요."
    },
    {
      "start": 763.93,
      "end": 766.65,
      "text": "저도 험멸를 몰려 있어서"
    },
    {
      "start": 766.65,
      "end": 769.21,
      "text": "여러분들 연막으로 하는 소리가 안 돼."
    },
    {
      "start": 769.21,
      "end": 771.69,
      "text": "빠질 꿈은 빨리 여기까지 빠졌다가"
    },
    {
      "start": 771.69,
      "end": 773.37,
      "text": "이렇게 올라갔는 게 좋을 것 같아요."
    },
    {
      "start": 773.37,
      "end": 775.85,
      "text": "왜냐하면 이렇게 빨리 빠지면"
    },
    {
      "start": 775.85,
      "end": 777.69,
      "text": "부위자 반드개 먹거든요."
    },
    {
      "start": 777.69,
      "end": 780.89,
      "text": "근데 지적은하게 빠지으면"
    },
    {
      "start": 780.89,
      "end": 781.85,
      "text": "지적은하게 빠지으면"
    },
    {
      "start": 781.85,
      "end": 782.89,
      "text": "나중에 올라갈 때 이 외물 때"
    },
    {
      "start": 782.89,
      "end": 783.85,
      "text": "너무 힘들어요."
    },
    {
      "start": 783.85,
      "end": 784.89,
      "text": "올리기 되게 힘들다."
    },
    {
      "start": 784.89,
      "end": 786.81,
      "text": "흥보를 많이 하고 올라온다."
    },
    {
      "start": 786.81,
      "end": 788.65,
      "text": "차라리 시원하게 빠지면"
    },
    {
      "start": 788.65,
      "end": 790.25,
      "text": "시원하게 부위자 반드시 오기 때문에"
    },
    {
      "start": 790.25,
      "end": 791.61,
      "text": "차라리의 용점으로"
    },
    {
      "start": 791.61,
      "end": 794.25,
      "text": "탈력이 꽤 빵 터지하고 스프링처럼"
    },
    {
      "start": 794.25,
      "end": 796.17,
      "text": "부위자 반드시 왔으면 좋겠다."
    },
    {
      "start": 796.17,
      "end": 799.37,
      "text": "그리고 만약에 여기서 이대로 올라가면"
    },
    {
      "start": 799.37,
      "end": 800.81,
      "text": "들어 올라가면"
    },
    {
      "start": 800.81,
      "end": 803.45,
      "text": "조정에 한 번 더 엄청 옷까지 있을지"
    },
    {
      "start": 803.45,
      "end": 805.37,
      "text": "아니면 이대로 올라갈지"
    },
    {
      "start": 805.37,
      "end": 806.81,
      "text": "이 중간점 올라오게 되면"
    },
    {
      "start": 806.81,
      "end": 809.61,
      "text": "또 고민이 엄청 될 거란 말이라 인탁 들어오면"
    },
    {
      "start": 809.61,
      "end": 812.41,
      "text": "여기서 당시에 저항이 시작되니까"
    },
    {
      "start": 812.41,
      "end": 815.69,
      "text": "심한 3,000원에서 2,000 구간 되면"
    },
    {
      "start": 815.69,
      "end": 817.21,
      "text": "저항이 시작되니까"
    },
    {
      "start": 817.21,
      "end": 818.41,
      "text": "또 고민이 될 거야."
    },
    {
      "start": 818.41,
      "end": 820.25,
      "text": "이대로 진짜 찔반되니까"
    },
    {
      "start": 820.25,
      "end": 822.73,
      "text": "아니면 반등에 조화력 해줄까 싶잖아."
    },
    {
      "start": 822.73,
      "end": 825.29,
      "text": "헷갈린다고 해서 개인적으로는"
    },
    {
      "start": 825.29,
      "end": 827.69,
      "text": "차라리 아른 시일에 한일 줄여요."
    },
    {
      "start": 827.69,
      "end": 829.45,
      "text": "여기까지 딱 터치해서"
    },
    {
      "start": 829.45,
      "end": 831.69,
      "text": "시원하게 딱 찔만 달라 짓고"
    },
    {
      "start": 831.69,
      "end": 833.37,
      "text": "부위자 반드시 왔으면"
    },
    {
      "start": 833.37,
      "end": 836.74,
      "text": "이러면 훨씬 좋을 것 같아요."
    },
    {
      "start": 836.74,
      "end": 838.02,
      "text": "그럼 좋을 것 같고"
    },
    {
      "start": 838.02,
      "end": 842.07,
      "text": "여기 개인적인 바람입니다."
    },
    {
      "start": 842.07,
      "end": 843.91,
      "text": "그리고 지금 시장상함이"
    },
    {
      "start": 843.91,
      "end": 845.91,
      "text": "지난번에도 이야기했지만"
    },
    {
      "start": 845.91,
      "end": 847.67,
      "text": "사람들의 얼마나 지금 비가"
    },
    {
      "start": 847.67,
      "end": 849.41,
      "text": "좀 그런 사람들의 얼마나 비가"
    },
    {
      "start": 849.41,
      "end": 855.38,
      "text": "좀 보고 있는지"
    },
    {
      "start": 855.38,
      "end": 860.55,
      "text": "그래서 휘어엉 그리도 인택스를 보면"
    },
    {
      "start": 860.55,
      "end": 861.83,
      "text": "어디 끌 보셔도 좋아요."
    },
    {
      "start": 861.83,
      "end": 865.03,
      "text": "시에는 사실 그 통 아니고 낯살이 있는데"
    },
    {
      "start": 865.03,
      "end": 868.55,
      "text": "거의 뭐 페어링 되어있기 때문에"
    },
    {
      "start": 868.55,
      "end": 874.41,
      "text": "거의 뭐 극단적 공부 2021년"
    },
    {
      "start": 874.41,
      "end": 875.85,
      "text": "그리고 여기는 이제"
    },
    {
      "start": 875.85,
      "end": 878.41,
      "text": "알톤의 뒤부랑 옛날부터 있었던"
    },
    {
      "start": 878.41,
      "end": 880.65,
      "text": "크리터 사이트인데"
    },
    {
      "start": 880.65,
      "end": 884.57,
      "text": "11이면 엄청 극단을 공부 상태보고"
    },
    {
      "start": 884.57,
      "end": 886.65,
      "text": "코인 마크 액퇴근"
    },
    {
      "start": 886.65,
      "end": 888.41,
      "text": "그나마 옛날자로는 없어요."
    },
    {
      "start": 888.41,
      "end": 890.89,
      "text": "23명 높도 잘 되는데"
    },
    {
      "start": 890.89,
      "end": 892.97,
      "text": "지금 23년도부터는"
    },
    {
      "start": 892.97,
      "end": 895.69,
      "text": "역대 최애대로"
    },
    {
      "start": 895.69,
      "end": 897.21,
      "text": "헌포즈스가 높죠."
    },
    {
      "start": 897.21,
      "end": 899.45,
      "text": "사실 공포의 사람은 말이 있듯이"
    },
    {
      "start": 899.45,
      "end": 900.73,
      "text": "선물사시는 분들은"
    },
    {
      "start": 900.73,
      "end": 902.33,
      "text": "지금부터 한"
    },
    {
      "start": 902.33,
      "end": 904.33,
      "text": "7만까지"
    },
    {
      "start": 904.33,
      "end": 906.49,
      "text": "분활로 매수를 하면"
    },
    {
      "start": 906.49,
      "end": 909.45,
      "text": "반대가 왔었을 때 충분히 쓰기 있지 않을까"
    },
    {
      "start": 909.45,
      "end": 910.41,
      "text": "생각을 하고"
    },
    {
      "start": 910.41,
      "end": 913.29,
      "text": "개인적으로는 좀 힘들더라도"
    },
    {
      "start": 913.29,
      "end": 915.37,
      "text": "7만을 떨리더라도"
    },
    {
      "start": 915.37,
      "end": 918.17,
      "text": "귀자반들이 오는게"
    },
    {
      "start": 918.17,
      "end": 919.77,
      "text": "차라리 어색픽에 올라갔다가"
    },
    {
      "start": 919.77,
      "end": 922.09,
      "text": "또 조정받아서 다 7만을 꼭 끌아봤고"
    },
    {
      "start": 922.09,
      "end": 924.41,
      "text": "시간이 오래 걸려서 또 저항이 많이 쌓인 거"
    },
    {
      "start": 924.41,
      "end": 925.69,
      "text": "오래 걸려 힘들고 올라간 거고"
    },
    {
      "start": 925.69,
      "end": 928.89,
      "text": "나는 차라리 이왕 여기 갈 거면"
    },
    {
      "start": 928.89,
      "end": 930.81,
      "text": "빨리 떨렸다고 귀자반동안 와주고"
    },
    {
      "start": 930.81,
      "end": 932.17,
      "text": "맵을게 안 싹고"
    },
    {
      "start": 932.17,
      "end": 934.89,
      "text": "맵을게 안 만들고 저항 없을 쭉"
    },
    {
      "start": 934.89,
      "end": 937.37,
      "text": "빨리 올라갔으면 하는 바람입니다"
    },
    {
      "start": 937.37,
      "end": 943.22,
      "text": "개인적인 바람은"
    },
    {
      "start": 943.22,
      "end": 945.22,
      "text": "그리고 만약에 이번에"
    },
    {
      "start": 945.22,
      "end": 947.94,
      "text": "이대로 계속 떨어져 줄지 모르겠지만"
    },
    {
      "start": 947.94,
      "end": 950.98,
      "text": "만약에 진짜 떨어져서 7만을 찍는다"
    },
    {
      "start": 950.98,
      "end": 953.7,
      "text": "그러면 그때부터는 이제"
    },
    {
      "start": 953.7,
      "end": 956.5,
      "text": "시즌 종료한 사람들 등등석 알겨됩니다"
    },
    {
      "start": 956.5,
      "end": 957.86,
      "text": "이제부터 시즌 시작해요"
    },
    {
      "start": 957.86,
      "end": 959.14,
      "text": "여기가"
    },
    {
      "start": 959.14,
      "end": 960.34,
      "text": "치면"
    },
    {
      "start": 960.34,
      "end": 962.82,
      "text": "새로운 시즌을 시작입니다"
    },
    {
      "start": 962.82,
      "end": 965.46,
      "text": "여기서 또 3 시즌 시작되는 걸 세파동"
    },
    {
      "start": 965.46,
      "end": 967.22,
      "text": "이런 해상도 받아나오고"
    },
    {
      "start": 967.22,
      "end": 968.98,
      "text": "일단 이렇게 하면서 엄청 오를 거거든요"
    },
    {
      "start": 968.98,
      "end": 970.34,
      "text": "좋겠네"
    },
    {
      "start": 971.3,
      "end": 974.02,
      "text": "제가 개인적인 바람은 오늘 지금"
    },
    {
      "start": 974.02,
      "end": 975.3,
      "text": "내 차례 이야기하고 있지만"
    },
    {
      "start": 975.3,
      "end": 977.46,
      "text": "7만을 그냥 시원하게 빨리 찍고"
    },
    {
      "start": 977.46,
      "end": 978.58,
      "text": "붙잡았는데 화자"
    },
    {
      "start": 979.86,
      "end": 981.14,
      "text": "나는 겁니다"
    },
    {
      "start": 981.14,
      "end": 982.26,
      "text": "지금 왼지 아닌가요?"
    },
    {
      "start": 982.26,
      "end": 985.77,
      "text": "왼지 6초 들어가 있습니다"
    },
    {
      "start": 985.77,
      "end": 988.33,
      "text": "방송 시작하자마자 말씀드려서"
    },
    {
      "start": 988.33,
      "end": 990.73,
      "text": "무엇인분들이 계실 텐데"
    },
    {
      "start": 990.73,
      "end": 992.65,
      "text": "누가 봐도 왼지죠?"
    },
    {
      "start": 992.65,
      "end": 994.97,
      "text": "수상할 정도로 왼지에요"
    },
    {
      "start": 994.97,
      "end": 998.01,
      "text": "대놓고 여기 쇼쳐야지"
    },
    {
      "start": 998.01,
      "end": 999.69,
      "text": "이거 차트근상 못해서 쇼"
    },
    {
      "start": 999.69,
      "end": 1002.33,
      "text": "쇼 안치면 호구지라고 쇼욱 정도로 왼지"
    },
    {
      "start": 1002.33,
      "end": 1004.33,
      "text": "그래서 좀 의심스럽게 해요"
    },
    {
      "start": 1004.33,
      "end": 1005.69,
      "text": "근데 의심을 사람에도 불구하고"
    },
    {
      "start": 1005.69,
      "end": 1006.73,
      "text": "쇼쳐서 들어가는 이유는"
    },
    {
      "start": 1006.73,
      "end": 1008.49,
      "text": "손질 라인 너무 짧잖아"
    },
    {
      "start": 1008.49,
      "end": 1010.33,
      "text": "그냥 상당히 여기"
    },
    {
      "start": 1010.33,
      "end": 1012.09,
      "text": "찍고 올라가면 바로 손질 치지 뭐"
    },
    {
      "start": 1012.09,
      "end": 1014.89,
      "text": "손질 얼마 안 되잖아요"
    },
    {
      "start": 1014.89,
      "end": 1016.57,
      "text": "그래서 왼지 보고"
    },
    {
      "start": 1016.57,
      "end": 1018.57,
      "text": "남의 10월봉을 하락대용을 보고"
    },
    {
      "start": 1018.57,
      "end": 1019.61,
      "text": "여기 맵을 때 있죠"
    },
    {
      "start": 1019.61,
      "end": 1020.65,
      "text": "맵을 때 보고"
    },
    {
      "start": 1020.65,
      "end": 1022.01,
      "text": "하락할 거나"
    },
    {
      "start": 1022.01,
      "end": 1024.25,
      "text": "라고 생각을 해서"
    },
    {
      "start": 1024.25,
      "end": 1027.45,
      "text": "왼지 쇼쳐서 들어가고 손이 꽤 좋고"
    },
    {
      "start": 1027.45,
      "end": 1030.57,
      "text": "밑절은 첫 맵을 때 하나도 안 영점을 못 간해서 할 거니까"
    },
    {
      "start": 1030.57,
      "end": 1033.05,
      "text": "반이 쪼른 연예살을 보고"
    },
    {
      "start": 1033.05,
      "end": 1034.41,
      "text": "제 수가 좋아서"
    },
    {
      "start": 1034.41,
      "end": 1035.85,
      "text": "저점이 겸신다면"
    },
    {
      "start": 1035.85,
      "end": 1036.73,
      "text": "저점 겸신다고"
    },
    {
      "start": 1036.73,
      "end": 1042.31,
      "text": "어딘가에서 또 많이 쪼를 하겠죠"
    },
    {
      "start": 1042.31,
      "end": 1044.79,
      "text": "그럴 맵에 계획이고"
    },
    {
      "start": 1044.79,
      "end": 1048.15,
      "text": "오늘 17분짜리 방송 인데"
    },
    {
      "start": 1048.15,
      "end": 1051.43,
      "text": "앞에 6분은 안과를 안 했으니까"
    },
    {
      "start": 1051.43,
      "end": 1055.16,
      "text": "10분 컷 방송이 들네요"
    },
    {
      "start": 1055.16,
      "end": 1056.92,
      "text": "오늘 방송은 짧게"
    },
    {
      "start": 1056.92,
      "end": 1059.24,
      "text": "이렇게 마치도록 하겠습니다"
    },
    {
      "start": 1059.24,
      "end": 1062.84,
      "text": "2000 7분 정도 갑자기 들어주셨는데"
    },
    {
      "start": 1062.84,
      "end": 1065.96,
      "text": "다음에 또 구독 누르시고 좋아요 누르시고"
    },
    {
      "start": 1065.96,
      "end": 1067.64,
      "text": "제가 방송 보시면"
    },
    {
      "start": 1067.64,
      "end": 1068.84,
      "text": "좋은 탓점 공유에 들이고"
    },
    {
      "start": 1068.84,
      "end": 1071.0,
      "text": "좋은 댄서 더군요 해드리도록 하겠습니다"
    },
    {
      "start": 1071.0,
      "end": 1074.52,
      "text": "아 맞다 그리고 시리얼의 희소식이 있습니다"
    },
    {
      "start": 1074.52,
      "end": 1080.54,
      "text": "희소식 다음 달"
    },
    {
      "start": 1080.54,
      "end": 1081.74,
      "text": "1"
    },
    {
      "start": 1081.74,
      "end": 1085.03,
      "text": "한금이"
    },
    {
      "start": 1085.03,
      "end": 1087.51,
      "text": "여기 개인대에요"
    },
    {
      "start": 1087.51,
      "end": 1089.19,
      "text": "왜냐하면"
    },
    {
      "start": 1089.19,
      "end": 1091.43,
      "text": "10월대의 우승자분이"
    },
    {
      "start": 1091.67,
      "end": 1098.1,
      "text": "상금 5천만 2.8호 이 분하쏘리"
    },
    {
      "start": 1098.1,
      "end": 1099.62,
      "text": "10월대의 우승자분이"
    },
    {
      "start": 1099.62,
      "end": 1101.86,
      "text": "상금이 1등이 5천만 있잖아요"
    },
    {
      "start": 1101.86,
      "end": 1105.46,
      "text": "근데 인터뷰 지방 소도시 공모원 이래요"
    },
    {
      "start": 1105.46,
      "end": 1106.98,
      "text": "그리고 이메일에 왔는데"
    },
    {
      "start": 1106.98,
      "end": 1108.1,
      "text": "지금 소도시 공모원이고"
    },
    {
      "start": 1108.1,
      "end": 1111.54,
      "text": "자기 주변에 자객 때문에 비트코인한 분들이 덜어있는데"
    },
    {
      "start": 1111.54,
      "end": 1113.14,
      "text": "제가 이렇게 큰 도무지 모른대요"
    },
    {
      "start": 1113.14,
      "end": 1114.26,
      "text": "그래서"
    },
    {
      "start": 1114.26,
      "end": 1116.58,
      "text": "내가 돈 뭐랬다고 하면"
    },
    {
      "start": 1116.58,
      "end": 1118.98,
      "text": "그러면 좀 주변에서 시선이 안 좋기 때문에"
    },
    {
      "start": 1118.98,
      "end": 1122.58,
      "text": "지금 워낙 소도시 회사적인 근거 아니라"
    },
    {
      "start": 1122.58,
      "end": 1123.78,
      "text": "원래 얘기했던 것처럼"
    },
    {
      "start": 1123.78,
      "end": 1124.9,
      "text": "만약 인터뷰 안 하면"
    },
    {
      "start": 1124.9,
      "end": 1128.42,
      "text": "1,500만 원"
    },
    {
      "start": 1128.42,
      "end": 1130.98,
      "text": "지급하고 3,500만 원은"
    },
    {
      "start": 1130.98,
      "end": 1131.7,
      "text": "이 월대요죠"
    },
    {
      "start": 1131.7,
      "end": 1134.26,
      "text": "그래서 12월대에 를 이어 를 했고"
    },
    {
      "start": 1134.26,
      "end": 1136.74,
      "text": "그래서 12월대 우승자는"
    },
    {
      "start": 1136.74,
      "end": 1139.06,
      "text": "5천만 원이 아니라 8,500만 원입니다"
    },
    {
      "start": 1139.06,
      "end": 1140.1,
      "text": "상금이"
    },
    {
      "start": 1140.1,
      "end": 1141.06,
      "text": "다음에"
    },
    {
      "start": 1141.06,
      "end": 1144.34,
      "text": "5K에서 공식 배에가 열려요"
    },
    {
      "start": 1144.34,
      "end": 1145.94,
      "text": "6K에서 공식 배가 열리는데"
    },
    {
      "start": 1145.94,
      "end": 1149.4,
      "text": "저 참가할 예정입니다"
    },
    {
      "start": 1149.4,
      "end": 1150.36,
      "text": "그래서"
    },
    {
      "start": 1150.36,
      "end": 1153.32,
      "text": "이 중요한 건 어느 대회에 선가야 되냐"
    },
    {
      "start": 1153.32,
      "end": 1155.96,
      "text": "아니 정시찬가가 된다"
    },
    {
      "start": 1155.96,
      "end": 1157.0,
      "text": "그래서"
    },
    {
      "start": 1157.0,
      "end": 1158.52,
      "text": "대회에 나가게 되면"
    },
    {
      "start": 1158.52,
      "end": 1161.08,
      "text": "저 OKX 저 이 팀을 나가게 되면"
    },
    {
      "start": 1161.08,
      "end": 1162.04,
      "text": "저 이 팀 우승하면"
    },
    {
      "start": 1162.04,
      "end": 1164.28,
      "text": "당이 상금 100은 받을 거고"
    },
    {
      "start": 1164.28,
      "end": 1165.96,
      "text": "또 잘해가지고 저 개인 대회에서"
    },
    {
      "start": 1165.96,
      "end": 1169.16,
      "text": "상금이 지급될 것 같던데"
    },
    {
      "start": 1169.16,
      "end": 1171.0,
      "text": "12월에 상금 포기"
    },
    {
      "start": 1171.0,
      "end": 1171.8,
      "text": "매우 크다"
    },
    {
      "start": 1171.8,
      "end": 1174.36,
      "text": "다음에 받을 확률을 매우 높다"
    },
    {
      "start": 1174.36,
      "end": 1178.04,
      "text": "그래서 12월에는 10월 11월에는"
    },
    {
      "start": 1178.04,
      "end": 1179.72,
      "text": "하락정 때문에 좀 손에 보시분들이"
    },
    {
      "start": 1179.72,
      "end": 1182.28,
      "text": "덜어와는 것 같은데 저도 그렇고"
    },
    {
      "start": 1182.28,
      "end": 1183.88,
      "text": "오늘 거래소를 심하지 않냐고"
    },
    {
      "start": 1183.88,
      "end": 1185.64,
      "text": "루는데 저 최근에 손절"
    },
    {
      "start": 1185.64,
      "end": 1188.28,
      "text": "연속 두 번인가 3번 찾거든요"
    },
    {
      "start": 1188.28,
      "end": 1189.24,
      "text": "방송 안 하는 동안"
    },
    {
      "start": 1189.24,
      "end": 1191.24,
      "text": "다음에 손절을 해볼게요"
    },
    {
      "start": 1191.24,
      "end": 1193.08,
      "text": "아무튼"
    },
    {
      "start": 1193.8,
      "end": 1195.56,
      "text": "힘든 분들 좀 있었는데"
    },
    {
      "start": 1195.56,
      "end": 1197.8,
      "text": "다음 달 10월에는 연말인데"
    },
    {
      "start": 1197.8,
      "end": 1199.72,
      "text": "25년에 마지막 달인데"
    },
    {
      "start": 1199.72,
      "end": 1201.24,
      "text": "한 번 멋지게"
    },
    {
      "start": 1201.24,
      "end": 1202.28,
      "text": "수익으로"
    },
    {
      "start": 1202.28,
      "end": 1203.32,
      "text": "남해오서"
    },
    {
      "start": 1203.32,
      "end": 1205.8,
      "text": "마무리 하는 연말에"
    },
    {
      "start": 1205.8,
      "end": 1207.32,
      "text": "그런 한 달에 됐으면 좋겠고"
    },
    {
      "start": 1207.32,
      "end": 1209.96,
      "text": "그런 음미를 저도 대회 나갈 거고"
    },
    {
      "start": 1210.92,
      "end": 1214.36,
      "text": "폼이 명당 폼 주갔네"
    },
    {
      "start": 1214.36,
      "end": 1216.28,
      "text": "나는 세팅이"
    },
    {
      "start": 1216.28,
      "end": 1217.56,
      "text": "덜어있어요"
    },
    {
      "start": 1217.56,
      "end": 1218.76,
      "text": "덜어"
    },
    {
      "start": 1218.76,
      "end": 1221.72,
      "text": "방송하면 한 개씩 올라오고 하는데"
    },
    {
      "start": 1221.72,
      "end": 1222.52,
      "text": "근데 뭐"
    },
    {
      "start": 1222.52,
      "end": 1224.84,
      "text": "늙을 있었던 이야기고"
    },
    {
      "start": 1224.84,
      "end": 1227.88,
      "text": "폼원 죽었지만 클래스는 영원하다는 걸 한 번"
    },
    {
      "start": 1227.88,
      "end": 1229.08,
      "text": "응"
    },
    {
      "start": 1229.08,
      "end": 1231.72,
      "text": "노력해보겠습니다"
    },
    {
      "start": 1231.72,
      "end": 1235.72,
      "text": "아무튼 그래서 10월달에 이런 대회가 있으니까"
    },
    {
      "start": 1235.72,
      "end": 1237.4,
      "text": "저희 다 같이 한 번"
    },
    {
      "start": 1237.4,
      "end": 1239.48,
      "text": "연말에 화이팅해서"
    },
    {
      "start": 1239.48,
      "end": 1243.0,
      "text": "잘 수익으로 마무리 해보면 좋겠네요"
    },
    {
      "start": 1243.0,
      "end": 1243.8,
      "text": "이러면 인데"
    },
    {
      "start": 1243.8,
      "end": 1246.28,
      "text": "방송 봐주셔서 고맙고"
    },
    {
      "start": 1246.28,
      "end": 1247.88,
      "text": "다음 또 방송 때"
    },
    {
      "start": 1247.88,
      "end": 1249.0,
      "text": "인사하테리도 하겠습니다"
    },
    {
      "start": 1249.0,
      "end": 1250.92,
      "text": "한주한 고생 많으셨고"
    },
    {
      "start": 1250.92,
      "end": 1251.92,
      "text": "편안한 반"
    },
    {
      "start": 1251.92,
      "end": 1253.0,
      "text": "편안한 주말 반"
    },
    {
      "start": 1253.0,
      "end": 1254.36,
      "text": "다시게 바랍니다"
    },
    {
      "start": 1254.36,
      "end": 1255.4,
      "text": "고맙습니다"
    }
  ]
}