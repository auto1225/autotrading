    },
    {
      "start": 575.06,
      "end": 576.22,
      "text": "일단은"
    },
    {
      "start": 576.22,
      "end": 578.66,
      "text": "11월 달은 이렇게 운영하겠습니다"
    },
    {
      "start": 578.66,
      "end": 581.42,
      "text": "원래는 1등이 4,000만 원 시계 없고"
    },
    {
      "start": 581.42,
      "end": 584.34,
      "text": "2,000 등이 1,000만 원 시계였죠"
    },
    {
      "start": 584.34,
      "end": 586.3,
      "text": "여기 1,000만 원 올렸고"
