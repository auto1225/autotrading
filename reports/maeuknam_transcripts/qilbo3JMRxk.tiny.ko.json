  "segments": [
    {
      "start": 368.4,
      "end": 375.41,
      "text": "네, 안녕하세요 반갑습니다."
    },
    {
      "start": 375.41,
      "end": 380.46,
      "text": "방송을 이해할 줄 알았는데"
    },
    {
      "start": 380.46,
      "end": 382.84,
      "text": "한 3살 동안 계속 술엄하고 있죠?"
    },
    {
      "start": 382.84,
      "end": 386.46,
      "text": "할 게 없어서 방송을 안 했고"
    },
    {
      "start": 386.46,
      "end": 388.64,
      "text": "근데 지난 방송할 때"
    },
    {
      "start": 388.64,
      "end": 391.86,
      "text": "한 가지 말 안 해 준 게 있어서"
    },
    {
      "start": 391.86,
      "end": 395.08,
      "text": "그거를 오늘 방송에서 말씀드리면 좋겠다 싶다 싶다"
    },
    {
      "start": 395.08,
      "end": 396.82,
      "text": "퍼서 방송을 켜고요"
    },
    {
      "start": 396.82,
      "end": 399.48,
      "text": "나 오늘의 11월 1일이잖아요"
    },
    {
      "start": 399.48,
      "end": 402.56,
      "text": "매달 1일부터는 대회가 시작되는데"
    },
    {
      "start": 402.56,
      "end": 406.8,
      "text": "대회가 관련되서 문의가 엄청 많더라고요"
    },
    {
      "start": 406.8,
      "end": 408.88,
      "text": "그래서 대회 안 내 간단하게"
    },
    {
      "start": 408.88,
      "end": 411.52,
      "text": "드디어 방송 켜습니다"
    },
    {
      "start": 411.52,
      "end": 412.68,
      "text": "대회 안 내 드리고"
    },
    {
      "start": 412.68,
      "end": 415.62,
      "text": "상갑실은 매달에서 짧게 이야기하고"
    },
    {
      "start": 415.62,
      "end": 418.62,
      "text": "오늘은 빠르게 방송 종류하도록 하겠습니다"
    },
    {
      "start": 418.62,
      "end": 422.58,
      "text": "일단 대회 폐지 인데"
    },
    {
      "start": 422.58,
      "end": 425.16,
      "text": "끝나고"
    },
    {
      "start": 425.16,
      "end": 427.14,
      "text": "커뮤니티의 공지 올려 드릴건데"
    },
    {
      "start": 427.14,
      "end": 434.63,
      "text": "보시면 되고"
    },
    {
      "start": 434.63,
      "end": 438.21,
      "text": "위하셔야 될 점 하나는 조잉 나올 공 누르시라 된다는 거"
    },
    {
      "start": 438.21,
      "end": 439.81,
      "text": "현재에는 그래요"
