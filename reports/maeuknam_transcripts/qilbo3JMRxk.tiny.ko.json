    },
    {
      "start": 459.9,
      "end": 461.22,
      "text": "의미가"
    },
    {
      "start": 461.22,
      "end": 462.34,
      "text": "따라 와서 가지고"
    },
    {
      "start": 462.34,
      "end": 464.9,
